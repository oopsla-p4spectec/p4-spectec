;;
;; Control body evaluation
;;
;; syntax controlBodyIR = blockStatementIR
;;

rulegroup ControlBody_eval {

  rule ControlBody_eval/cont:
    EC_0 ARCH_0 |- controlBodyIR
                 : EC_1 ARCH_1 (RETURN eps)
    -- Block_eval:
        EC_0 ARCH_0 |- controlBodyIR
                     : EC_1 ARCH_1 `EMPTY

  rule ControlBody_eval/exit:
    EC_0 ARCH_0 |- controlBodyIR
                 : EC_1 ARCH_1 EXIT
    -- Block_eval:
        EC_0 ARCH_0 |- controlBodyIR
                     : EC_1 ARCH_1 EXIT

  rule ControlBody_eval/return:
    EC_0 ARCH_0 |- controlBodyIR
                 : EC_1 ARCH_1 (RETURN eps)
    -- Block_eval:
        EC_0 ARCH_0 |- controlBodyIR
                     : EC_1 ARCH_1 (RETURN eps)

}
