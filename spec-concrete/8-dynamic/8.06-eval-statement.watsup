;;
;; Statement evaluation
;;
;; syntax statementIR
;;

;;; emptyStatementIR

rule Stmt_eval/emptyStatementIR:
  p EC ARCH |- `; : EC ARCH `EMPTY

;;; assignmentStatementIR
;;; syntax assignmentStatementIR = typedLvalueIR assignop typedExpressionIR `;

rulegroup Stmt_eval/assignmentStatementIR {

  rule Stmt_eval/typedLvalueIR-abort:
    p EC_0 ARCH_0 |- typedLvalueIR assignop typedExpressionIR `;
                   : EC_1 ARCH_1 abortResult
    ---- ;; evaluate l-value
    -- Lvalue_eval:
        p EC_0 ARCH_0 |- typedLvalueIR
                       : EC_1 ARCH_1 abortResult

  rule Stmt_eval/typedLvalueIR-cont-eq-typedExpressionIR-abort:
    p EC_0 ARCH_0 |- typedLvalueIR assignop typedExpressionIR `;
                   : EC_2 ARCH_2 abortResult
    ---- ;; evaluate l-value
    -- Lvalue_eval:
        p EC_0 ARCH_0 |- typedLvalueIR
                       : EC_1 ARCH_1 (`` storageReference)
    ---- ;; evaluate expression
    -- Expr_eval:
        p EC_1 ARCH_1 |- typedExpressionIR
                       : EC_2 ARCH_2 abortResult

  rule Stmt_eval/typedLvalueIR-cont-eq-typedExpressionIR-cont:
    p EC_0 ARCH_0 |- typedLvalueIR assignop typedExpressionIR `;
                   : EC_3 ARCH_2 `EMPTY
    ---- ;; evaluate l-value
    -- Lvalue_eval:
        p EC_0 ARCH_0 |- typedLvalueIR
                       : EC_1 ARCH_1 (`` storageReference)
    ---- ;; evaluate expression
    -- Expr_eval:
        p EC_1 ARCH_1 |- typedExpressionIR
                       : EC_2 ARCH_2 (`` value)
    ---- ;; perform assignment
    -- Lvalue_write:
        p EC_2 ARCH_2 |- storageReference -> value
                       : EC_3

}

;;; callStatementIR
;;; syntax callStatementIR =
;;;   routineTargetIR `< typeArgumentListIR > `( argumentListIR ) `;

rulegroup Stmt_eval/callStatementIR {

  rule Stmt_eval/callee-abort:
    p EC_0 ARCH_0 |- callableTargetIR `< typeArgumentIR* > `( argumentIR* ) `;
                   : EC_1 ARCH_1 abortResult
    -- Callee_eval:
        p EC_0 ARCH_0 |- callableTargetIR `< `_ > `( argumentIR* )
                       : EC_1 ARCH_1 abortResult

  rule Stmt_eval/callee-cont-call-abort:
    p EC_0 ARCH_0 |- callableTargetIR `< typeArgumentIR* > `( argumentIR* ) `;
                   : EC_2 ARCH_2 abortResult
    -- Callee_eval:
        p EC_0 ARCH_0 |- callableTargetIR `< `_ > `( argumentIR* )
                       : EC_1 ARCH_1 (`` callee)
    -- Call_eval:
        p EC_1 ARCH_1 |- callee `@ `< typeArgumentIR* > `( argumentIR* )
                       : EC_2 ARCH_2 abortResult

  rule Stmt_eval/callee-cont-call-return:
    p EC_0 ARCH_0 |- callableTargetIR `< typeArgumentIR* > `( argumentIR* ) `;
                   : EC_2 ARCH_2 `EMPTY
    -- Callee_eval:
        p EC_0 ARCH_0 |- callableTargetIR `< `_ > `( argumentIR* )
                       : EC_1 ARCH_1 (`` callee)
    -- Call_eval:
        p EC_1 ARCH_1 |- callee `@ `< typeArgumentIR* > `( argumentIR* )
                       : EC_2 ARCH_2 returnResult

}

;;; directApplicationStatementIR
;;; direct applications should have been handled during instantiation

;;; returnStatementIR
;;; syntax returnStatementIR

;;;; RETURN `;
;;;; RETURN typedExpressionIR `;

rulegroup Stmt_eval/returnStatementIR {

  rule Stmt_eval/non-expression:
    LOCAL EC ARCH |- RETURN `; : EC ARCH (RETURN eps)

  rule Stmt_eval/expression-abort:
    LOCAL EC_0 ARCH_0 |- RETURN typedExpressionIR `;
                       : EC_1 ARCH_1 abortResult
    -- Expr_eval:
        LOCAL EC_0 ARCH_0 |- typedExpressionIR
                           : EC_1 ARCH_1 abortResult

  rule Stmt_eval/expression-cont:
    LOCAL EC_0 ARCH_0 |- RETURN typedExpressionIR `;
                       : EC_1 ARCH_1 (RETURN value)
    -- Expr_eval:
        LOCAL EC_0 ARCH_0 |- typedExpressionIR
                           : EC_1 ARCH_1 (`` value)

}

;;; exitStatementIR
;;; syntax exitStatementIR = EXIT `;

rule Stmt_eval/exitStatementIR:
  p EC ARCH |- EXIT `; : EC ARCH EXIT

;;; syntax blockStatementIR =
;;;   annotationList `{ blockElementStatementListIR }

rule Stmt_eval/blockStatementIR:
  p EC_0 ARCH_0 |- blockStatementIR
                 : EC_3 ARCH_1 statementResult
  -- if EC_1 = $enter_e(EC_0)
  -- Block_eval:
      EC_1 ARCH_0 |- blockStatementIR
                   : EC_2 ARCH_1 statementResult
  -- if EC_3 = $exit_e(EC_2)

;;; conditionalStatementIR
;;; syntax conditionalStatementIR

;;;; IF `( typedExpressionIR ) statementIR
;;;; IF `( typedExpressionIR ) statementIR ELSE statementIR

rulegroup Stmt_eval/conditionalStatementIR {

  rule Stmt_eval/non-else-abort:
    p EC ARCH |- IF `( typedExpressionIR_cond ) statementIR_then
               : EC_cond ARCH_cond abortResult
    -- Expr_eval:
        p EC ARCH |- typedExpressionIR_cond
                   : EC_cond ARCH_cond abortResult

  rule Stmt_eval/non-else-cont-true:
    p EC ARCH |- IF `( typedExpressionIR_cond ) statementIR_then
               : EC_then ARCH_then statementResult
    -- Expr_eval:
        p EC ARCH |- typedExpressionIR_cond
                   : EC_cond ARCH_cond (`` (`B true))
    -- Stmt_eval:
        p EC_cond ARCH_cond |- statementIR_then
                             : EC_then ARCH_then statementResult

  rule Stmt_eval/non-else-cont-false:
    p EC ARCH |- IF `( typedExpressionIR_cond ) statementIR_then
               : EC_cond ARCH_cond `EMPTY
    -- Expr_eval:
        p EC ARCH |- typedExpressionIR_cond
                   : EC_cond ARCH_cond (`` (`B false))

  rule Stmt_eval/else-abort:
    p EC ARCH |- IF `( typedExpressionIR_cond ) statementIR_then
                ELSE statementIR_else
               : EC_cond ARCH_cond abortResult
    -- Expr_eval:
        p EC ARCH |- typedExpressionIR_cond
                   : EC_cond ARCH_cond abortResult

  rule Stmt_eval/else-cont-true:
    p EC ARCH |- IF `( typedExpressionIR_cond ) statementIR_then
                ELSE statementIR_else
               : EC_then ARCH_then statementResult
    -- Expr_eval:
        p EC ARCH |- typedExpressionIR_cond
                   : EC_cond ARCH_cond (`` (`B true))
    -- Stmt_eval:
        p EC_cond ARCH_cond |- statementIR_then
                             : EC_then ARCH_then statementResult

  rule Stmt_eval/else-cont-false:
    p EC ARCH |- IF `( typedExpressionIR_cond ) statementIR_then
                ELSE statementIR_else
               : EC_else ARCH_else statementResult
    -- Expr_eval:
        p EC ARCH |- typedExpressionIR_cond
                   : EC_cond ARCH_cond (`` (`B false))
    -- Stmt_eval:
        p EC_cond ARCH_cond |- statementIR_else
                             : EC_else ARCH_else statementResult

}

;;; forStatementIR
;;; syntax forStatementIR

;;;; annotationList FOR
;;;;   `( forInitStatementListIR `; typedExpressionIR `; forUpdateStatementListIR )
;;;;   statementIR

;;;;; syntax forUpdateStatementIR

relation ForUpdateStmt_eval:
  evalContext arch |- forUpdateStatementIR
                    : evalContext arch statementResult
  hint(input %0 %1 %2)
  hint(prose_in "runtime evaluation of" %2#
                ", under evaluation context" %0 "and state" %1)
  hint(prose_out "\nthe updated evaluation context" %3#
                 ", state" %4#", and" %5)

;;;;;; callableTargetIR `< typeArgumentListIR > `( argumentListIR )
;;;;;; typedLvalueIR assignop typedExpressionIR

rulegroup ForUpdateStmt_eval {

  rule ForUpdateStmt_eval/call:
    EC_0 ARCH_0 |- callableTargetIR `< typeArgumentListIR > `( argumentListIR )
                 : EC_1 ARCH_1 statementResult
    -- Stmt_eval: 
        LOCAL EC_0 ARCH_0 |- callableTargetIR `< typeArgumentListIR > `( argumentListIR ) `;
                           : EC_1 ARCH_1 statementResult

  rule ForUpdateStmt_eval/assign:
    EC_0 ARCH_0 |- typedLvalueIR assignop typedExpressionIR
                 : EC_1 ARCH_1 statementResult
    -- Stmt_eval: LOCAL EC_0 ARCH_0 |- typedLvalueIR assignop typedExpressionIR `;
                                     : EC_1 ARCH_1 statementResult

}

;;;;; syntax forUpdateStatementListIR = forUpdateStatementIR*

relation ForUpdateStmts_eval:
  evalContext arch |- forUpdateStatementListIR
                    : evalContext arch statementResult
  hint(input %0 %1 %2)
  hint(prose_in "runtime evaluation of" %2#
                ", under evaluation context" %0 "and state" %1)
  hint(prose_out "\nthe updated evaluation context" %3#
                 ", state" %4#", and" %5)

rulegroup ForUpdateStmts_eval {

  rule ForUpdateStmts_eval/nil:
    EC ARCH |- eps : EC ARCH `EMPTY

  rule ForUpdateStmts_eval/cons-head-exit:
    EC_0 ARCH_0 |- forUpdateStatementIR_h :: forUpdateStatementIR_t*
                 : EC_1 ARCH_1 EXIT
    -- ForUpdateStmt_eval: 
        EC_0 ARCH_0 |- forUpdateStatementIR_h : EC_1 ARCH_1 EXIT

  rule ForUpdateStmts_eval/cons-head-cont:
    EC_0 ARCH_0 |- forUpdateStatementIR_h :: forUpdateStatementIR_t*
                 : EC_2 ARCH_2 statementResult
    -- ForUpdateStmt_eval:
        EC_0 ARCH_0 |- forUpdateStatementIR_h : EC_1 ARCH_1 `EMPTY
    -- ForUpdateStmts_eval:
        EC_1 ARCH_1 |- forUpdateStatementIR_t* : EC_2 ARCH_2 statementResult

}

;;;;; syntax forInitStatementIR

relation ForInitStmt_eval:
  evalContext arch |- forInitStatementIR
                    : evalContext arch statementResult
  hint(input %0 %1 %2)
  hint(prose_in "runtime evaluation of" %2#
                ", under evaluation context" %0 "and state" %1)
  hint(prose_out "\nthe updated evaluation context" %3#
                 ", state" %4#", and" %5)

;;;;;; annotationList typeIR nameIR initializerOptIR

rulegroup ForInitStmt_eval {

  rule ForInitStmt_eval/variableDeclarationIR-non-initializer:
    EC_0 ARCH |- annotationList typeIR nameIR eps
               : EC_1 ARCH `EMPTY
    ---- ;; get initial value
    -- if typeIR_subst = $subst_type_e(LOCAL, EC_0, typeIR)
    -- if value_init = $default(typeIR_subst)
    ---- ;; update evaluation context
    -- if EC_1 = $add_var_e(LOCAL, EC_0, `` nameIR, value_init)

  rule ForInitStmt_eval/variableDeclarationIR-initializer-abort:
    EC_0 ARCH_0 |- annotationList typeIR nameIR (`= typedExpressionIR_init)
                 : EC_1 ARCH_1 abortResult
    ---- ;; evaluate initializer
    -- Expr_eval:
        LOCAL EC_0 ARCH_0 |- typedExpressionIR_init 
                           : EC_1 ARCH_1 abortResult

  rule ForInitStmt_eval/variableDeclarationIR-initializer-cont:
    EC_0 ARCH_0 |- annotationList typeIR nameIR (`= typedExpressionIR_init)
                 : EC_2 ARCH_1 `EMPTY
    ---- ;; evaluate initializer
    -- Expr_eval:
        LOCAL EC_0 ARCH_0 |- typedExpressionIR_init
                           : EC_1 ARCH_1 (`` value_init)
    ---- ;; update evaluation context
    -- if EC_2 = $add_var_e(LOCAL, EC_1, `` nameIR, value_init)

  rule ForInitStmt_eval/forUpdateStatementIR:
    EC_0 ARCH_0 |- forUpdateStatementIR
                 : EC_1 ARCH_1 statementResult
    -- ForUpdateStmt_eval: 
        EC_0 ARCH_0 |- forUpdateStatementIR
                     : EC_1 ARCH_1 statementResult

}

;;;;;; forUpdateStatementIR

;;;;; syntax forInitStatementListIR = forInitStatementIR*

relation ForInitStmts_eval:
  evalContext arch |- forInitStatementListIR
                     : evalContext arch statementResult
  hint(input %0 %1 %2)
  hint(prose_in "runtime evaluation of" %2#
                ", under evaluation context" %0 "and state" %1)
  hint(prose_out "\nthe updated evaluation context" %3#
                 ", state" %4#", and" %5)

rulegroup ForInitStmts_eval {

  rule ForInitStmts_eval/nil:
    EC ARCH |- eps : EC ARCH `EMPTY

  rule ForInitStmts_eval/cons-head-abort:
    EC_0 ARCH_0 |- forInitStatementIR_h :: forInitStatementIR_t*
                 : EC_1 ARCH_1 abortResult
    -- ForInitStmt_eval: 
        EC_0 ARCH_0 |- forInitStatementIR_h : EC_1 ARCH_1 abortResult

  rule ForInitStmts_eval/cons-head-cont:
    EC_0 ARCH_0 |- forInitStatementIR_h :: forInitStatementIR_t*
                 : EC_2 ARCH_2 statementResult
    -- ForInitStmt_eval:
        EC_0 ARCH_0 |- forInitStatementIR_h : EC_1 ARCH_1 `EMPTY
    -- ForInitStmts_eval:
        EC_1 ARCH_1 |- forInitStatementIR_t* : EC_2 ARCH_2 statementResult

}

;;;; annotationList FOR
;;;;   `( forInitStatementListIR `; typedExpressionIR `; forUpdateStatementListIR )
;;;;   statementIR

relation ForThreeClauseStmt_eval:
  evalContext arch |- typedExpressionIR statementIR forUpdateStatementListIR
                     : evalContext arch statementResult
  hint(input %0 %1 %2 %3 %4)
  hint(prose_in "looping" %3 "with condition" %2 "and updates" %4#
                ", under evaluation context" %0 "and state" %1)
  hint(prose_out "\nthe updated evaluation context" %5#
                 ", state" %6#", and" %7)

rulegroup ForThreeClauseStmt_eval {

  rule ForThreeClauseStmt_eval/cond-abort:
    EC_0 ARCH_0 |- typedExpressionIR statementIR forUpdateStatementListIR
                 : EC_1 ARCH_1 abortResult
    -- Expr_eval: 
        LOCAL EC_0 ARCH_0 |- typedExpressionIR
                           : EC_1 ARCH_1 abortResult

  rule ForThreeClauseStmt_eval/cond-false:
    EC_0 ARCH_0 |- typedExpressionIR statementIR forUpdateStatementListIR
                 : EC_1 ARCH_1 `EMPTY
    -- Expr_eval:
        LOCAL EC_0 ARCH_0 |- typedExpressionIR
                           : EC_1 ARCH_1 (`` (`B false))

  rule ForThreeClauseStmt_eval/cond-true-loop-abort:
    EC_0 ARCH_0 |- typedExpressionIR statementIR forUpdateStatementListIR
                 : EC_2 ARCH_2 abortResult
    -- Expr_eval:
        LOCAL EC_0 ARCH_0 |- typedExpressionIR
                           : EC_1 ARCH_1 (`` (`B true))
    -- Stmt_eval:
        LOCAL EC_1 ARCH_1 |- statementIR
                           : EC_2 ARCH_2 abortResult

  rule ForThreeClauseStmt_eval/cond-true-loop-return:
    EC_0 ARCH_0 |- typedExpressionIR statementIR forUpdateStatementListIR
                 : EC_2 ARCH_2 returnResult
    -- Expr_eval:
        LOCAL EC_0 ARCH_0 |- typedExpressionIR
                           : EC_1 ARCH_1 (`` (`B true))
    -- Stmt_eval:
        LOCAL EC_1 ARCH_1 |- statementIR
                           : EC_2 ARCH_2 returnResult

  rule ForThreeClauseStmt_eval/cond-true-loop-break:
    EC_0 ARCH_0 |- typedExpressionIR statementIR forUpdateStatementListIR
                 : EC_2 ARCH_2 `EMPTY
    -- Expr_eval:
        LOCAL EC_0 ARCH_0 |- typedExpressionIR
                           : EC_1 ARCH_1 (`` (`B true))
    -- Stmt_eval:
        LOCAL EC_1 ARCH_1 |- statementIR
                           : EC_2 ARCH_2 BREAK

  rule ForThreeClauseStmt_eval/cond-true-loop-cont-update-exit:
    EC_0 ARCH_0 |- typedExpressionIR statementIR forUpdateStatementListIR
                 : EC_3 ARCH_3 EXIT
    -- Expr_eval:
        LOCAL EC_0 ARCH_0 |- typedExpressionIR
                           : EC_1 ARCH_1 (`` (`B true))
    -- Stmt_eval:
        LOCAL EC_1 ARCH_1 |- statementIR
                           : EC_2 ARCH_2 statementResult_loop
    -- if statementResult_loop = `EMPTY
          \/ statementResult_loop = CONTINUE
    -- ForUpdateStmts_eval: 
        EC_2 ARCH_2 |- forUpdateStatementListIR
                     : EC_3 ARCH_3 EXIT

  rule ForThreeClauseStmt_eval/cond-true-loop-cont-update-cont:
    EC_0 ARCH_0 |- typedExpressionIR statementIR forUpdateStatementListIR
                 : EC_4 ARCH_4 statementResult
    -- Expr_eval:
        LOCAL EC_0 ARCH_0 |- typedExpressionIR
                           : EC_1 ARCH_1 (`` (`B true))
    -- Stmt_eval:
        LOCAL EC_1 ARCH_1 |- statementIR
                           : EC_2 ARCH_2 statementResult_loop
    -- if statementResult_loop = `EMPTY
          \/ statementResult_loop = CONTINUE
    -- ForUpdateStmts_eval:
        EC_2 ARCH_2 |- forUpdateStatementListIR
                     : EC_3 ARCH_3 `EMPTY
    -- ForThreeClauseStmt_eval: 
        EC_3 ARCH_3 |- typedExpressionIR statementIR forUpdateStatementListIR
                     : EC_4 ARCH_4 statementResult

}

rulegroup Stmt_eval/forStatementIR-three-clause {

  rule Stmt_eval/init-abort:
    LOCAL EC_0 ARCH_0 |- annotationList FOR
                          `( forInitStatementListIR `;
                             typedExpressionIR `;
                             forUpdateStatementListIR ) statementIR
                       : EC_3 ARCH_1 abortResult
    -- if EC_1 = $enter_e(EC_0)
    -- ForInitStmts_eval:
        EC_1 ARCH_0 |- forInitStatementListIR
                     : EC_2 ARCH_1 abortResult
    -- if EC_3 = $exit_e(EC_2)

  rule Stmt_eval/init-cont:
    LOCAL EC_0 ARCH_0 |- annotationList FOR
                          `( forInitStatementListIR `;
                             typedExpressionIR `;
                             forUpdateStatementListIR ) statementIR
                       : EC_4 ARCH_2 statementResult
    -- if EC_1 = $enter_e(EC_0)
    -- ForInitStmts_eval:
        EC_1 ARCH_0 |- forInitStatementListIR
                     : EC_2 ARCH_1 `EMPTY
    -- ForThreeClauseStmt_eval:
        EC_2 ARCH_1 |- typedExpressionIR statementIR forUpdateStatementListIR
                     : EC_3 ARCH_2 statementResult
    -- if EC_4 = $exit_e(EC_3)

}

;;;; annotationList FOR
;;;;   `( typeIR nameIR IN forCollectionExpressionIR )
;;;;   statementIR
;;;; annotationList FOR
;;;;   `( annotationList typeIR nameIR IN forCollectionExpressionIR )
;;;;   statementIR

;;;;; syntax forCollectionExpressionIR

relation ForCollectionExpr_eval:
  evalContext arch |- forCollectionExpressionIR
                    : evalContext arch expressionListResult
  hint(input %0 %1 %2)
  hint(prose_in "runtime evaluation of" %2#
                ", under evaluation context" %0 "and state" %1)
  hint(prose_out "\nthe updated evaluation context" %3#
                 ", state" %4#", and" %5)

;;;;;; typedExpressionIR

rulegroup ForCollectionExpr_eval {

  rule ForCollectionExpr_eval/abort:
    EC_0 ARCH_0 |- typedExpressionIR
                 : EC_1 ARCH_1 abortResult
    -- Expr_eval:
        LOCAL EC_0 ARCH_0 |- typedExpressionIR
                           : EC_1 ARCH_1 abortResult

  rule ForCollectionExpr_eval/list:
    EC_0 ARCH_0 |- typedExpressionIR
                 : EC_1 ARCH_1 (`` value*)
    -- Expr_eval:
        LOCAL EC_0 ARCH_0 |- typedExpressionIR
                           : EC_1 ARCH_1 (`` listValue)
    -- if LIST `[ value* ] = listValue

  rule ForCollectionExpr_eval/header-stack:
    EC_0 ARCH_0 |- typedExpressionIR
                 : EC_1 ARCH_1 (`` value*)
    -- Expr_eval:
        LOCAL EC_0 ARCH_0 |- typedExpressionIR
                           : EC_1 ARCH_1 (`` headerStackValue)
  -- if HEADER_STACK `[ value* `( _ `; _ ) ] = headerStackValue

}

;;;;;; typedExpressionIR `.. typedExpressionIR

dec $values_of_setValue(setTypeIR, setValue) : value*
  hint(prose_in "the values in" %1 "of type" %0)

def $values_of_setValue(SET `< typeIR >, SET `{ value_l `.. value_r })
  = value_l :: $values_of_setValue(SET `< typeIR >,
                                   SET `{ value_l_inc `.. value_r })
  -- if $bin_lt(value_l, value_r)
  -- if value_one = $cast_op(typeIR, D 1)
  -- if value_l_inc = $bin_plus(value_l, value_one)
def $values_of_setValue(SET `< typeIR >, SET `{ value_l `.. value_r }) = value_l
  -- if $bin_eq(value_l, value_r)
def $values_of_setValue(SET `< typeIR >, SET `{ value_l `.. value_r }) = eps
  -- if $bin_gt(value_l, value_r)

rulegroup ForCollectionExpr_eval/range {

  rule ForCollectionExpr_eval/left-abort:
    EC_0 ARCH_0 |- typedExpressionIR_l `.. typedExpressionIR_r 
                 : EC_1 ARCH_1 abortResult
    -- Expr_eval: 
        LOCAL EC_0 ARCH_0 |- typedExpressionIR_l
                           : EC_1 ARCH_1 abortResult

  rule ForCollectionExpr_eval/left-cont-right-abort:
    EC_0 ARCH_0 |- typedExpressionIR_l `.. typedExpressionIR_r 
                 : EC_2 ARCH_2 abortResult
    -- Expr_eval: 
        LOCAL EC_0 ARCH_0 |- typedExpressionIR_l
                           : EC_1 ARCH_1 (`` value_l)
    -- Expr_eval:
        LOCAL EC_1 ARCH_1 |- typedExpressionIR_r
                           : EC_2 ARCH_2 abortResult

  rule ForCollectionExpr_eval/left-cont-right-cont:
    EC_0 ARCH_0 |- typedExpressionIR_l `.. typedExpressionIR_r 
                 : EC_2 ARCH_2 (`` value*)
    -- Expr_eval: 
        LOCAL EC_0 ARCH_0 |- typedExpressionIR_l
                           : EC_1 ARCH_1 (`` value_l)
    -- Expr_eval:
        LOCAL EC_1 ARCH_1 |- typedExpressionIR_r
                           : EC_2 ARCH_2 (`` value_r)
    -- if typeIR = $type_of_typedExpressionIR(typedExpressionIR_l)
    -- if value*
        = $values_of_setValue(SET `< typeIR >, SET `{ value_l `.. value_r })

}

relation ForInStmt_eval:
  evalContext arch |- nameIR value* statementIR
                    : evalContext arch statementResult
  hint(input %0 %1 %2 %3 %4)
  hint(prose_in "looping over" %3 "with loop variable" %2
                "and body" %4#", under evaluation context" %0 "and state" %1)
  hint(prose_out "\nthe updated evaluation context" %5#
                 ", state" %6#", and" %7)

rulegroup ForInStmt_eval {

  rule ForInStmt_eval/nil:
    EC ARCH |- nameIR eps statementIR : EC ARCH `EMPTY

  rule ForInStmt_eval/cons-loop-abort:
    EC_0 ARCH_0 |- nameIR (value_h :: value_t*) statementIR
                 : EC_2 ARCH_1 abortResult
    -- if EC_1 = $update_var_e(LOCAL, EC_0, `` nameIR, value_h)
    -- Stmt_eval:
        LOCAL EC_1 ARCH_0 |- statementIR
                           : EC_2 ARCH_1 abortResult

  rule ForInStmt_eval/cons-loop-return:
    EC_0 ARCH_0 |- nameIR (value_h :: value_t*) statementIR
                 : EC_2 ARCH_1 returnResult
    -- if EC_1 = $update_var_e(LOCAL, EC_0, `` nameIR, value_h)
    -- Stmt_eval:
        LOCAL EC_1 ARCH_0 |- statementIR
                           : EC_2 ARCH_1 returnResult

  rule ForInStmt_eval/cons-loop-break:
    EC_0 ARCH_0 |- nameIR (value_h :: value_t*) statementIR
                 : EC_2 ARCH_1 `EMPTY
    -- if EC_1 = $update_var_e(LOCAL, EC_0, `` nameIR, value_h)
    -- Stmt_eval:
        LOCAL EC_1 ARCH_0 |- statementIR
                           : EC_2 ARCH_1 BREAK

  rule ForInStmt_eval/cons-loop-cont:
    EC_0 ARCH_0 |- nameIR (value_h :: value_t*) statementIR
                 : EC_3 ARCH_2 statementResult
    -- if EC_1 = $update_var_e(LOCAL, EC_0, `` nameIR, value_h)
    -- Stmt_eval:
        LOCAL EC_1 ARCH_0 |- statementIR
                           : EC_2 ARCH_1 statementResult_loop
    -- if statementResult_loop = `EMPTY
          \/ statementResult_loop = CONTINUE
    -- ForInStmt_eval:
        EC_2 ARCH_1 |- nameIR value_t* statementIR
                     : EC_3 ARCH_2 statementResult

}

rulegroup Stmt_eval/forStatementIR-in {

  rule Stmt_eval/no-annotations-collection-abort:
    LOCAL EC_0 ARCH_0 |- annotationList FOR
                          `( typeIR nameIR IN forCollectionExpressionIR ) 
                          statementIR
                       : EC_3 ARCH_1 abortResult
    -- if EC_1 = $enter_e(EC_0)
    -- ForCollectionExpr_eval:
        EC_1 ARCH_0 |- forCollectionExpressionIR
                     : EC_2 ARCH_1 abortResult
    -- if EC_3 = $exit_e(EC_2)

  rule Stmt_eval/no-annotations-collection-loop:
    LOCAL EC_0 ARCH_0 |- annotationList FOR
                          `( typeIR nameIR IN forCollectionExpressionIR ) 
                          statementIR
                       : EC_5 ARCH_2 statementResult
    -- if EC_1 = $enter_e(EC_0)
    ---- ;; evaluate collection
    -- ForCollectionExpr_eval:
        EC_1 ARCH_0 |- forCollectionExpressionIR
                     : EC_2 ARCH_1 (`` value*)
    ---- ;; update evaluation context
    -- if typeIR_subst = $subst_type_e(LOCAL, EC_0, typeIR)
    -- if value_init = $default(typeIR_subst)
    -- if EC_3 = $add_var_e(LOCAL, EC_2, `` nameIR, value_init)
    ---- ;; evaluate loop
    -- ForInStmt_eval:
        EC_3 ARCH_1 |- nameIR value* statementIR
                     : EC_4 ARCH_2 statementResult
    -- if EC_5 = $exit_e(EC_4)

  rule Stmt_eval/annotations:
    LOCAL EC_0 ARCH_0 |- annotationList FOR
                          `( annotationList_in
                             typeIR nameIR IN forCollectionExpressionIR )
                          statementIR
                       : EC_1 ARCH_1 statementResult
    -- Stmt_eval:
        LOCAL EC_0 ARCH_0 |- annotationList FOR
                              `( typeIR nameIR IN forCollectionExpressionIR )
                              statementIR
                           : EC_1 ARCH_1 statementResult

}

;;; breakStatementIR

rule Stmt_eval/breakStatementIR:
  LOCAL EC ARCH |- BREAK `; : EC ARCH BREAK

;;; continueStatementIR

rule Stmt_eval/continueStatementIR:
  LOCAL EC ARCH |- CONTINUE `; : EC ARCH CONTINUE

;;; switchStatementIR
;;; syntax switchStatementIR =
;;;   SWITCH `( typedExpressionIR ) `{ switchCaseListIR }

;;;; Switch on table apply method result

relation Switch_table_eval:
  evalContext arch |- SWITCH `( id ) `{ switchCaseIR* }
                    : evalContext arch statementResult
  hint(input %0 %1 %2 %3)

;;;;; syntax switchLabelIR
;;;;;; DEFAULT
;;;;;; typedExpressionIR

dec $match_switchLabelIR_table(id, switchLabelIR) : bool
  hint(prose_true %0 "matches" %1)
  hint(prose_false %0 "does not match" %1)
def $match_switchLabelIR_table(id, DEFAULT) = true
def $match_switchLabelIR_table(id, (`` id) `# _) = true
def $match_switchLabelIR_table(id, _) = false
  -- otherwise

;;;;; syntax switchCaseListIR
;;;;;; switchLabelIR `: blockStatementIR
;;;;;; switchLabelIR `: 

relation SwitchCases_table_eval:
  id |- switchCaseListIR : blockStatementIR?
  hint(input %0 %1)
  hint(prose_in "runtime evaluation of" %1 "for invocation of table" %0)
  hint(prose_out "the matched block" %2)

dec $is_non_fallthrough_switchCaseIR(switchCaseIR) : bool
  hint(prose_true %0 "is not a fall-through case")
  hint(prose_false %0 "is a fall-through case")
def $is_non_fallthrough_switchCaseIR(switchLabelIR `: blockStatementIR) = true
def $is_non_fallthrough_switchCaseIR(switchLabelIR `: ) = false

rulegroup SwitchCases_table_eval {

  rule SwitchCases_table_eval/nil:
    id |- eps : eps

  rule SwitchCases_table_eval/cons-non-fallthrough-match:
    id |- switchCaseIR_h :: switchCaseIR_t* : blockStatementIR_h
    ---- ;; if not fallthrough
    -- if switchLabelIR_h `: blockStatementIR_h = switchCaseIR_h
    ---- ;; if match
    -- if $match_switchLabelIR_table(id, switchLabelIR_h)

  rule SwitchCases_table_eval/cons-non-fallthrough-no-match:
    id |- switchCaseIR_h :: switchCaseIR_t* : blockStatementIR?
    ---- ;; if not fallthrough
    -- if switchLabelIR_h `: blockStatementIR_h = switchCaseIR_h
    ---- ;; if no match
    -- if ~$match_switchLabelIR_table(id, switchLabelIR_h)
    -- SwitchCases_table_eval:
        id |- switchCaseIR_t* : blockStatementIR?

  rule SwitchCases_table_eval/cons-fallthrough-match:
    id |- switchCaseIR_h :: switchCaseIR_t* : blockStatementIR
    ---- ;; if fallthrough
    -- if switchLabelIR_h `: = switchCaseIR_h
    ---- ;; if match
    -- if $match_switchLabelIR_table(id, switchLabelIR_h)
    ---- ;; take the closest non-fallthrough case
    -- if (_ `: blockStatementIR) :: _
        = $filter_<switchCaseIR>(
            switchCaseIR_t*,
            $is_non_fallthrough_switchCaseIR(switchCaseIR_t)*)

  rule SwitchCases_table_eval/cons-fallthrough-no-match:
    id |- switchCaseIR_h :: switchCaseIR_t* : blockStatementIR?
    ---- ;; if fallthrough
    -- if switchLabelIR_h `: = switchCaseIR_h
    ---- ;; if no match
    -- if ~$match_switchLabelIR_table(id, switchLabelIR_h)
    -- SwitchCases_table_eval:
        id |- switchCaseIR_t* : blockStatementIR?

}

rulegroup Switch_table_eval {

  rule Switch_table_eval/no-match:
    EC_0 ARCH_0 |- SWITCH `( id_enum ) `{ switchCaseIR* }
                 : EC_0 ARCH_0 `EMPTY
    ---- ;; find matching case
    -- SwitchCases_table_eval:
        id_enum |- switchCaseIR* : eps

  rule Switch_table_eval/match:
    EC_0 ARCH_0 |- SWITCH `( id_enum ) `{ switchCaseIR* }
                 : EC_1 ARCH_1 statementResult
    ---- ;; find matching case
    -- SwitchCases_table_eval:
        id_enum |- switchCaseIR* : blockStatementIR
    ---- ;; evaluate matching case
    -- Stmt_eval:
        LOCAL EC_0 ARCH_0 |- blockStatementIR
                           : EC_1 ARCH_1 statementResult

}

;;;; Switch on error, numeric or enumerated type expression

relation Switch_general_eval:
  evalContext arch |- SWITCH `( value ) `{ switchCaseIR* }
                    : evalContext arch statementResult
  hint(input %0 %1 %2 %3)

;;;;; syntax switchLabelIR
;;;;;; DEFAULT
;;;;;; typedExpressionIR

relation SwitchLabel_general_eval:
  cursor evalContext arch |- switchLabelIR
                           : evalContext arch expressionResult
  hint(input %0 %1 %2 %3)
  hint(prose_in "runtime evaluation of" %2#
                ", under evaluation context" %0 "and state" %1)
  hint(prose_out "\nthe updated evaluation context" %4#
                 ", state" %5#", and" %6)

rulegroup SwitchLabel_general_eval {

  rule SwitchLabel_general_eval/default:
    LOCAL EC_0 ARCH_0 |- DEFAULT
                       : EC_0 ARCH_0 (`` DEFAULT)

  rule SwitchLabel_general_eval/typedExpressionIR:
    LOCAL EC_0 ARCH_0 |- typedExpressionIR
                       : EC_1 ARCH_1 expressionResult
    -- Expr_eval:
        LOCAL EC_0 ARCH_0 |- typedExpressionIR
                           : EC_1 ARCH_1 expressionResult

}

dec $match_switchLabelIR_general(value, value) : bool
  hint(prose_true %0 "matches" %1)
  hint(prose_false %0 "does not match" %1)
def $match_switchLabelIR_general(value, DEFAULT) = true
def $match_switchLabelIR_general(value_a, value_b) = $bin_eq(value_a, value_b)
  -- otherwise

relation SwitchCases_general_eval:
  cursor evalContext arch value |- switchCaseListIR
                                 : evalContext arch blockStatementIR?
  hint(input %0 %1 %2 %3 %4)
  hint(prose_in "runtime evaluation of" %4#
                ", under evaluation context" %0 "and state" %1
                "with switch key" %3)
  hint(prose_out "\nthe updated evaluation context" %5#
                 ", state" %6#", and" %7)

rulegroup SwitchCases_general_eval {

  rule SwitchCases_general_eval/nil:
    LOCAL EC_0 ARCH_0 value |- eps : EC_0 ARCH_0 eps

  rule SwitchCases_general_eval/cons-non-fallthrough-match:
    LOCAL EC_0 ARCH_0 value |- (switchCaseIR_h :: switchCaseIR_t*)
                             : EC_1 ARCH_1 blockStatementIR_h
    ---- ;; if not fall-through
    -- if switchLabelIR_h `: blockStatementIR_h = switchCaseIR_h
    -- SwitchLabel_general_eval:
        LOCAL EC_0 ARCH_0 |- switchLabelIR_h
                           : EC_1 ARCH_1 (`` value_label)
    ---- ;; if match
    -- if $match_switchLabelIR_general(value, value_label)

  rule SwitchCases_general_eval/cons-non-fallthrough-no-match:
    LOCAL EC_0 ARCH_0 value |- (switchCaseIR_h :: switchCaseIR_t*)
                             : EC_2 ARCH_2 blockStatementIR?
    ---- ;; if not fall-through
    -- if switchLabelIR_h `: blockStatementIR_h = switchCaseIR_h
    -- SwitchLabel_general_eval:
        LOCAL EC_0 ARCH_0 |- switchLabelIR_h
                           : EC_1 ARCH_1 (`` value_label)
    ---- ;; if not match
    -- if ~$match_switchLabelIR_general(value, value_label)
    -- SwitchCases_general_eval:
        LOCAL EC_1 ARCH_1 value |- switchCaseIR_t*
                                 : EC_2 ARCH_2 blockStatementIR?

  rule SwitchCases_general_eval/cons-fallthrough-match:
    LOCAL EC_0 ARCH_0 value |- (switchCaseIR_h :: switchCaseIR_t*)
                             : EC_1 ARCH_1 blockStatementIR
    ---- ;; if fallthrough
    -- if switchLabelIR_h `: = switchCaseIR_h
    -- SwitchLabel_general_eval:
        LOCAL EC_0 ARCH_0 |- switchLabelIR_h
                           : EC_1 ARCH_1 (`` value_label)
    ---- ;; if match
    -- if $match_switchLabelIR_general(value, value_label)
    ---- ;; take the closest non-fallthrough case
    -- if (_ `: blockStatementIR) :: _
        = $filter_<switchCaseIR>(
            switchCaseIR_t*,
            $is_non_fallthrough_switchCaseIR(switchCaseIR_t)*)

  rule SwitchCases_general_eval/cons-fallthrough-no-match:
    LOCAL EC_0 ARCH_0 value |- (switchCaseIR_h :: switchCaseIR_t*)
                             : EC_2 ARCH_2 blockStatementIR?
    ---- ;; if fallthrough
    -- if switchLabelIR_h `: = switchCaseIR_h
    -- SwitchLabel_general_eval:
        LOCAL EC_0 ARCH_0 |- switchLabelIR_h
                           : EC_1 ARCH_1 (`` value_label)
    ---- ;; if no match
    -- if ~$match_switchLabelIR_general(value, value_label)
    -- SwitchCases_general_eval:
        LOCAL EC_1 ARCH_1 value |- switchCaseIR_t*
                                 : EC_2 ARCH_2 blockStatementIR?

}

rulegroup Switch_general_eval {

  rule Switch_general_eval/no-match:
    EC_0 ARCH_0 |- SWITCH `( value ) `{ switchCaseIR* }
                 : EC_1 ARCH_1 `EMPTY
    ---- ;; find matching case
    -- SwitchCases_general_eval:
        LOCAL EC_0 ARCH_0 value |- switchCaseIR*
                                 : EC_1 ARCH_1 eps

  rule Switch_general_eval/match:
    EC_0 ARCH_0 |- SWITCH `( value ) `{ switchCaseIR* }
                 : EC_2 ARCH_2 statementResult
    ---- ;; find matching case
    -- SwitchCases_general_eval:
        LOCAL EC_0 ARCH_0 value |- switchCaseIR*
                                 : EC_1 ARCH_1 blockStatementIR
    ---- ;; evaluate matching case
    -- Stmt_eval:
        LOCAL EC_1 ARCH_1 |- blockStatementIR
                           : EC_2 ARCH_2 statementResult

}

rulegroup Stmt_eval/switchStatementIR {

  rule Stmt_eval/target-abort:
    LOCAL EC_0 ARCH_0 |- SWITCH `( typedExpressionIR ) `{ switchCaseIR* }
                       : EC_1 ARCH_1 abortResult
    ---- ;; evaluate switch target
    -- Expr_eval:
        LOCAL EC_0 ARCH_0 |- typedExpressionIR
                           : EC_1 ARCH_1 abortResult

  rule Stmt_eval/target-cont-table:
    LOCAL EC_0 ARCH_0 |- SWITCH `( typedExpressionIR ) `{ switchCaseIR* }
                       : EC_2 ARCH_2 statementResult
    ---- ;; evaluate switch target
    -- Expr_eval:
        LOCAL EC_0 ARCH_0 |- typedExpressionIR
                           : EC_1 ARCH_1 (`` value)
    ---- ;; if switch on table apply result
    -- if TABLE_ENUM _ `. id_enum = value
    ---- ;; find matching case
    -- Switch_table_eval:
        EC_1 ARCH_1 |- SWITCH `( id_enum ) `{ switchCaseIR* }
                     : EC_2 ARCH_2 statementResult

  rule Stmt_eval/target-cont-general:
    LOCAL EC_0 ARCH_0 |- SWITCH `( typedExpressionIR ) `{ switchCaseIR* }
                       : EC_2 ARCH_2 statementResult
    ---- ;; evaluate switch target
    -- Expr_eval:
        LOCAL EC_0 ARCH_0 |- typedExpressionIR
                           : EC_1 ARCH_1 (`` value)
    ---- ;; if switch on table apply result
    -- if ~(value <: tableMetadataEnumValue)
    ---- ;; find matching case
    -- Switch_general_eval:
        EC_1 ARCH_1 |- SWITCH `( value ) `{ switchCaseIR* }
                     : EC_2 ARCH_2 statementResult

}

