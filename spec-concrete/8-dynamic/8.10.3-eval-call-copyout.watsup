;;
;; Copy-out (single argument)
;;

;;; IN | `EMPTY

rule Copy_out_argument/in-directionless:
  ARCH |-
    p_caller EC_caller_0 (_ direction typeIR nameIR _)
   `@ p_callee EC_callee eps
  ~> EC_caller_0
  ---- ;; check parameter direction
  -- if direction = IN \/ direction = `EMPTY

;;; OUT | INOUT

rulegroup Copy_out_argument/out-inout {

  rule Copy_out_argument/dontcare:
    ARCH |-
      p_caller EC_caller (_ direction typeIR nameIR _)
     `@ p_callee EC_callee eps
    ~> EC_caller
    ---- ;; check parameter direction
    -- if direction = OUT \/ direction = INOUT

  rule Copy_out_argument/non-dontcare:
    ARCH |-
      p_caller EC_caller_0 (_ direction typeIR nameIR _)
     `@ p_callee EC_callee storageReference
    ~> EC_caller_1
    ---- ;; check parameter direction
    -- if direction = OUT \/ direction = INOUT
    ---- ;; find value and write it to storage reference
    ---- ;; (TODO) support := without backticks
    -- if value = $find_var_e(`` nameIR, p_callee, EC_callee)
    -- Lvalue_write:
        p_caller EC_caller_0 ARCH |- storageReference -> value
                                   : EC_caller_1

}

;;
;; Copy-out (multiple arguments)
;;

relation Copy_out_inner:
  arch |-
    cursor evalContext parameterListIR
    `@ cursor evalContext storageReference?*
  ~> evalContext
  hint(input %0 %1 %2 %3 %4 %5 %6)

rulegroup Copy_out_inner {

  rule Copy_out_inner/nil:
    ARCH |-
      p_caller EC_caller eps
      `@ p_callee EC_callee eps
    ~> EC_caller

  rule Copy_out_inner/cons:
    ARCH |-
      p_caller EC_caller_0 (parameterIR_h :: parameterIR_t*)
     `@ p_callee EC_callee (storageReference_h? :: storageReference_t?*)
    ~> EC_caller_2
    ----
    -- Copy_out_argument:
        ARCH |-
          p_caller EC_caller_0 parameterIR_h
         `@ p_callee EC_callee storageReference_h?
        ~> EC_caller_1
    ----
    -- Copy_out_inner:
        ARCH |-
          p_caller EC_caller_1 parameterIR_t*
         `@ p_callee EC_callee storageReference_t?*
        ~> EC_caller_2

}

rule Copy_out:
  p_shared ARCH |-
    p_caller EC_caller_0 parameterListIR
    `@ p_callee EC_callee storageReference?*
  ~> EC_caller_2
  ---- ;; propagate shared layer
  -- if EC_caller_1 = $copy_e(p_shared, EC_callee, EC_caller_0)
  ---- ;; perform copy-out for each argument
  -- Copy_out_inner:
      ARCH |-
        p_caller EC_caller_1 parameterListIR
       `@ p_callee EC_callee storageReference?*
      ~> EC_caller_2
