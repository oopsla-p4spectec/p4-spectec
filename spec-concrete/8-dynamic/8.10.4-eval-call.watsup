                            : EC_callee_4 ARCH_2 `EMPTY
    ---- ;; execute the control body
    -- ControlBody_eval:
        EC_callee_4 ARCH_2 |- controlBodyIR
                            : EC_callee_5 ARCH_3 EXIT
    ---- ;; copy-out
