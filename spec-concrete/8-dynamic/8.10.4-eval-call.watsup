;;;; tableApplyMethodCallee

rulegroup Call_eval/tableApplyMethodCallee {

    rule Call_eval/tableApplyMethodCallee-exit:
      p EC_0 ARCH_0 |- tableApplyMethodCallee
                      `@ `< typeArgumentListIR > `( argumentListIR )
                     : EC_1 ARCH_1 EXIT
      ---- ;; unpack the table apply method callee
      -- if TABLE objectId `. APPLY `{ frame `; TBL }
          = tableApplyMethodCallee
      ---- ;; create the callee context
      -- if EC_callee_0 = $inherit_e(BLOCK, EC_0)
      -- if EC_callee_1 = EC_callee_0[ .LOCAL.FRAMES = [ frame ] ]
      ---- ;; evaluate match-action
      -- if typeId :: _ = $rev_<id>(objectId)
      -- Table_eval:
          EC_callee_1 ARCH_0 |- typeId TBL
                              : EC_callee_2 ARCH_1 EXIT
      ---- ;; propagate shared layers
      -- if EC_1 = $copy_e(BLOCK, EC_callee_2, EC_0)

    rule Call_eval/tableApplyMethodCallee-return:
      p EC_0 ARCH_0 |- tableApplyMethodCallee
                      `@ `< typeArgumentListIR > `( argumentListIR )
                     : EC_1 ARCH_1 returnResult
      ---- ;; unpack the table apply method callee
      -- if TABLE objectId `. APPLY `{ frame `; TBL }
          = tableApplyMethodCallee
      ---- ;; create the callee context
      -- if EC_callee_0 = $inherit_e(BLOCK, EC_0)
      -- if EC_callee_1 = EC_callee_0[ .LOCAL.FRAMES = [ frame ] ]
      ---- ;; evaluate match-action
      -- if typeId :: _ = $rev_<id>(objectId)
      -- Table_eval:
          EC_callee_1 ARCH_0 |- typeId TBL
                              : EC_callee_2 ARCH_1 returnResult
      ---- ;; propagate shared layers
      -- if EC_1 = $copy_e(BLOCK, EC_callee_2, EC_0)

}
