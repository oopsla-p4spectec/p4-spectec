;;
;; Architecture-specific state
;;

extern syntax archState
extern dec $init_archState : archState

syntax arch =
  { STATE archState,
    STORE store }

var ARCH : arch

;;
;; Adder
;;

dec $add_object_e(arch, objectId, object) : arch

def $add_object_e(ARCH, objectId, object)
  = ARCH[ .STORE = STO ]
  -- if STO
      = $add_map<objectId, object>(ARCH.STORE, objectId, object)

;;
;; Finder
;;

dec $find_archState_e(arch) : archState
def $find_archState_e(ARCH) = ARCH.STATE

dec $find_object_e(arch, objectId) : object?
  hint(prose_in "the object" %1 "in" %0)
def $find_object_e(ARCH, objectId)
  = $find_map<objectId, object>(ARCH.STORE, objectId)

dec $find_object_qualified_e(arch, objectId) : object?
def $find_object_qualified_e(ARCH, objectId)
  = $find_object_e(ARCH, objectId)

dec $find_object_unqualified_e(arch, id) : object?
def $find_object_unqualified_e(ARCH, id) = object_id_found
  -- if `{ (objectId `: object)* } = ARCH.STORE
  -- if (object_id?
      = $ite<object?>($objectId_ends_with(objectId, id), object, eps))*
  -- if object_id_found
      = $filter_<object?>(object_id?*, (object_id? =/= eps)*)
def $find_object_unqualified_e(ARCH, id) = eps 
  -- otherwise

dec $find_objectState_e(arch, objectId) : objectState?

def $find_objectState_e(ARCH, objectId) = objectState
  -- if externObject = $find_object_e(ARCH, objectId)
  -- if EXTERN _ `< _ > `{ objectState _ _ } = externObject
def $find_objectState_e(ARCH, objectId) = eps
  -- otherwise

;;
;; Updater
;;

dec $update_archState_e(arch, archState) : arch
def $update_archState_e(ARCH, archState) = ARCH[ .STATE = archState ]

dec $update_object_qualified_e(arch, objectId, object) : arch

def $update_object_qualified_e(ARCH_0, objectId, object) = ARCH_1
  -- if eps =/= $find_object_qualified_e(ARCH_0, objectId)
  -- if ARCH_1 = $add_object_e(ARCH_0, objectId, object)

dec $update_object_unqualified_e(arch, id, object) : arch

def $update_object_unqualified_e(ARCH_0, id, object) = ARCH_1
  -- if `{ (objectId `: _)* } = ARCH_0.STORE
  -- if (objectId_id?
      = $ite<objectId?>($objectId_ends_with(objectId, id), objectId, eps))*
  -- if objectId_found
      = $filter_<objectId?>(objectId_id?*, (objectId_id? =/= eps)*)
  -- if ARCH_1 = $add_object_e(ARCH_0, objectId_found, object)

dec $update_objectState_e(arch, objectId, objectState) : arch?

def $update_objectState_e(ARCH_0, objectId, objectState) = ARCH_1
  -- if externObject = $find_object_e(ARCH_0, objectId)
  -- if EXTERN typeId `< theta > `{ _ frame externMethodDefEnv }
      = externObject
  -- if externObject_update
      = EXTERN typeId `< theta > `{ objectState frame externMethodDefEnv }
  -- if ARCH_1 = $add_object_e(ARCH_0, objectId, externObject_update)
def $update_objectState_e(ARCH, objectId, objectState) = eps
  -- otherwise
