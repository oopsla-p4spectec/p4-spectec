;;
;; Callee evaluation
;;
;; syntax routineTargetIR
;;

;;; referenceExpressionIR

;;;; Action call

rule Callee_eval/actionCallee:
  p EC ARCH |- referenceExpressionIR `< `_ > `( argumentListIR )
             : EC ARCH (`` actionCallee)
  ---- ;; find the action definition being called
  ---- ;; (TODO) Is it correct to call overload resolution here
  -- if _ `: (p_ref, actionDef) `# id_default* `# _
      = $find_callableDef_overloaded_e(
          p, EC, referenceExpressionIR, argumentListIR)
  ---- ;; prepare the callee
  -- if _ ACTION nameIR `( parameterListIR ) blockStatementIR = actionDef
  -- if actionCallee
      = ACTION p_ref `. nameIR `( parameterListIR `# id_default* ) blockStatementIR

;;;; Extern function call

rule Callee_eval/externFunctionCallee:
  p EC ARCH |- referenceExpressionIR `< `_ > `( argumentListIR )
             : EC ARCH (`` externFunctionCallee)
  ---- ;; find the extern function definition being called
  -- if _ `: (_, externFunctionDef) `# id_default* `# id_optional*
      = $find_callableDef_overloaded_e(
          p, EC, referenceExpressionIR, argumentListIR)
  ---- ;; prepare the callee
  -- if EXTERN_FUNCTION nameIR `< typeParameterListIR > `( parameterListIR )
      = externFunctionDef
  -- if externFunctionCallee
      = EXTERN_FUNCTION nameIR `< typeParameterListIR >
          `( parameterListIR `# id_default* `# id_optional* )

;;;; Defined function call

rule Callee_eval/definedFunctionCallee:
  p EC ARCH |- referenceExpressionIR `< `_ > `( argumentListIR )
             : EC ARCH (`` definedFunctionCallee)
  ---- ;; find the function definition being called
  -- if _ `: (_, definedFunctionDef) `# id_default* `# _
      = $find_callableDef_overloaded_e(p, EC, referenceExpressionIR, argumentListIR)
  ---- ;; prepare the callee
  -- if FUNCTION nameIR `< typeParameterListIR > `( parameterListIR ) blockStatementIR
      = definedFunctionDef
  -- if definedFunctionCallee
      = FUNCTION nameIR `< typeParameterListIR > `( parameterListIR `# id_default* ) blockStatementIR

;;; typedExpressionIR `. nameIR

;;;; Builtin method call

rulegroup Callee_eval/builtinMethodCallee {

  rule Callee_eval/abort:
    p EC_0 ARCH_0 |- (typedExpressionIR `. nameIR) `< `_ > `( argumentListIR )
                   : EC_1 ARCH_1 abortResult
    ---- ;; get storage reference of expression base
    -- if typedLvalueIR
        = $typedExpressionIR_as_typedLvalueIR(typedExpressionIR)
    -- Lvalue_eval:
        p EC_0 ARCH_0 |- typedLvalueIR
                       : EC_1 ARCH_1 abortResult

  rule Callee_eval/header-stack-push_front:
    p EC_0 ARCH_0 |- (typedExpressionIR `. "push_front") `< `_ > `( argumentIR )
                   : EC_1 ARCH_1 (`` builtinMethodCallee)
    ---- ;; get storage reference of expression base
    -- if typedLvalueIR
        = $typedExpressionIR_as_typedLvalueIR(typedExpressionIR)
    -- Lvalue_eval:
        p EC_0 ARCH_0 |- typedLvalueIR
                       : EC_1 ARCH_1 (`` storageReference)
    ---- ;; prepare the callee
    -- if parameterIR = `EMPTY `EMPTY INT "count" eps
    -- if builtinMethodCallee
        = BUILTIN_METHOD storageReference `. "push_front" `< eps > `( parameterIR )

  rule Callee_eval/header-stack-pop_front:
    p EC_0 ARCH_0 |- (typedExpressionIR `. "pop_front") `< `_ > `( argumentIR )
                   : EC_1 ARCH_1 (`` builtinMethodCallee)
    ---- ;; get storage reference of expression base
    -- if typedLvalueIR
        = $typedExpressionIR_as_typedLvalueIR(typedExpressionIR)
    -- Lvalue_eval:
        p EC_0 ARCH_0 |- typedLvalueIR
                       : EC_1 ARCH_1 (`` storageReference)
    ---- ;; prepare the callee
    -- if parameterIR = `EMPTY `EMPTY INT "count" eps
    -- if builtinMethodCallee
        = BUILTIN_METHOD storageReference `. "pop_front" `< eps > `( parameterIR )

  rule Callee_eval/header-isValid:
    p EC_0 ARCH_0 |- (typedExpressionIR `. "isValid") `< `_ > `( eps )
                   : EC_1 ARCH_1 (`` builtinMethodCallee)
    ---- ;; get storage reference of expression base
    -- if typedLvalueIR
        = $typedExpressionIR_as_typedLvalueIR(typedExpressionIR)
    -- Lvalue_eval:
        p EC_0 ARCH_0 |- typedLvalueIR
                       : EC_1 ARCH_1 (`` storageReference)
    ---- ;; prepare the callee
    -- if builtinMethodCallee
        = BUILTIN_METHOD storageReference `. "isValid" `< eps > `( eps )

  rule Callee_eval/header-setValid:
    p EC_0 ARCH_0 |- (typedExpressionIR `. "setValid") `< `_ > `( eps )
                   : EC_1 ARCH_1 (`` builtinMethodCallee)
    ---- ;; get storage reference of expression base
    -- if typedLvalueIR
        = $typedExpressionIR_as_typedLvalueIR(typedExpressionIR)
    -- Lvalue_eval:
        p EC_0 ARCH_0 |- typedLvalueIR
                       : EC_1 ARCH_1 (`` storageReference)
    ---- ;; prepare the callee
    -- if builtinMethodCallee
        = BUILTIN_METHOD storageReference `. "setValid" `< eps > `( eps )

  rule Callee_eval/header-setInvalid:
    p EC_0 ARCH_0 |- (typedExpressionIR `. "setInvalid") `< `_ > `( eps )
                   : EC_1 ARCH_1 (`` builtinMethodCallee)
    ---- ;; get storage reference of expression base
    -- if typedLvalueIR
        = $typedExpressionIR_as_typedLvalueIR(typedExpressionIR)
    -- Lvalue_eval:
        p EC_0 ARCH_0 |- typedLvalueIR
                      : EC_1 ARCH_1 (`` storageReference)
    ---- ;; prepare the callee
    -- if builtinMethodCallee
        = BUILTIN_METHOD storageReference `. "setInvalid" `< eps > `( eps )

}

;;;; Extern method call

rulegroup Callee_eval/externMethodCallee {

  rule Callee_eval/abort:
    p EC_0 ARCH_0 |- (typedExpressionIR `. nameIR) `< `_ > `( argumentListIR )
                   : EC_1 ARCH_1 abortResult
    ---- ;; get storage reference of expression base
    -- if typedLvalueIR
        = $typedExpressionIR_as_typedLvalueIR(typedExpressionIR)
    -- Lvalue_eval:
        p EC_0 ARCH_0 |- typedLvalueIR
                       : EC_1 ARCH_1 abortResult

  rule Callee_eval/cont:
    p EC_0 ARCH_0 |- (typedExpressionIR `. nameIR) `< `_ > `( argumentListIR )
                   : EC_1 ARCH_1 (`` externMethodCallee)
    ---- ;; get storage reference of expression base
    -- if typedLvalueIR
        = $typedExpressionIR_as_typedLvalueIR(typedExpressionIR)
    -- Lvalue_eval:
        p EC_0 ARCH_0 |- typedLvalueIR
                       : EC_1 ARCH_1 (`` storageReference)
    ---- ;; read value of storage reference
    -- Lvalue_read:
        p EC_1 ARCH_1 |- storageReference : (REF objectId)
    ---- ;; if the value is an object reference to an extern
    -- if EXTERN _ `< theta > `{ _ frame externMethodDefEnv } 
        = $find_object_e(ARCH_1, objectId)
    ---- ;; find the method being called
    -- if callTargetKey = $callTargetKey(nameIR, argumentListIR)
    -- if _ `: externMethodDef `# id_default* `# id_optional*
        = $find_overloaded<externMethodDef>(
            externMethodDefEnv, callTargetKey,
            def $parameterListIR_of_externMethodDef)
    ---- ;; prepare the callee
    -- if EXTERN_METHOD nameIR `< typeParameterListIR >
            `( parameterListIR ) blockStatementIR?
        = externMethodDef
    -- if externMethodCallee
        = EXTERN_METHOD objectId `. nameIR `< typeParameterListIR >
            `( parameterListIR `# id_default* `# id_optional* )
            `{ theta `; frame `; blockStatementIR? }

}

;;;; Parser apply method call

rulegroup Callee_eval/parserApplyMethodCallee {

  rule Callee_eval/abort:
    p EC_0 ARCH_0 |- (typedExpressionIR `. "apply") `< `_ > `( argumentListIR )
                   : EC_1 ARCH_1 abortResult
    ---- ;; get storage reference of expression base
    -- if typedLvalueIR
        = $typedExpressionIR_as_typedLvalueIR(typedExpressionIR)
    -- Lvalue_eval:
        p EC_0 ARCH_0 |- typedLvalueIR
                       : EC_1 ARCH_1 abortResult

  rule Callee_eval/cont:
    p EC_0 ARCH_0 |- (typedExpressionIR `. "apply") `< `_ > `( argumentListIR )
                   : EC_1 ARCH_1 (`` parserApplyMethodCallee)
    ---- ;; get storage reference of expression base
    -- if typedLvalueIR
        = $typedExpressionIR_as_typedLvalueIR(typedExpressionIR)
    -- Lvalue_eval:
        p EC_0 ARCH_0 |- typedLvalueIR
                       : EC_1 ARCH_1 (`` storageReference)
    ---- ;; read value of storage reference
    ---- ;; if the value is an object reference to a parser
    -- Lvalue_read:
        p EC_1 ARCH_1 |- storageReference : (REF objectId)
    -- if PARSER `< theta > `( parameterListIR )
            `{ frame parserLocalDeclarationListIR stateEnv }
        = $find_object_e(ARCH_1, objectId)
    ---- ;; perform default resolution
    -- if callableId = $callableId_IR("apply", parameterListIR)
    -- if parserApplyMethodDef
        = PARSER_APPLY `( parameterListIR )
            `{ parserLocalDeclarationListIR `; stateEnv }
    -- if callTargetKey = $callTargetKey("apply", argumentListIR)
    -- if _ `: _ `# id_default* `# _
        = $find_overloaded<parserApplyMethodDef>(
            `{ (callableId `: parserApplyMethodDef) },
            callTargetKey,
            def $parameterListIR_of_parserApplyMethodDef)
    ---- ;; prepare the callee
    -- if parserApplyMethodCallee
        = PARSER objectId `. APPLY `( parameterListIR `# id_default* )
            `{ theta `; frame `; parserLocalDeclarationListIR `; stateEnv }

}

;;;; Control apply method call

rulegroup Callee_eval/controlApplyMethodCallee {

  rule Callee_eval/abort:
    p EC_0 ARCH_0 |- (typedExpressionIR `. "apply") `< `_ > `( argumentListIR )
                   : EC_1 ARCH_1 abortResult
    ---- ;; get storage reference of expression base
    -- if typedLvalueIR
        = $typedExpressionIR_as_typedLvalueIR(typedExpressionIR)
    -- Lvalue_eval:
        p EC_0 ARCH_0 |- typedLvalueIR : EC_1 ARCH_1 abortResult

  rule Callee_eval/cont:
    p EC_0 ARCH_0 |- (typedExpressionIR `. "apply") `< `_ > `( argumentListIR )
                   : EC_1 ARCH_1 (`` controlApplyMethodCallee)
    ---- ;; get storage reference of expression base
    -- if typedLvalueIR
        = $typedExpressionIR_as_typedLvalueIR(typedExpressionIR)
    -- Lvalue_eval:
        p EC_0 ARCH_0 |- typedLvalueIR
                       : EC_1 ARCH_1 (`` storageReference)
    ---- ;; read value of storage reference
    -- Lvalue_read:
        p EC_1 ARCH_1 |- storageReference : (REF objectId)
    ---- ;; if the value is an object reference to a control
    -- if CONTROL `< theta > `( parameterListIR )
            `{ frame controlLocalDeclarationListIR
               actionDefEnv controlBodyIR }
        = $find_object_e(ARCH_1, objectId)
    ---- ;; perform default resolution
    -- if callableId = $callableId_IR("apply", parameterListIR)
    -- if controlApplyMethodDef
        = CONTROL_APPLY `( parameterListIR )
            `{ controlLocalDeclarationListIR `; actionDefEnv `; controlBodyIR }
    -- if callTargetKey = $callTargetKey("apply", argumentListIR)
    -- if _ `: _ `# id_default* `# _
        = $find_overloaded<controlApplyMethodDef>(
            `{ (callableId `: controlApplyMethodDef) },
            callTargetKey,
            def $parameterListIR_of_controlApplyMethodDef)
    ---- ;; prepare the callee
    -- if controlApplyMethodCallee
        = CONTROL objectId `. APPLY `( parameterListIR `# id_default* )
            `{ theta `; frame `; controlLocalDeclarationListIR `;
               actionDefEnv `; controlBodyIR }

}

;;;; Table apply method call

rulegroup Callee_eval/tableApplyMethodCallee {

  rule Callee_eval/abort:
    p EC_0 ARCH_0 |- (typedExpressionIR `. "apply") `< `_ > `( eps )
                   : EC_1 ARCH_1 abortResult
    ---- ;; get storage reference of expression base
    -- if typedLvalueIR
        = $typedExpressionIR_as_typedLvalueIR(typedExpressionIR)
    -- Lvalue_eval:
        p EC_0 ARCH_0 |- typedLvalueIR : EC_1 ARCH_1 abortResult

  rule Callee_eval/cont:
    p EC_0 ARCH_0 |- (typedExpressionIR `. "apply") `< `_ > `( eps )
                   : EC_1 ARCH_1 (`` tableApplyMethodCallee)
    ---- ;; get storage reference of expression base
    -- if typedLvalueIR
        = $typedExpressionIR_as_typedLvalueIR(typedExpressionIR)
    -- Lvalue_eval:
        p EC_0 ARCH_0 |- typedLvalueIR
                       : EC_1 ARCH_1 (`` storageReference)
    ---- ;; read value of storage reference
    -- Lvalue_read:
        p EC_1 ARCH_1 |- storageReference : (REF objectId)
    ---- ;; if the value is an object reference to a table
    -- if TABLE typeId `{ frame TBL }
        = $find_object_e(ARCH_1, objectId)
    ---- ;; prepare the callee
    -- if tableApplyMethodCallee
        = TABLE objectId `. APPLY `{ frame `; TBL }

}

;;; TYPE prefixedNameIR `. nameIR

;;; `( routineTargetIR )
