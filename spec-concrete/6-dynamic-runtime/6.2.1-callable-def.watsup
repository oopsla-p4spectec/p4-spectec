;;
;; Callable definitions
;;

syntax stateEnv, actionDefEnv, frame, tableObjectProperty

;;
;;;; Action definitions
;;

syntax actionDef =
  annotationList ACTION nameIR `( parameterListIR ) blockStatementIR

;;
;;;; Function definitions
;;

syntax definedFunctionDef =
  FUNCTION nameIR `< typeParameterListIR >
    `( parameterListIR ) blockStatementIR

syntax externFunctionDef =
  EXTERN_FUNCTION nameIR
    `< typeParameterListIR > `( parameterListIR )

syntax functionDef =
  | definedFunctionDef
  | externFunctionDef

;;
;;;; Method definitions
;;

syntax externMethodDef =
  | EXTERN_METHOD nameIR `< typeParameterListIR >
      `( parameterListIR ) blockStatementIR?
  | EXTERN_METHOD ABSTRACT nameIR
      `< typeParameterListIR > `( parameterListIR )

syntax parserApplyMethodDef =
  PARSER_APPLY `( parameterListIR )
    `{ parserLocalDeclarationListIR `; stateEnv }

syntax controlApplyMethodDef =
  CONTROL_APPLY `( parameterListIR )
    `{ controlLocalDeclarationListIR `; actionDefEnv `; controlBodyIR }

syntax tableApplyMethodDef =
  TABLE_APPLY `{ tablePropertyListIR }

syntax methodDef =
  | externMethodDef
  | parserApplyMethodDef
  | controlApplyMethodDef
  | tableApplyMethodDef

syntax callableDef = actionDef | functionDef | methodDef
