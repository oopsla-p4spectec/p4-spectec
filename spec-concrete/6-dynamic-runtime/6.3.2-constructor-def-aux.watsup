;;
;; parameterListIR of a constructor definition
;;

dec $parameterListIR_of_constructorDef(constructorDef)
  : parameterIR*

def $parameterListIR_of_constructorDef(
    EXTERN _ `< _ > `( constructorParameterListIR ) `{ _ })
  = constructorParameterListIR

def $parameterListIR_of_constructorDef(
    PARSER `< _ > `( _ ) `( constructorParameterListIR ) `{ _ _ })
  = constructorParameterListIR

def $parameterListIR_of_constructorDef(
    CONTROL `< _ > `( _ ) `( constructorParameterListIR ) `{ _ APPLY _ })
  = constructorParameterListIR

def $parameterListIR_of_constructorDef(
    PACKAGE `< _ > `( constructorParameterListIR ))
  = constructorParameterListIR
