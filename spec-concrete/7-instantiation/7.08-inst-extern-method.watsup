;;
;; Extern method instantiation
;;
;; syntax externMethodPrototypeIR
;;

;;; annotationList functionPrototypeIR `;

rule ExternMethod_inst/non-abstract:
  IC_0 |- annotationList (typeIR nameIR
            `< typeParameterListIR `, typeParameterListIR_inferred >
            `( parameterListIR )) `;
        : IC_1
  ---- ;; bind extern method definition to environment
  -- if callableId = $callableId_IR(nameIR, parameterListIR)
  -- if externMethodDef
      = EXTERN_METHOD nameIR
        `< typeParameterListIR ++ typeParameterListIR_inferred >
        `( parameterListIR ) eps
  -- if IC_1 = $add_callableDef_overload_i(BLOCK, IC_0, callableId, externMethodDef)

;;; annotationList ABSTRACT functionPrototypeIR `;

rule ExternMethod_inst/abstract:
  IC_0 |- annotationList ABSTRACT (typeIR nameIR
            `< typeParameterListIR `, typeParameterListIR_inferred >
            `( parameterListIR )) `;
        : IC_1
  ---- ;; bind extern abstract method definition to environment
  -- if callableId = $callableId_IR(nameIR, parameterListIR)
  -- if externMethodDef
      = EXTERN_METHOD ABSTRACT nameIR
        `< typeParameterListIR ++ typeParameterListIR_inferred >
        `( parameterListIR )
  -- if IC_1 = $add_callableDef_overload_i(BLOCK, IC_0, callableId, externMethodDef)

;;
;; Extern method list instantiation
;;
;; syntax externMethodPrototypeListIR
;;

rulegroup ExternMethods_inst {

  rule ExternMethods_inst/nil:
    IC |- eps : IC

  rule ExternMethods_inst/cons:
    IC_0 |- externMethodPrototypeIR_h :: externMethodPrototypeIR_t* : IC_2
    -- ExternMethod_inst: IC_0 |- externMethodPrototypeIR_h : IC_1
    -- ExternMethods_inst: IC_1 |- externMethodPrototypeIR_t* : IC_2

}
