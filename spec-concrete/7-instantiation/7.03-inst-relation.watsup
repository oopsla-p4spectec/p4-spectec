;;
;;;; Expression instantiation
;;

relation Expr_inst:
  cursor instContext store |- typedExpressionIR : store value
  hint(input %0 %1 %2 %3)
  hint(prose_in "compile-time evaluation of" %3#
                ", under context" %1 "and store" %2 "at" %0)
  hint(prose_out "store" %4 "and" %5)

relation Exprs_inst:
  cursor instContext store |- typedExpressionIR* : store value*
  hint(input %0 %1 %2 %3)
  hint(prose_in "compile-time evaluation of" %3#
                ", under context" %1 "and store" %2 "at" %0)
  hint(prose_out "store" %4 "and" %5)

;;
;;;; Argument instantiation
;;

relation Argument_inst:
  cursor instContext store |- argumentIR : store value
  hint(input %0 %1 %2 %3)
  hint(prose_in "compile-time evaluation of" %3#
                ", under context" %1 "and store" %2 "at" %0)
  hint(prose_out "store" %4 "and" %5)

;;
;;;; Statement instantiation
;;

relation DirectApplicationStmt_inst:
  cursor instContext store |- directApplicationStatementIR
                            : store constantDeclarationIR callStatementIR
  hint(input %0 %1 %2 %3)
  hint(prose_in "compile-time evaluation of" %3#
                ", under context" %1 "and store" %2 "at" %0)
  hint(prose_out "store" %4 "and desugared" %5#"," %6)

relation Stmt_inst:
  cursor instContext store |- statementIR
                            : instContext store statementIR
  hint(input %0 %1 %2 %3)
  hint(prose_in "compile-time evaluation of" %3#
                ", under context" %1 "and store" %2 "at" %0)
  hint(prose_out "context" %4#", store" %5#", and" %6)

relation BlockElementStmt_inst:
  instContext store |- blockElementStatementIR
                      : instContext store blockElementStatementIR
  hint(input %0 %1 %2)
  hint(prose_in "compile-time evaluation of" %2#
                ", under context" %0#", and store" %1)
  hint(prose_out "context" %3#
                 ", store" %4#", and" %5)

relation BlockElementStmtList_inst:
  instContext store |- blockElementStatementListIR
                     : instContext store blockElementStatementIR*
  hint(input %0 %1 %2)
  hint(prose_in "compile-time evaluation of" %2#
                ", under context" %0#", and store" %1)
  hint(prose_out "context" %3#
                 ", store" %4#", and" %5)

relation Block_inst:
  instContext store |- blockStatementIR
                     : instContext store blockStatementIR
  hint(input %0 %1 %2)
  hint(prose_in "compile-time evaluation of" %2#
                ", under context" %0#", and store" %1)
  hint(prose_out "context" %3#
                 ", store" %4#", and" %5)

;;
;;;; Extern method/constructor instantiation
;;

relation ExternMethod_inst:
  instContext |- externMethodPrototypeIR : instContext
  hint(input %0 %1)

relation ExternMethods_inst:
  instContext |- externMethodPrototypeIR* : instContext
  hint(input %0 %1)
  hint(prose_in "compile-time evaluation of" %1#", under context" %0)
  hint(prose_out "context" %2)

;;
;;;; Parser instantiation
;;

relation ParserStmt_inst:
  instContext store |- parserStatementIR
                     : instContext store parserStatementIR
  hint(input %0 %1 %2)
  hint(prose_in "compile-time evaluation of" %2#", under context" %0
                "and store" %1)
  hint(prose_out "context" %3
                 "and store" %4)

relation ParserStmts_inst:
  instContext store |- parserStatementIR*
                     : instContext store parserStatementIR*
  hint(input %0 %1 %2)
  hint(prose_in "compile-time evaluation of" %2#", under context" %0
                "and store" %1)
  hint(prose_out "context" %3
                 "and store" %4)

relation ParserState_inst:
  instContext store |- parserStateIR
                     : instContext store
  hint(input %0 %1 %2)
  hint(prose_in "compile-time evaluation of" %2#", under context" %0
                "and store" %1)
  hint(prose_out "context" %3
                 "and store" %4)

relation ParserStates_inst:
  instContext store |- parserStateIR*
                     : instContext store
  hint(input %0 %1 %2)
  hint(prose_in "compile-time evaluation of" %2#", under context" %0
                "and store" %1)
  hint(prose_out "context" %3
                 "and store" %4)

relation ParserLocalDecl_inst:
  instContext store |- parserLocalDeclarationIR
                     : instContext store parserLocalDeclarationIR
  hint(input %0 %1 %2)
  hint(prose_in "compile-time evaluation of" %2#", under context" %0
                "and store" %1)
  hint(prose_out "context" %3#
                 ", store" %4#", and" %5)

relation ParserLocalDecls_inst:
  instContext store |- parserLocalDeclarationIR*
                     : instContext store parserLocalDeclarationIR*
  hint(input %0 %1 %2)
  hint(prose_in "compile-time evaluation of" %2#", under context" %0
                "and store" %1)
  hint(prose_out "context" %3#
                 ", store" %4#", and" %5)

;;
;;;; Control instantiation
;;

relation TableAction_inst:
  instContext store |- tableActionIR : store tableActionIR
  hint(input %0 %1 %2)
  hint(prose_in "compile-time evaluation of" %2#", under context" %0#
                "and store" %1)
  hint(prose_out "store" %3 "and" %4)

relation TableActions_inst:
  instContext store |- tableActionIR*
                     : store tableActionIR*
  hint(input %0 %1 %2)
  hint(prose_in "compile-time evaluation of" %2#", under context" %0#
                "and store" %1)
  hint(prose_out "store" %3 "and" %4)

relation TableProperty_inst:
  instContext store |- tablePropertyIR
                     : store tablePropertyIR
  hint(input %0 %1 %2)
  hint(prose_in "compile-time evaluation of" %2#", under context" %0#
                "and store" %1)
  hint(prose_out "store" %3 "and" %4)

relation TableProperties_inst:
  instContext store |- tablePropertyIR*
                     : store tablePropertyIR*
  hint(input %0 %1 %2)
  hint(prose_in "compile-time evaluation of" %2#", under context" %0#
                "and store" %1)
  hint(prose_out "store" %3 "and" %4)

relation ControlLocalDecl_inst:
  instContext store |- controlLocalDeclarationIR
                     : instContext store controlLocalDeclarationIR?
  hint(input %0 %1 %2)
  hint(prose_in "compile-time evaluation of" %2#", under context" %0#
                "and store" %1)
  hint(prose_out "context" %3#
                 ", store" %4#", and" %5)

relation ControlLocalDecls_inst:
  instContext store |- controlLocalDeclarationIR*
                     : instContext store controlLocalDeclarationIR*
  hint(input %0 %1 %2)
  hint(prose_in "compile-time evaluation of" %2#", under context" %0#
                "and store" %1)
  hint(prose_out "context" %3#
                 ", store" %4#", and" %5)

;;
;;;; Declaration instantiation
;;

relation ConstDecl_inst:
  cursor instContext |- constantDeclarationIR
                      : instContext
  hint(input %0 %1 %2)
  hint(prose_in "loading" %2#", under context" %1 "at" %0)
  hint(prose_out "context" %3)

relation InstDecl_inst:
  cursor instContext store |- instantiationIR
                            : instContext store constantDeclarationIR
  hint(input %0 %1 %2 %3)
  hint(prose_in "loading" %3#", under context" %1 "and store" %2 "at" %0)
  hint(prose_out "context" %4#", store" %5#","
                 "and reference to object" %6)

relation FuncDecl_inst:
  cursor instContext |- functionDeclarationIR
                      : instContext
  hint(input %0 %1 %2)
  hint(prose_in "loading" %2#", under context" %1 "at" %0)
  hint(prose_out "context" %3)

relation ActionDecl_inst:
  cursor instContext |- actionDeclarationIR
                      : instContext
  hint(input %0 %1 %2)
  hint(prose_in "loading" %2#", under context" %1 "at" %0)
  hint(prose_out "context" %3)

relation Decl_inst:
  instContext store |- declarationIR
                     : instContext store
  hint(input %0 %1 %2)
  hint(prose_in "loading" %2#", under context"
                %0#", and store" %1)
  hint(prose_out "context" %4 "and store" %5)

relation Decls_inst:
  instContext store |- declarationIR*
                     : instContext store
  hint(input %0 %1 %2)
  hint(prose_in "loading" %2#", under context"
                %0#", and store" %1)
  hint(prose_out "context" %4 "and store" %5)

relation Program_inst:
  |- p4program : globalInstLayer store
  hint(input %0)
  hint(prose_in "loading" %0)
  hint(prose_out "global instantiation layer" %1
                 "and store" %2)

;;
;;;; Instantiate constructor arguments using caller context,
;;;; and bind them to callee context
;;

relation Copy_in_argument_inst:
  store cursor instContext argumentIR
     `@ cursor instContext id
  ~> store instContext
  hint(input %0 %1 %2 %3 %4 %5 %6)

relation Copy_in_inst:
  store cursor instContext argumentIR*
     `@ cursor instContext id*
  ~> store instContext
  hint(input %0 %1 %2 %3 %4 %5 %6)
  hint(prose_in "copy-in from" %2 "at" %1 "with" %3
                "to" %5 "at" %4 "with" %6#", under store" %0)
  hint(prose_out "store" %7 "and context" %8)

relation Copy_in_argument_inst_default:
  store cursor instContext
     `@ cursor instContext parameterIR
  ~> store instContext
  hint(input %0 %1 %2 %3 %4 %5)

relation Copy_in_inst_default:
  store cursor instContext
     `@ cursor instContext parameterIR*
  ~> store instContext
  hint(input %0 %1 %2 %3 %4 %5)
  hint(prose_in "copying defaults" %5 "from" %1 "at" %2
                "to" %4 "at" %3#", under store" %0)
  hint(prose_out "store" %6 "and context" %7)

;;
;;;; Constructor instantiation
;;;; takes a constructor and returns an object
;;

relation Constructor_inst:
  cursor instContext |- prefixedNameIR
                          `< typeArgumentListIR >
                          `( argumentListIR )
                      : constructorDef `< typeArgumentListIR > `( `# id* `# id* )
  hint(input %0 %1 %2 %3 %4)
  hint(prose_in "finding constructor for" %2 `< %3 > `( %4 )
                "under context" %1 "at" %0)
  hint(prose_out "constructor" %5 `< %6 >
                 "with defaults" %7 "and optionals" %8)

relation Constructor_call:
  cursor instContext store |- constructorDef
                                `< typeArgumentListIR >
                                `( argumentListIR `# id* `# id* )
                             : store object
  hint(input %0 %1 %2 %3 %4 %5 %6 %7)
  hint(prose_in "instantiating" %3 `< %4 > `( %5 )
                "with defaults" %6 "and optionals" %7#
                ", under context" %1 "and store" %2 "at" %0)
  hint(prose_out "store" %8 "and instantiated" %9)
