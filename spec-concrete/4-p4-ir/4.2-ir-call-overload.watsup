;;
;; Call target overload resolution
;;

syntax callTargetKey = nameIR `( id?* )
syntax namedCallTargetKey = nameIR `( id* )
syntax unnamedCallTargetKey = nameIR `( nat )

syntax callTargetParameter = nameIR `# bool `# bool
syntax callTargetValue = callTargetParameter*

syntax callTargetMatch =
  | MATCH id* id*   hint(prose MATCH "with defaults" %0 and "optionals" %1)
  | NOMATCH

syntax callResolution<V> =
  callableId `: V `# nameIR* `# nameIR*
  hint(prose_fields "call target id" "call target" "defaults" "optionals")

dec $callTargetKey(nameIR, argumentListIR) : callTargetKey
  hint(prose_in "the call target key for" %0 `( %1 ))
dec $callTargetKey'(argumentIR) : id?

def $callTargetKey(nameIR_f, argumentIR*)
  = nameIR_f `( id_arg?* )
  -- if (id_arg? = $callTargetKey'(argumentIR))*

def $callTargetKey'(typedExpressionIR) = eps
def $callTargetKey'(id_arg `= _) = id_arg
def $callTargetKey'(id_arg `= `_) = id_arg
def $callTargetKey'(`_) = eps

;;
;;;; Match a single named call target against a named call target key
;;

dec $match_overloaded_named<V>(
    pair<callTargetId, V>,
    namedCallTargetKey,
    def $get_parameterListIR(V) : parameterListIR)
  : callTargetMatch
  hint(prose_in "matching" %0 "against named key" %1 "using parameter getter" %2)

;;; When call target names and arity match on named arguments,
;;; i.e., no default parameters used

def $match_overloaded_named<V>(
    (callTargetId `: V),
    nameIR_f `( id_arg* ),
    def $get_parameterListIR)
  = $ite<callTargetMatch>(
      $eq_set<id>(`{ id_param* }, `{ id_arg* }),
      MATCH eps eps, NOMATCH)
  ----
  -- if nameIR_f `( id_param* ) = callTargetId
  ----
  -- if parameterIR* = $get_parameterListIR(V)
  -- if (id_param = $id_of_parameterIR(parameterIR))*
  ----
  -- if |id_param*| = |id_arg*|

;;; When call target names match and arity is less than parameters,
;;; i.e., some default parameters used or some optional parameters omitted

def $match_overloaded_named<V>(
    (callTargetId `: V),
    nameIR_f `( id_arg* ),
    def $get_parameterListIR)
  = MATCH id_default* id_optional*
  ----
  -- if nameIR_f `( id_param* ) = callTargetId
  ----
  -- if parameterIR* = $get_parameterListIR(V)
  -- if (id_param = $id_of_parameterIR(parameterIR))*
  -- if (b_default = $is_default_parameterIR(parameterIR))*
  -- if (b_optional = $is_optional_parameterIR(parameterIR))*
  ----
  -- if $(|id_param*| > |id_arg*|)
  -- if `{ id_param_omitted* }
      = $diff_set<id>(`{ id_param* }, `{ id_arg* })
  -- if id_default_param*
      = $filter_<id>(id_param*, $is_default_parameterIR(parameterIR)*)
  -- if id_default*
      = $filter_<id>(id_param_omitted*, (id_param_omitted <- id_default_param*)*)
  -- if id_optional_param*
      = $filter_<id>(id_param*, $is_optional_parameterIR(parameterIR)*)
  -- if id_optional*
      = $filter_<id>(id_param_omitted*, (id_param_omitted <- id_optional_param*)*)
  -- if $eq_set<id>(
        `{ id_default* ++ id_optional* },
        `{ id_param_omitted* })

;;; Otherwise

def $match_overloaded_named<V>(
    (callTargetId `: V),
    nameIR_f `( id_arg* ),
    def $get_parameterListIR)
  = NOMATCH
  -- otherwise

;;
;;;; Match a single named call target against an unnamed call target key
;;

dec $match_overloaded_unnamed<V>(
    pair<callTargetId, V>,
    unnamedCallTargetKey,
    def $get_parameterListIR(V) : parameterListIR)
  : callTargetMatch
  hint(prose_in "matching" %0 "against unnamed key" %1 "using parameter getter" %2)

;;; When call target names and arity match on unnamed arguments,
;;; i.e., no default parameters used and no omitted optional parameters
;;; if a procedure-like construct has both optional parameters and
;;; default values then it can only be called using named arguments

def $match_overloaded_unnamed<V>(
    (callTargetId `: V),
    nameIR_f `( n_arg ),
    def $get_parameterListIR)
  = MATCH eps eps
  ----
  -- if nameIR_f `( id_param* ) = callTargetId
  ----
  -- if parameterIR* = $get_parameterListIR(V)
  -- if (b_default = $is_default_parameterIR(parameterIR))*
  -- if (b_optional = $is_optional_parameterIR(parameterIR))*
  -- if ~($exists_(b_default*) /\ $exists_(b_optional*))
  ----
  -- if |id_param*| = n_arg

;;; When call target names match, arity is less than parameters,
;;; and some default parameters used

def $match_overloaded_unnamed<V>(
    (callTargetId `: V),
    nameIR_f `( n_arg ),
    def $get_parameterListIR)
  = MATCH id_default* eps
  ----
  -- if nameIR_f `( id_param* ) = callTargetId
  ----
  -- if parameterIR* = $get_parameterListIR(V)
  -- if (b_default = $is_default_parameterIR(parameterIR))*
  -- if (b_optional = $is_optional_parameterIR(parameterIR))*
  -- if ~($exists_(b_default*) /\ $exists_(b_optional*))
  ----
  -- if $(|id_param*| > n_arg)
  ----
  -- if (parameterIR_given*, parameterIR_omitted*)
      = $partition_<parameterIR>(parameterIR*, n_arg)
  -- if (~$is_optional_parameterIR(parameterIR_omitted))*
  -- if $is_default_parameterIR(parameterIR_omitted)*
  -- if (id_default = $id_of_parameterIR(parameterIR_omitted))*

;;; When call target names match, arity is less than parameters,
;;; and some optional parameters omitted

def $match_overloaded_unnamed<V>(
    (callTargetId `: V),
    nameIR_f `( n_arg ),
    def $get_parameterListIR)
  = MATCH eps id_optional*
  ----
  -- if nameIR_f `( id_param* ) = callTargetId
  ----
  -- if parameterIR* = $get_parameterListIR(V)
  -- if (b_default = $is_default_parameterIR(parameterIR))*
  -- if (b_optional = $is_optional_parameterIR(parameterIR))*
  -- if ~($exists_(b_default*) /\ $exists_(b_optional*))
  ----
  -- if $(|id_param*| > n_arg)
  ----
  -- if (parameterIR_given*, parameterIR_omitted*)
      = $partition_<parameterIR>(parameterIR*, n_arg)
  -- if (~$is_default_parameterIR(parameterIR_given))*
  -- if $is_optional_parameterIR(parameterIR_omitted)*
  -- if (id_optional = $id_of_parameterIR(parameterIR_omitted))*

;;; Otherwise

def $match_overloaded_unnamed<V>(
    (callTargetId `: V),
    nameIR_f `( n_arg ),
    def $get_parameterListIR)
  = NOMATCH
  -- otherwise

;;
;;;; Find all matching call targets (V), given a callable key with named arguments
;;

dec $find_overloadeds_named<V>(
    map<callableId, V>,
    namedCallTargetKey,
    def $get_parameterListIR(V) : parameterListIR)
  : callResolution<V>*
  hint(prose_in "finding all items in" %0 "matching named key" %1 "using parameter getter" %2)

def $find_overloadeds_named<V>(
    `{ eps },
    nameIR_f `( id_arg* ),
    def $get_parameterListIR)
  = eps

def $find_overloadeds_named<V>(
    `{ (callTargetId_h `: V_h) :: (callTargetId_t `: V_t)* },
    nameIR_f `( id_arg* ),
    def $get_parameterListIR)
  = $find_overloadeds_named<V>(
      `{ (callTargetId_t `: V_t)* },
      nameIR_f `( id_arg* ),
      def $get_parameterListIR)
  -- if NOMATCH
      = $match_overloaded_named<V>(
          (callTargetId_h `: V_h),
          nameIR_f `( id_arg* ),
          def $get_parameterListIR)

def $find_overloadeds_named<V>(
    `{ (callTargetId_h `: V_h) :: (callTargetId_t `: V_t)* },
    nameIR_f `( id_arg* ),
    def $get_parameterListIR)
  =  (callTargetId_h `: V_h `# id_default* `# id_optional*) ::
      $find_overloadeds_named<V>(
        `{ (callTargetId_t `: V_t)* },
        nameIR_f `( id_arg* ),
        def $get_parameterListIR)
  -- if MATCH id_default* id_optional*
      = $match_overloaded_named<V>(
          (callTargetId_h `: V_h),
          nameIR_f `( id_arg* ),
          def $get_parameterListIR)

;;
;;;; Find all matching call targets (V), given a callable key with named arguments
;;

dec $find_overloadeds_unnamed<V>(
    map<callableId, V>,
    unnamedCallTargetKey,
    def $get_parameterListIR(V) : parameterListIR)
  : callResolution<V>*
  hint(prose_in "finding all items in" %0 "matching unnamed key" %1 "using parameter getter" %2)

def $find_overloadeds_unnamed<V>(
    `{ eps },
    nameIR_f `( nat ),
    def $get_parameterListIR)
  = eps

def $find_overloadeds_unnamed<V>(
    `{ (callTargetId_h `: V_h) :: (callTargetId_t `: V_t)* },
    nameIR_f `( n_arg ),
    def $get_parameterListIR)
  = $find_overloadeds_unnamed<V>(
      `{ (callTargetId_t `: V_t)* },
      nameIR_f `( n_arg ),
      def $get_parameterListIR)
  -- if NOMATCH
      = $match_overloaded_unnamed<V>(
          (callTargetId_h `: V_h),
          nameIR_f `( n_arg ),
          def $get_parameterListIR)

def $find_overloadeds_unnamed<V>(
    `{ (callTargetId_h `: V_h) :: (callTargetId_t `: V_t)* },
    nameIR_f `( n_arg ),
    def $get_parameterListIR)
  = (callTargetId_h `: V_h `# id_default* `# id_optional*) ::
      $find_overloadeds_unnamed<V>(
        `{ (callTargetId_t `: V_t)* },
        nameIR_f `( n_arg ),
        def $get_parameterListIR)
  -- if MATCH id_default* id_optional*
      = $match_overloaded_unnamed<V>(
          (callTargetId_h `: V_h),
          nameIR_f `( n_arg ),
          def $get_parameterListIR)

;;
;;;; Find a matching call target (V), given a callable key via overloads
;;

dec $find_overloaded<V>(
    map<callTargetId, V>,
    callTargetKey,
    def $get_parameterListIR(V) : parameterListIR)
  : callResolution<V>?
  hint(prose_in "finding the item in" %0 "matching" %1 "using parameter getter" %2)

;;; When all arguments are named

def $find_overloaded<V>(
    `{ (callableId `: V)* },
    nameIR_f `( id_arg?* ),
    def $get_parameterListIR)
  = eps
  -- if $(|(id_arg?)*| > 0)
  -- if (id_arg_inner = id_arg?)*
  -- if eps
      = $find_overloadeds_named<V>(
          `{ (callableId `: V)* },
          nameIR_f `( id_arg_inner* ),
          def $get_parameterListIR)

def $find_overloaded<V>(
    `{ (callableId `: V)* },
    nameIR_f `( id_arg?* ),
    def $get_parameterListIR)
  = callableId_found `: V_found `# id_default* `# id_optional*
  -- if $(|(id_arg?)*| > 0)
  -- if (id_arg_inner = id_arg?)*
  -- if callableId_found `: V_found `# id_default* `# id_optional*
      = $find_overloadeds_named<V>(
          `{ (callableId `: V)* },
          nameIR_f `( id_arg_inner* ),
          def $get_parameterListIR)

;;; When all arguments are unnamed

def $find_overloaded<V>(
    `{ (callableId `: V)* },
    nameIR_f `( id_arg?* ),
    def $get_parameterListIR)
  = eps
  -- if (id_arg? = eps)*
  -- if eps
      = $find_overloadeds_unnamed<V>(
          `{ (callableId `: V)* },
          nameIR_f `( |id_arg?*| ),
          def $get_parameterListIR)

def $find_overloaded<V>(
    `{ (callableId `: V)* },
    nameIR_f `( id_arg?* ),
    def $get_parameterListIR)
  = callableId_found `: V_found `# id_omitted* `# id_optional*
  -- if (id_arg? = eps)*
  -- if callableId_found `: V_found `# id_omitted* `# id_optional*
      = $find_overloadeds_unnamed<V>(
          `{ (callableId `: V)* },
          nameIR_f `( |id_arg?*| ),
          def $get_parameterListIR)

;;
;;;; Find a matching call target (V), given a callable key via non-overloads
;;

dec $find_non_overloaded<V>(map<callableId, V>, nameIR)
  : (callableId, V)?
dec $find_non_overloadeds<V>(map<callableId, V>, nameIR)
  : (callableId, V)*

def $find_non_overloaded<V>(
    `{ (callableId `: V)* }, nameIR_f)
  = (callableId_found, V_found)
  -- if (callableId_found, V_found)
      = $find_non_overloadeds<V>(`{ (callableId `: V)* }, nameIR_f)
def $find_non_overloaded<V>(
    `{ (callableId `: V)* }, nameIR_f)
  = eps
  -- otherwise

def $find_non_overloadeds<V>(`{ eps }, nameIR_f) = eps
def $find_non_overloadeds<V>(
    `{ (callableId_h `: V_h) :: (callableId_t `: V_t)* }, nameIR_f)
  = (callableId_h, V_h) :: (callableId_t_found, V_t_found)*
  -- if nameIR_f `( _ ) = callableId_h
  -- if (callableId_t_found, V_t_found)*
      = $find_non_overloadeds<V>(`{ (callableId_t `: V_t)* }, nameIR_f)
def $find_non_overloadeds<V>(
    `{ (callableId_h `: V_h) :: (callableId_t `: V_t)* }, nameIR_f)
  = (callableId_t_found, V_t_found)*
  -- if nameIR_f_h `( _ ) = callableId_h
  -- if nameIR_f =/= nameIR_f_h
  -- if (callableId_t_found, V_t_found)*
      = $find_non_overloadeds<V>(`{ (callableId_t `: V_t)* }, nameIR_f)
