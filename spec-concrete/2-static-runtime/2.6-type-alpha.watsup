;;
;; Relations for type alpha-equivalence
;;

relation Type_alpha:
  typeIR ~~ typeIR
  hint(input %0 %1)
  hint(prose_true %0 "and" %1 "are the same type")
  hint(prose_false %0 "and" %1 "are not the same type")

relation ParameterType_alpha:
  parameterIR ~~ parameterIR
  hint(input %0 %1)
  hint(prose_true %0 "and" %1 "are the same type")
  hint(prose_false %0 "and" %1 "are not the same type")

relation ExternMethodType_alpha:
  externMethodTypeIR ~~ externMethodTypeIR
  hint(input %0 %1)
  hint(prose_true %0 "and" %1 "are the same type")
  hint(prose_false %0 "and" %1 "are not the same type")

relation ExternMethodTypeDef_alpha:
  externMethodTypeDefIR ~~ externMethodTypeDefIR
  hint(input %0 %1)
  hint(prose_true %0 "and" %1 "are the same type")
  hint(prose_false %0 "and" %1 "are not the same type")

;;
;;;; Alpha-equivalence of types
;;

;;; Base types

rule Type_alpha/baseTypeIR:
  baseTypeIR ~~ baseTypeIR

;;; Name types

rule Type_alpha/nameTypeIR:
  (`` typeId) ~~  (`` typeId)

;;; Alias types

rulegroup Type_alpha/typedefTypeIR {

  rule Type_alpha/left:
    (TYPEDEF _ typeIR_a) ~~ typeIR_b
    -- Type_alpha: typeIR_a ~~ typeIR_b

  rule Type_alpha/right:
    typeIR_a ~~ (TYPEDEF _ typeIR_b)
    -- if ~(typeIR_a <: typedefTypeIR)
    -- Type_alpha: typeIR_a ~~ typeIR_b

}

rule Type_alpha/newTypeIR:
  (TYPE typeId typeIR_a) ~~ (TYPE typeId typeIR_b)
  -- Type_alpha: typeIR_a ~~ typeIR_b

;;; Data types

rule Type_alpha/listTypeIR:
  (LIST `< typeIR_a >) ~~ (LIST `< typeIR_b >)
  -- Type_alpha: typeIR_a ~~ typeIR_b

rule Type_alpha/tupleTypeIR:
  (TUPLE `< typeIR_a* >) ~~ (TUPLE `< typeIR_b* >)
  -- (Type_alpha: typeIR_a ~~ typeIR_b)*

rule Type_alpha/headerStackTypeIR:
  (typeIR_a `[ n_size ]) ~~ (typeIR_b `[ n_size ])
  -- Type_alpha: typeIR_a ~~ typeIR_b

rule Type_alpha/structTypeIR:
  (STRUCT typeId `< typeArgumentIR_a* > `{ _ })
  ~~ (STRUCT typeId `< typeArgumentIR_b* > `{ _ })
  -- (Type_alpha: typeArgumentIR_a ~~ typeArgumentIR_b)*

rule Type_alpha/headerTypeIR:
  (HEADER typeId `< typeArgumentIR_a* > `{ _ })
  ~~ (HEADER typeId `< typeArgumentIR_b* > `{ _ })
  -- (Type_alpha: typeArgumentIR_a ~~ typeArgumentIR_b)*

rule Type_alpha/headerUnionTypeIR:
  (HEADER_UNION typeId `< typeArgumentIR_a* > `{ _ })
  ~~ (HEADER_UNION typeId `< typeArgumentIR_b* > `{ _ })
  -- (Type_alpha: typeArgumentIR_a ~~ typeArgumentIR_b)*

rulegroup Type_alpha/enumTypeIR {

  rule Type_alpha/non-serializable:
    (ENUM typeId `{ nameIR_field* }) ~~ (ENUM typeId `{ nameIR_field* })

  rule Type_alpha/serializable:
    (ENUM typeId `< typeIR_a > `{ (nameIR_field `= value_field `;)* })
    ~~ (ENUM typeId `< typeIR_b > `{ (nameIR_field `= value_field `;)* })
    -- Type_alpha: typeIR_a ~~ typeIR_b

}

;;; Object types

rule Type_alpha/externObjectTypeIR:
  (EXTERN typeId `< typeArgumentIR_a* > _) ~~ (EXTERN typeId `< typeArgumentIR_b* > _)
  -- (Type_alpha: typeArgumentIR_a ~~ typeArgumentIR_b)*

rule Type_alpha/parserObjectTypeIR:
  (PARSER _ `< _ > `( parameterIR_a* )) ~~ (PARSER _ `< _ > `( parameterIR_b* ))
  -- (ParameterType_alpha: parameterIR_a ~~ parameterIR_b)*

rule Type_alpha/controlObjectTypeIR:
  (CONTROL _ `< _ > `( parameterIR_a* )) ~~ (CONTROL _ `< _ > `( parameterIR_b* ))
  -- (ParameterType_alpha: parameterIR_a ~~ parameterIR_b)*

rule Type_alpha/packetObjectTypeIR:
  (PACKAGE _ `< _ > `{ typeIR_a* }) ~~ (PACKAGE _ `< _ > `{ typeIR_b* })
  -- (Type_alpha: typeIR_a ~~ typeIR_b)*

rule Type_alpha/tableObjectTypeIR:
  tableObjectTypeIR ~~ tableObjectTypeIR

;;; Synthesized types

rule Type_alpha/defaultTypeIR:
  DEFAULT ~~ DEFAULT

rule Type_alpha/invalidHeaderTypeIR:
  HEADER_INVALID ~~ HEADER_INVALID

rulegroup Type_alpha/sequenceTypeIR {

  rule Type_alpha/non-default:
    (SEQ `< typeIR_a* >) ~~ (SEQ `< typeIR_b* >)
    -- (Type_alpha: typeIR_a ~~ typeIR_b)*

  rule Type_alpha/default:
    (SEQ `< typeIR_a* `, `... >) ~~ (SEQ `< typeIR_b* `, `... >)
    -- (Type_alpha: typeIR_a ~~ typeIR_b)*

}

rulegroup Type_alpha/recordTypeIR {

  rule Type_alpha/non-default:
    (RECORD `{ (annotationList typeIR_field_a nameIR_field `;)* })
    ~~ (RECORD `{ (annotationList typeIR_field_b nameIR_field `;)* })
    -- (Type_alpha: typeIR_field_a ~~ typeIR_field_b)*

  rule Type_alpha/default:
    (RECORD `{ (annotationList typeIR_field_a nameIR_field `;)* `, `... })
    ~~ (RECORD `{ (annotationList typeIR_field_b nameIR_field `;)* `, `... })
    -- (Type_alpha: typeIR_field_a ~~ typeIR_field_b)*

}

rule Type_alpha/setTypeIR:
  (SET `< typeIR_a >) ~~ (SET `< typeIR_b >)
  -- Type_alpha: typeIR_a ~~ typeIR_b

rule Type_alpha/tableMetadataTypeIR:
  tableMetadataTypeIR ~~ tableMetadataTypeIR

;;
;;;; Alpha-equivalence of parameter types
;;

rule ParameterType_alpha:
  (_ direction typeIR_a _ _) ~~ (_ direction typeIR_b _ _)
  -- Type_alpha: typeIR_a ~~ typeIR_b

;;
;;;; Alpha-equivalence of extern method callable types
;;

rulegroup ExternMethodType_alpha {

  rule ExternMethodType_alpha/non-abstract:
    (EXTERN_METHOD nameIR `( parameterIR_a* ) `: typeIR_a)
    ~~ (EXTERN_METHOD nameIR `( parameterIR_b* ) `: typeIR_b)
    -- (ParameterType_alpha:
          parameterIR_a ~~ parameterIR_b)*
    -- Type_alpha: typeIR_a ~~ typeIR_b

  rule ExternMethodType_alpha/abstract:
    (EXTERN_METHOD ABSTRACT nameIR `( parameterIR_a* ) `: typeIR_a)
    ~~ (EXTERN_METHOD ABSTRACT nameIR `( parameterIR_b* ) `: typeIR_b)
    -- (ParameterType_alpha:
          parameterIR_a ~~ parameterIR_b)*
    -- Type_alpha: typeIR_a ~~ typeIR_b

}

;;
;;;; Alpha-equivalence of callable type definitions
;;

rule ExternMethodTypeDef_alpha:
  externMethodTypeDefIR_a ~~ externMethodTypeDefIR_b
  ---- ;; retrieve type parameters
  -- if (typeParameterIR_expl_a*, typeParameterIR_impl_a*)
      = $typeParameterListIR_of_callableTypeDefIR(externMethodTypeDefIR_a)
  -- if (typeParameterIR_expl_b*, typeParameterIR_impl_b*)
      = $typeParameterListIR_of_callableTypeDefIR(externMethodTypeDefIR_b)
  ---- ;; check type parameter arity
  -- if |typeParameterIR_expl_a*| = |typeParameterIR_expl_b*|
  -- if |typeParameterIR_impl_a*| = |typeParameterIR_impl_b*|
  ---- ;; create fresh type variables
  -- if typeParameterIR_fresh*
      = $fresh_typeIds(|typeParameterIR_expl_a* ++ typeParameterIR_impl_a*|)
  ---- ;; substitute the left hand side
  -- if typeParameterIR_a* = typeParameterIR_expl_a* ++ typeParameterIR_impl_a*
  -- if theta_a = `{ (typeParameterIR_a `: (`` typeParameterIR_fresh))* }
  -- if externMethodTypeIR_a
      = $callableTypeIR_of_callableTypeDefIR(externMethodTypeDefIR_a)
  -- if externMethodTypeIR_a_subst
      = $subst_callableTypeIR(theta_a, externMethodTypeIR_a)
  ---- ;; substitute the right hand side
  -- if typeParameterIR_b* = typeParameterIR_expl_b* ++ typeParameterIR_impl_b*
  -- if theta_b = `{ (typeParameterIR_b `: (`` typeParameterIR_fresh))* }
  -- if externMethodTypeIR_b
      = $callableTypeIR_of_callableTypeDefIR(externMethodTypeDefIR_b)
  -- if externMethodTypeIR_b_subst
      = $subst_callableTypeIR(theta_b, externMethodTypeIR_b)
  ---- ;; compare the substituted definitions
  -- ExternMethodType_alpha:
      externMethodTypeIR_a_subst ~~ externMethodTypeIR_b_subst
