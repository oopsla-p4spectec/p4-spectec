;;
;; Type definitions
;;

syntax typeParameterIR = typeId

;;
;;;; Name type definitions (to represent type parameters)
;;

syntax nameTypeDefIR = nameTypeIR

;;
;;;; Alias type definitions
;;

syntax aliasTypeDefIR = aliasTypeIR

;;
;;;; Data type definitions
;;

syntax structTypeDefIR =
  STRUCT typeId `< typeParameterIR* > `{ fieldTypeIR* }
syntax headerTypeDefIR =
  HEADER typeId `< typeParameterIR* > `{ fieldTypeIR* }
syntax headerUnionTypeDefIR =
  HEADER_UNION typeId `< typeParameterIR* > `{ fieldTypeIR* }

syntax enumTypeDefIR = enumTypeIR

syntax dataTypeDefIR =
  | structTypeDefIR
  | headerTypeDefIR
  | headerUnionTypeDefIR
  | enumTypeDefIR

;;
;;;; Object type definitions
;;

syntax externObjectTypeDefIR =
  EXTERN typeId `< typeParameterIR* `, typeParameterIR* >
    externMethodTypeDefEnv

syntax parserObjectTypeDefIR =
  PARSER typeId `< typeParameterIR* `, typeParameterIR* >
    `( parameterIR* )

syntax controlObjectTypeDefIR =
  CONTROL typeId `< typeParameterIR* `, typeParameterIR* >
    `( parameterIR* )

syntax packageObjectTypeDefIR =
  PACKAGE typeId `< typeParameterIR* `, typeParameterIR* >
    `{ typeIR* }

syntax tableObjectTypeDefIR = tableObjectTypeIR

syntax objectTypeDefIR =
  | externObjectTypeDefIR
  | parserObjectTypeDefIR
  | controlObjectTypeDefIR
  | packageObjectTypeDefIR
  | tableObjectTypeDefIR

;;
;;;; Type definitions
;;

syntax typeDefIR =
  | nameTypeDefIR
  | aliasTypeDefIR
  | dataTypeDefIR
  | objectTypeDefIR
