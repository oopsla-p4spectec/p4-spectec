;;
;; Value
;;

;;
;;;; Base values
;;

syntax boolValue = `B bool
syntax errorValue = ERROR `. nameIR
syntax matchKindValue = MATCH_KIND `. nameIR
syntax stringValue = stringLiteral

syntax integerValue =
  | integerLiteral
  | nat `. nat V int

syntax baseValue =
  | boolValue
  | errorValue
  | matchKindValue
  | stringValue
  | integerValue

;;
;;;; Data values
;;

syntax value

syntax listValue = LIST `[ value* ]
syntax tupleValue = TUPLE `( value* )
syntax headerStackValue = HEADER_STACK `[ value* `( nat `; nat ) ]

syntax fieldValue = value nameIR `;

syntax structValue = STRUCT typeId `{ fieldValue* }
syntax headerValue = HEADER typeId `{ bool `; fieldValue* }
syntax headerUnionValue = HEADER_UNION typeId `{ fieldValue* }

syntax enumValue =
  | typeId `. nameIR
  | typeId `. nameIR `. value

syntax dataValue =
  | listValue
  | tupleValue
  | headerStackValue
  | structValue
  | headerValue
  | headerUnionValue
  | enumValue

;;
;;;; Object reference values
;;

syntax objectReferenceValue = REF objectId

;;
;;;; Synthesized values
;;

syntax defaultValue = DEFAULT

syntax invalidHeaderValue = `{#}

syntax sequenceValue =
  | SEQ `( value* )
  | SEQ `( value* `, `... )

syntax recordValue =
  | RECORD `{ fieldValue* }
  | RECORD `{ fieldValue* `, `... }

syntax setValue =
  | SET `{ value }
  | SET `{ value* `( nat ) }
  | SET `{ value `&&& value }
  | SET `{ value `.. value }
  | SET `{ `... }

syntax tableMetadataEnumValue = TABLE_ENUM typeId `. nameIR

syntax tableMetadataStructValue =
  TABLE_STRUCT typeId `{ HIT boolValue `;
                         MISS boolValue `;
                         ACTION_RUN tableMetadataEnumValue `; }

syntax tableMetadataValue =
  | tableMetadataEnumValue
  | tableMetadataStructValue

syntax synthesizedValue =
  | defaultValue
  | invalidHeaderValue
  | sequenceValue
  | recordValue
  | setValue
  | tableMetadataValue

;;
;;;; Values
;;

syntax value =
  | baseValue
  | dataValue
  | objectReferenceValue
  | synthesizedValue
