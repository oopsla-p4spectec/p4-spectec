;;
;; Substitution (capture-avoiding)
;;

syntax theta = map<typeId, typeIR>

dec $empty_theta : theta
def $empty_theta = $empty_map<typeId, typeIR>

dec $capture_avoiding_(theta, typeParameterIR*, bound)
  : (theta, typeParameterIR*)
dec $capture_avoiding(theta, typeId*, typeId*, bound)
  : (theta, typeId*, typeId*)

dec $subst_typeIR(theta, typeIR) : typeIR
  hint(prose_in %1 "substituted by" %0)
dec $subst_typeIR'(theta, typeIR) : typeIR
  hint(prose_in %1 "substituted by a non-empty" %0)

dec $subst_parameterIR(theta, parameterIR) : parameterIR
  hint(prose_in %1 "substituted by" %0)
dec $subst_parameterIR'(theta, parameterIR) : parameterIR
  hint(prose_in %1 "substituted by a non-empty" %0)

dec $subst_callableTypeIR(theta, callableTypeIR) : callableTypeIR
  hint(prose_in %1 "substituted by" %0)
dec $subst_callableTypeIR'(theta, callableTypeIR) : callableTypeIR
  hint(prose_in %1 "substituted by a non-empty" %0)

dec $subst_callableTypeDefIR(theta, callableTypeDefIR) : callableTypeDefIR
  hint(prose_in %1 "substituted by" %0)
dec $subst_callableTypeDefIR'(theta, callableTypeDefIR) : callableTypeDefIR
  hint(prose_in %1 "substituted by a non-empty" %0)

dec $subst_constructorTypeIR(theta, constructorTypeIR) : constructorTypeIR
  hint(prose_in %1 "substituted by" %0)
dec $subst_constructorTypeIR'(theta, constructorTypeIR) : constructorTypeIR
  hint(prose_in %1 "substituted by a non-empty" %0)

;;
;;;; Capture avoidance
;;

def $capture_avoiding_(theta, typeParameterIR*, B)
  = (theta_fresh, typeParameterIR_fresh*)
  ---- ;; collect free type variables
  -- if `{ typeId_free* }
      = $diff_set<typeId>(B, `{ typeParameterIR* })
  ---- ;; compute captured type variables
  -- if (typeIR_free = $find_map<typeId, typeIR>(theta, typeId_free))*
  -- if B_capture
      = $unions_set<typeId>($free_typeIR(typeIR_free)*)
  ---- ;; create fresh type variables to avoid capture
  -- if typeParameterIR_fresh* = $fresh_typeIds(|typeParameterIR*|)
  -- if (~$in_set<typeId>(typeParameterIR_fresh, B_capture))*
  ---- ;; update substitution mapping
  -- if theta_fresh
      = $adds_map<typeId, typeIR>(
          theta, typeParameterIR*, (`` typeParameterIR_fresh)*)

def $capture_avoiding(theta, typeParameterIR_expl*, typeParameterIR_impl*, B)
  = (theta_fresh, typeParameterIR_expl_fresh*, typeParameterIR_impl_fresh*)
  ---- ;; collect free type variables
  -- if `{ typeId_free* }
      = $diff_set<typeId>(B, `{ typeParameterIR_expl* ++ typeParameterIR_impl* })
  ---- ;; compute captured type variables
  -- if (typeIR_free = $find_map<typeId, typeIR>(theta, typeId_free))*
  -- if B_capture
      = $unions_set<typeId>($free_typeIR(typeIR_free)*)
  ---- ;; create fresh type variables to avoid capture
  -- if typeId_fresh* = $fresh_typeIds(|typeParameterIR_expl* ++ typeParameterIR_impl*|)
  -- if (~$in_set<typeId>(typeId_fresh, B_capture))*
  -- if typeParameterIR_expl_fresh* = typeId_fresh*[0 : |typeParameterIR_expl*|]
  -- if typeParameterIR_impl_fresh* = typeId_fresh*[|typeParameterIR_expl*| : |typeParameterIR_impl*|]
  ---- ;; update substitution mapping
  -- if theta_fresh
      = $adds_map<typeId, typeIR>(
          theta,
          typeParameterIR_expl* ++ typeParameterIR_impl*,
          (`` typeParameterIR_expl_fresh)* ++ (`` typeParameterIR_impl_fresh)*)

;;
;;;; Type substitutions
;;

def $subst_typeIR(`{ eps }, typeIR) = typeIR
def $subst_typeIR(theta, typeIR) = $subst_typeIR'(theta, typeIR)
  -- otherwise

;;; Base types

def $subst_typeIR'(theta, baseTypeIR) = baseTypeIR

;;; Named types

def $subst_typeIR'(theta, `` typeId) = typeIR
  -- if typeIR = $find_map<typeId, typeIR>(theta, typeId)
def $subst_typeIR'(theta, `` typeId) = `` typeId
  -- if eps = $find_map<typeId, typeIR>(theta, typeId)

;;; Alias types

def $subst_typeIR'(theta, TYPEDEF typeId typeIR)
  = TYPEDEF typeId typeIR_subst
  -- if typeIR_subst = $subst_typeIR'(theta, typeIR)

def $subst_typeIR'(theta, TYPE typeId typeIR)
  = TYPE typeId typeIR_subst
  -- if typeIR_subst = $subst_typeIR'(theta, typeIR)

;;; Data types

def $subst_typeIR'(theta, LIST `< typeIR >)
  = LIST `< typeIR_subst >
  -- if typeIR_subst = $subst_typeIR'(theta, typeIR)

def $subst_typeIR'(theta, TUPLE `< typeIR* >)
  = TUPLE `< typeIR_subst* >
  -- if (typeIR_subst = $subst_typeIR'(theta, typeIR))*

def $subst_typeIR'(theta, typeIR `[ n_size ])
  = typeIR_subst `[ n_size ]
  -- if typeIR_subst = $subst_typeIR'(theta, typeIR)

def $subst_typeIR'(theta, structTypeIR)
  = structTypeIR_subst
  -- if STRUCT typeId `< typeArgumentIR* >
          `{ (annotationList typeIR_field nameIR_field `;)* }
      = structTypeIR
  -- if (typeArgumentIR_subst = $subst_typeIR'(theta, typeArgumentIR))*
  -- if (typeIR_field_subst = $subst_typeIR'(theta, typeIR_field))*
  -- if structTypeIR_subst
      = STRUCT typeId `< typeArgumentIR_subst* >
          `{ (annotationList typeIR_field_subst nameIR_field `;)* }

def $subst_typeIR'(theta, headerTypeIR)
  = headerTypeIR_subst
  -- if HEADER typeId `< typeArgumentIR* >
          `{ (annotationList typeIR_field nameIR_field `;)* }
      = headerTypeIR
  -- if (typeArgumentIR_subst = $subst_typeIR'(theta, typeArgumentIR))*
  -- if (typeIR_field_subst = $subst_typeIR'(theta, typeIR_field))*
  -- if headerTypeIR_subst
      = HEADER typeId `< typeArgumentIR_subst* >
          `{ (annotationList typeIR_field_subst nameIR_field `;)* }

def $subst_typeIR'(theta, headerUnionTypeIR)
  = headerUnionTypeIR_subst
  -- if HEADER_UNION typeId `< typeArgumentIR* >
          `{ (annotationList typeIR_field nameIR_field `;)* }
      = headerUnionTypeIR
  -- if (typeArgumentIR_subst = $subst_typeIR'(theta, typeArgumentIR))*
  -- if (typeIR_field_subst = $subst_typeIR'(theta, typeIR_field))*
  -- if headerUnionTypeIR_subst
      = HEADER_UNION typeId `< typeArgumentIR_subst* >
          `{ (annotationList typeIR_field_subst nameIR_field `;)* }

def $subst_typeIR'(theta, ENUM typeId `{ id_field* })
  = ENUM typeId `{ id_field* }

def $subst_typeIR'(theta, ENUM typeId `< typeIR > `{ valueFieldIR* })
  = ENUM typeId `< typeIR_subst > `{ valueFieldIR* }
  -- if typeIR_subst = $subst_typeIR'(theta, typeIR)

;;; Object types

def $subst_typeIR'(theta, externObjectTypeIR)
  = externObjectTypeIR_subst
  -- if EXTERN typeId `< typeArgumentIR* >
          `{ (callableId `: externMethodTypeDefIR)* }
      = externObjectTypeIR
  -- if (typeArgumentIR_subst = $subst_typeIR'(theta, typeArgumentIR))*
  -- if (externMethodTypeDefIR_subst
        = $subst_callableTypeDefIR(theta, externMethodTypeDefIR))*
  -- if externObjectTypeIR_subst
      = EXTERN typeId `< typeArgumentIR_subst* >
          `{ (callableId `: externMethodTypeDefIR_subst)* }

def $subst_typeIR'(theta, parserObjectTypeIR)
  = parserObjectTypeIR_subst
  -- if PARSER typeId `< typeArgumentIR* > `( parameterIR* )
      = parserObjectTypeIR
  -- if (typeArgumentIR_subst = $subst_typeIR'(theta, typeArgumentIR))*
  -- if (parameterIR_subst
      = $subst_parameterIR'(theta, parameterIR))*
  -- if parserObjectTypeIR_subst
      = PARSER typeId `< typeArgumentIR_subst* > `( parameterIR_subst* )

def $subst_typeIR'(theta, controlObjectTypeIR)
  = controlObjectTypeIR_subst
  -- if CONTROL typeId `< typeArgumentIR* > `( parameterIR* )
      = controlObjectTypeIR
  -- if (typeArgumentIR_subst = $subst_typeIR'(theta, typeArgumentIR))*
  -- if (parameterIR_subst
      = $subst_parameterIR'(theta, parameterIR))*
  -- if controlObjectTypeIR_subst
      = CONTROL typeId `< typeArgumentIR_subst* > `( parameterIR_subst* )

def $subst_typeIR'(theta, packageObjectTypeIR)
  = packageObjectTypeIR_subst
  -- if PACKAGE typeId `< typeArgumentIR* > `{ typeIR* }
      = packageObjectTypeIR
  -- if (typeArgumentIR_subst = $subst_typeIR'(theta, typeArgumentIR))*
  -- if (typeIR_subst = $subst_typeIR'(theta, typeIR))*
  -- if packageObjectTypeIR_subst
      = PACKAGE typeId `< typeArgumentIR_subst* > `{ typeIR_subst* }

def $subst_typeIR'(theta, tableObjectTypeIR) = tableObjectTypeIR

;;; Synthesized types

def $subst_typeIR'(theta, DEFAULT) = DEFAULT

def $subst_typeIR'(theta, HEADER_INVALID) = HEADER_INVALID

def $subst_typeIR'(theta, SEQ `< typeIR* >)
  = SEQ `< typeIR_subst* >
  -- if (typeIR_subst = $subst_typeIR'(theta, typeIR))*

def $subst_typeIR'(theta, SEQ `< typeIR* `, `... >)
  = SEQ `< typeIR_subst* `, `... >
  -- if (typeIR_subst = $subst_typeIR'(theta, typeIR))*

def $subst_typeIR'(
    theta, RECORD `{ (annotationList typeIR_field id_field `;)* })
  = RECORD `{ (annotationList typeIR_field_subst id_field `;)* }
  -- if (typeIR_field_subst = $subst_typeIR'(theta, typeIR_field))*

def $subst_typeIR'(
    theta, RECORD `{ (annotationList typeIR_field id_field `;)* `, `... })
  = RECORD `{ (annotationList typeIR_field_subst id_field `;)* `, `... }
  -- if (typeIR_field_subst = $subst_typeIR'(theta, typeIR_field))*

def $subst_typeIR'(theta, SET `< typeIR >)
  = SET `< typeIR_subst >
  -- if typeIR_subst = $subst_typeIR'(theta, typeIR)

def $subst_typeIR'(theta, tableMetadataTypeIR) = tableMetadataTypeIR

;;
;;;; Parameter type substitutions
;;

def $subst_parameterIR(`{ eps }, parameterIR) = parameterIR
def $subst_parameterIR(theta, parameterIR)
  = $subst_parameterIR'(theta, parameterIR)
  -- otherwise

def $subst_parameterIR'(
  theta, annotationList direction typeIR id parameterInitializerOptIR)
  = annotationList direction typeIR_subst id parameterInitializerOptIR
  -- if typeIR_subst = $subst_typeIR'(theta, typeIR)

;;
;;;; Callable type substitutions
;;

def $subst_callableTypeIR(`{ eps }, callableTypeIR) = callableTypeIR
def $subst_callableTypeIR(theta, callableTypeIR)
  = $subst_callableTypeIR'(theta, callableTypeIR)
  -- otherwise

;;; Action types

def $subst_callableTypeIR'(theta, annotationList ACTION nameIR `( parameterIR* ))
  = annotationList ACTION nameIR `( parameterIR_subst* )
  -- if (parameterIR_subst
      = $subst_parameterIR'(theta, parameterIR))*

;;; Function types

def $subst_callableTypeIR'(theta, FUNCTION nameIR `( parameterIR* ) `: typeIR)
  = FUNCTION nameIR `( parameterIR_subst* ) `: typeIR_subst
  -- if (parameterIR_subst
      = $subst_parameterIR'(theta, parameterIR))*
  -- if typeIR_subst = $subst_typeIR'(theta, typeIR)

def $subst_callableTypeIR'(theta, EXTERN_FUNCTION nameIR `( parameterIR* ) `: typeIR)
  = EXTERN_FUNCTION nameIR `( parameterIR_subst* ) `: typeIR_subst
  -- if (parameterIR_subst
      = $subst_parameterIR'(theta, parameterIR))*
  -- if typeIR_subst = $subst_typeIR'(theta, typeIR)

;;; Method types

def $subst_callableTypeIR'(theta, BUILTIN_METHOD nameIR `( parameterIR* ) `: typeIR)
  = BUILTIN_METHOD nameIR `( parameterIR_subst* ) `: typeIR_subst
  -- if (parameterIR_subst
      = $subst_parameterIR'(theta, parameterIR))*
  -- if typeIR_subst = $subst_typeIR'(theta, typeIR)

def $subst_callableTypeIR'(theta, EXTERN_METHOD nameIR `( parameterIR* ) `: typeIR)
  = EXTERN_METHOD nameIR `( parameterIR_subst* ) `: typeIR_subst
  -- if (parameterIR_subst
      = $subst_parameterIR'(theta, parameterIR))*
  -- if typeIR_subst = $subst_typeIR'(theta, typeIR)

def $subst_callableTypeIR'(theta, EXTERN_METHOD ABSTRACT nameIR `( parameterIR* ) `: typeIR)
  = EXTERN_METHOD ABSTRACT nameIR `( parameterIR_subst* ) `: typeIR_subst
  -- if (parameterIR_subst
      = $subst_parameterIR'(theta, parameterIR))*
  -- if typeIR_subst = $subst_typeIR'(theta, typeIR)

def $subst_callableTypeIR'(theta, PARSER_APPLY `( parameterIR* ))
  = PARSER_APPLY `( parameterIR_subst* )
  -- if (parameterIR_subst
      = $subst_parameterIR'(theta, parameterIR))*

def $subst_callableTypeIR'(theta, CONTROL_APPLY `( parameterIR* ))
  = CONTROL_APPLY `( parameterIR_subst* )
  -- if (parameterIR_subst
      = $subst_parameterIR'(theta, parameterIR))*

def $subst_callableTypeIR'(theta, tableApplyMethodTypeIR)
  = tableApplyMethodTypeIR

;;
;;;; Callable type definition substitutions
;;

def $subst_callableTypeDefIR(`{ eps }, callableTypeDefIR)
  = callableTypeDefIR
def $subst_callableTypeDefIR(theta, callableTypeDefIR)
  = $subst_callableTypeDefIR'(theta, callableTypeDefIR)
  -- otherwise

;;; Action type definitions

def $subst_callableTypeDefIR'(theta, actionTypeDefIR)
  = actionTypeDefIR_subst
  -- if actionTypeDefIR_subst
      = $subst_callableTypeIR'(theta, actionTypeDefIR)

;;; Function type definitions

def $subst_callableTypeDefIR'(
    theta,
    FUNCTION nameIR `< typeParameterIR_expl* `, typeParameterIR_impl* >
      `( parameterIR* ) `: typeIR)
  = FUNCTION nameIR `< typeParameterIR_expl_fresh* `, typeParameterIR_impl_fresh* >
      `( parameterIR_subst* ) `: typeIR_subst
  -- if B
      = $free_callableTypeIR(
          FUNCTION nameIR `( parameterIR* ) `: typeIR
        )
  -- if (theta_fresh, typeParameterIR_expl_fresh*, typeParameterIR_impl_fresh*)
      = $capture_avoiding(theta, typeParameterIR_expl*, typeParameterIR_impl*, B)
  -- if (parameterIR_subst
      = $subst_parameterIR(theta_fresh, parameterIR))*
  -- if typeIR_subst = $subst_typeIR(theta_fresh, typeIR)

def $subst_callableTypeDefIR'(
    theta,
    EXTERN_FUNCTION nameIR `< typeParameterIR_expl* `, typeParameterIR_impl* >
      `( parameterIR* ) `: typeIR)
  = EXTERN_FUNCTION nameIR `< typeParameterIR_expl_fresh* `, typeParameterIR_impl_fresh* >
      `( parameterIR_subst* ) `: typeIR_subst
  -- if B
      = $free_callableTypeIR(
          EXTERN_FUNCTION nameIR `( parameterIR* ) `: typeIR)
  -- if (theta_fresh, typeParameterIR_expl_fresh*, typeParameterIR_impl_fresh*)
      = $capture_avoiding(theta, typeParameterIR_expl*, typeParameterIR_impl*, B)
  -- if (parameterIR_subst
      = $subst_parameterIR(theta_fresh, parameterIR))*
  -- if typeIR_subst = $subst_typeIR(theta_fresh, typeIR)

;;; Method type definitions

def $subst_callableTypeDefIR'(
    theta,
    EXTERN_METHOD nameIR `< typeParameterIR_expl* `, typeParameterIR_impl* >
      `( parameterIR* ) `: typeIR)
  = EXTERN_METHOD nameIR `< typeParameterIR_expl_fresh* `, typeParameterIR_impl_fresh* >
      `( parameterIR_subst* ) `: typeIR_subst
  -- if B
      = $free_callableTypeIR(
          EXTERN_METHOD nameIR `( parameterIR* ) `: typeIR)
  -- if (theta_fresh, typeParameterIR_expl_fresh*, typeParameterIR_impl_fresh*)
      = $capture_avoiding(theta, typeParameterIR_expl*, typeParameterIR_impl*, B)
  -- if (parameterIR_subst
      = $subst_parameterIR(theta_fresh, parameterIR))*
  -- if typeIR_subst = $subst_typeIR(theta_fresh, typeIR)

def $subst_callableTypeDefIR'(
    theta,
    EXTERN_METHOD ABSTRACT nameIR `< typeParameterIR_expl* `, typeParameterIR_impl* >
      `( parameterIR* ) `: typeIR)
  = EXTERN_METHOD ABSTRACT nameIR `< typeParameterIR_expl_fresh* `, typeParameterIR_impl_fresh* >
      `( parameterIR_subst* ) `: typeIR_subst
  -- if B
      = $free_callableTypeIR(
          EXTERN_METHOD ABSTRACT nameIR `( parameterIR* ) `: typeIR)
  -- if (theta_fresh, typeParameterIR_expl_fresh*, typeParameterIR_impl_fresh*)
      = $capture_avoiding(theta, typeParameterIR_expl*, typeParameterIR_impl*, B)
  -- if (parameterIR_subst
      = $subst_parameterIR(theta_fresh, parameterIR))*
  -- if typeIR_subst = $subst_typeIR(theta_fresh, typeIR)

def $subst_callableTypeDefIR'(theta, parserApplyMethodTypeDefIR)
  = parserApplyMethodTypeDefIR_subst
  -- if parserApplyMethodTypeDefIR_subst
      = $subst_callableTypeIR'(theta, parserApplyMethodTypeDefIR)

def $subst_callableTypeDefIR'(theta, controlApplyMethodTypeDefIR)
  = controlApplyMethodTypeDefIR_subst
  -- if controlApplyMethodTypeDefIR_subst
      = $subst_callableTypeIR'(theta, controlApplyMethodTypeDefIR)

;;
;;;; Constructor type substitutions
;;

def $subst_constructorTypeIR(`{ eps }, constructorTypeIR) = constructorTypeIR
def $subst_constructorTypeIR(theta, constructorTypeIR)
  = $subst_constructorTypeIR'(theta, constructorTypeIR)
  -- otherwise

def $subst_constructorTypeIR'(
    theta,
    CONSTRUCTOR `( constructorParameterIR* ) `: typeIR)
  = CONSTRUCTOR `( constructorParameterIR_subst* ) `: typeIR_subst
  -- if (constructorParameterIR_subst
      = $subst_parameterIR'(theta, constructorParameterIR))*
  -- if typeIR_subst = $subst_typeIR'(theta, typeIR)
