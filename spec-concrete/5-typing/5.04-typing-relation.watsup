relation VarDecl_ok:
  cursor typingContext |- variableDeclaration
                        : typingContext variableDeclarationIR
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %1 "at" %0)
  hint(prose_out "context" %3 "and" %4)

relation ConstDecl_ok:
  cursor typingContext |- constantDeclaration
                        : typingContext constantDeclarationIR
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %1 "at" %0)
  hint(prose_out "context" %3 "and" %4)

relation InstDecl_ok:
  cursor typingContext |- instantiation
                        : typingContext instantiationIR
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %1 "at" %0)
  hint(prose_out "context" %3 "and" %4)

relation FuncDecl_ok:
  cursor typingContext |- functionDeclaration
                        : typingContext functionDeclarationIR
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %1 "at" %0)
  hint(prose_out "context" %3 "and" %4)

relation ActionDecl_ok:
  cursor typingContext |- actionDeclaration
                        : typingContext actionDeclarationIR
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %1 "at" %0)
  hint(prose_out "context" %3 "and" %4)

relation Decl_ok:
  typingContext |- declaration : typingContext declarationIR
  hint(input %0 %1)
  hint(prose_in "typing" %1 "under context" %0)
  hint(prose_out "context" %2 "and" %3)

relation Decls_ok:
  typingContext |- declaration* : typingContext declarationIR*
  hint(input %0 %1)
  hint(prose_in "typing" %1 "under context" %0)
  hint(prose_out "context" %2 "and" %3)

relation Program_ok:
  |- p4program : p4programIR
  hint(input %0)
  hint(prose_in "typing" %0)
  hint(prose_out "typed P4 program" %1)

;;
;;;; Call/instantiation convention
;;

;; Checks the copy-in/out calling convention,
;; and inserts implicit casts for arguments, if necessary
;; note that it depends on whether an action is being called or not

syntax actctxt = ACTION | NOACTION

relation Call_convention_expr_ok:
  cursor typingContext actctxt |- parameterIR `@ typedExpressionIR
                                : typedExpressionIR
  hint(input %0 %1 %2 %3 %4)
  hint(prose_in "checking calling convention of" %4 "applied to" %3
             #", under context" %1 "and action context" %2 "at" %0)

relation Call_convention_argument_ok:
  cursor typingContext actctxt |- parameterIR `@ argumentIR
                                : argumentIR
  hint(input %0 %1 %2 %3 %4)
  hint(prose_in "checking calling convention of" %4 "applied to parameter type" %3
             #", under context" %1 "and action context" %2 "at" %0)

relation Call_convention_ok:
  cursor typingContext actctxt |- parameterIR* `@ argumentListIR
                                : argumentListIR
  hint(input %0 %1 %2 %3 %4)
  hint(prose_in "checking calling convention of" %4 "applied on" %3#
                ", under context" %1 "and action context" %2 "at" %0)
  hint(prose_out "casted" %5)

;;
;;;; Callable typing
;;

;; Finds the type of a callable target,
;; inserts fresh type variables for parameters with don't care types, (typeId*)
;; and also identifies the ids of default/optional arguments (id*)

dec $is_static_callableTypeIR(callableTypeIR) : ctk
  hint(prose_in "compile-time known-ness of" %0)
def $is_static_callableTypeIR(EXTERN_FUNCTION "static_assert" `( _ ) `: _)
  = LCTK
def $is_static_callableTypeIR(BUILTIN_METHOD nameIR `( _ ) `: _) = LCTK
  -- if nameIR <- [ "minSizeInBits", "minSizeInBytes",
                    "maxSizeInBits", "maxSizeInBytes" ]
def $is_static_callableTypeIR(_) = DYN
  -- otherwise

dec $is_static_assert_callableTypeIR(callableTypeIR) : bool
  hint(prose_true %0 "is a static_assert call")
  hint(prose_false %0 "is not a static_assert call")
def $is_static_assert_callableTypeIR(EXTERN_FUNCTION "static_assert" `( _ ) `: _)
  = true
def $is_static_assert_callableTypeIR(_) = false
  -- otherwise

relation CallableTarget_ok:
  cursor typingContext |- callableTarget : callableTargetIR
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2 "as a callable target, under cursor" %0 "and context" %1)
  hint(prose_out "typed callable target" %3)

relation CallableTarget_lvalue_ok:
  cursor typingContext |- lvalue : callableTargetIR
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2 "as a callable target, under cursor" %0 "and context" %1)
  hint(prose_out "typed callable target" %3)

relation CallableType_ok:
  cursor typingContext |- callableTargetIR `< typeArgumentListIR > `( argumentIR* )
                        : callableTypeIR `< `# typeId* > `( `# id* `# id* )
  hint(input %0 %1 %2 %3 %4)
  hint(prose_in "finding type of callable call" %2 `< %3 > `( %4 )#
                ", under cursor" %0 "and context" %1)
  hint(prose_out "callable type" %5 "with fresh type variables" %6#
                 ", defaults" %7 "and optionals" %8)

;; Checks that an action/function/method invocation is valid,
;; gets the return type,
;; infers the types of missing type arguments,
;; and inserts implicit casts for arguments, if necessary

relation Call_ok:
  cursor typingContext |- callableTypeIR `< typeArgumentListIR `# typeId* >
                            `( argumentListIR `# id* `# id* )
                        : typeIR `< typeArgumentListIR > `( argumentListIR )
  hint(input %0 %1 %2 %3 %4 %5 %6 %7)
  hint(prose_in "typing invocation" %2 `< %3 > `( %5 ) "with omitted type arguments"
                %4#", defaults" %6 "and optionals" %7#
                ", under cursor" %0 "and context" %1)
  hint(prose_out "return type" %8 "with inferred" %9 "and casted" %10)

;;
;;;; Constructor typing
;;

;; Finds the type of a constructor,
;; inserts fresh type variables for parameters with don't care types, (typeId*)
;; and also identifies the ids of default/optional arguments (id*)

relation ConstructorType_ok:
  cursor typingContext |- constructorTargetIR `( argumentIR* )
                        : constructorTypeIR `< `# typeId* > `( `# id* `# id* )
  hint(input %0 %1 %2 %3)
  hint(prose_in "finding type of constructor call"
                %2 `( %3 ) #", under cursor" %0 "and context" %1)
  hint(prose_out %4 "with fresh type variables" %5#
                 ", defaults" %6 "and optionals" %7)

;; Checks that a constructor invocation is valid,
;; gets the return type,
;; infers the types of missing type arguments,
;; and inserts implicit casts for arguments, if necessary

syntax instctxt = NAMED | ANON

relation Inst_ok:
  cursor typingContext instctxt
  |- constructorTypeIR `< typeArgumentListIR `# typeId* >
      `( argumentListIR `# id* `# id* )
  : typeIR `< typeArgumentListIR > `( argumentListIR )
  hint(input %0 %1 %2 %3 %4 %5 %6 %7 %8)
  hint(prose_in "typing instantiation" %3 `< %4 > `( %6 ) "with omitted type arguments"
             %5#", defaults" %7 "and optionals" %8
             ", under cursor" %0#", context" %1
             #", and" %2 "instantiation site context")
  hint(prose_out "constructed type" %9 "with inferred" %10 "and casted" %11)
