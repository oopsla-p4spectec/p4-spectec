;;
;;;; Static evaluation
;;;; of expressions/arguments that are local compile-time known
;;

extern relation ExternFunctionCall_eval_lctk:
  typingContext |- nameIR `( nameIR* ) ~> value
  hint(input %0 %1 %2)
  hint(testgen_ignore)
  hint(prose_in "calling an extern function" %1#"("#%2#")" "under context" %0)
  hint(prose_out %3)

relation Expr_eval_lctk:
  cursor typingContext |- typedExpressionIR ~> value
  hint(input %0 %1 %2)
  hint(testgen_ignore)
  hint(prose_in "local compile-time evaluation of" %2#", under context" %1 "at" %0)
  hint(prose_out %3)

relation Argument_eval_lctk:
  cursor typingContext |- argumentIR ~> value
  hint(input %0 %1 %2)
  hint(testgen_ignore)
  hint(prose_in "local compile-time evaluation of" %2#", under context" %1 "at" %0)
  hint(prose_out %3)

;;
;;;; Type evaluation
;;;; Inserts fresh type variables (`# typeId*) for don't care type arguments (`_)
;;

relation Type_ok:
  cursor typingContext |- typeOrVoid : typeIR `# typeId*
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %1 "at" %0)
  hint(prose_out %3 "and fresh type variables" %4)

relation TypeParameterListOpt_ok:
  cursor typingContext |- typeParameterListOpt : typingContext typeId*
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %1 "at" %0)
  hint(prose_out "context" %3 "and type parameters" %4)

relation TypeArgument_ok:
  cursor typingContext |- typeArgument : typeArgumentIR `# typeId*
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %1 "at" %0)
  hint(prose_out %3 "and fresh type variables" %4)

relation TypeArguments_ok:
  cursor typingContext |- typeArgument* : typeArgumentListIR `# typeId*
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %1 "at" %0)
  hint(prose_out %3 "and fresh type variables" %4)

relation TypeArgumentList_ok:
  cursor typingContext |- typeArgumentList : typeArgumentListIR `# typeId*
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %1 "at" %0)
  hint(prose_out %3 "and fresh type variables" %4)

;;
;;;; Casting, explicit and implicit
;;

relation Cast_expl: typeIR -> typeIR
  hint(input %0 %1)
  hint(prose_true %0 "can be explicitly cast to" %1)
  hint(prose_false %0 "cannot be explicitly cast to" %1)
relation Cast_expl_neq: typeIR -> typeIR
  hint(input %0 %1)
  hint(prose_true %0 "can be explicitly cast to" %1 "(when unequal)")
  hint(prose_false %0 "cannot be explicitly cast to" %1 "(when unequal)")

relation Cast_impl: typeIR -> typeIR
  hint(input %0 %1)
  hint(prose_true %0 "can be implicitly cast to" %1)
  hint(prose_false %0 "cannot be implicitly cast to" %1)
relation Cast_impl_neq: typeIR -> typeIR
  hint(input %0 %1)
  hint(prose_true %0 "can be implicitly cast to" %1 "(when unequal)")
  hint(prose_false %0 "cannot be implicitly cast to" %1 "(when unequal)")

;;
;;;; Expression typing
;;

relation Expr_ok:
  cursor typingContext |- expression : typedExpressionIR
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %1 "at" %0)
  hint(prose_out %3)

;;
;;;; Argument typing
;;

relation Argument_ok:
  cursor typingContext |- argument : argumentIR
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %1 "at" %0)
  hint(prose_out %3)

relation ArgumentList_ok:
  cursor typingContext |- argumentList : argumentListIR
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %1 "at" %0)
  hint(prose_out %3)

;;
;;;; L-value typing
;;

relation Lvalue_ok:
  cursor typingContext |- lvalue : typedLvalueIR
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %1 "at" %0)
  hint(prose_out %3)

;;
;;;; Statement typing
;;

syntax loopctxt = LOOP | NOLOOP

var l : loopctxt

relation Stmt_ok:
  cursor typingContext flow loopctxt |- statement
                                      : typingContext flow statementIR
  hint(input %0 %1 %2 %3 %4)
  hint(prose_in
        "typing" %4#", under context"%1#", abstract control flow" %2#", and loop context" %3
        "at" %0)
  hint(prose_out
        "context" %5#", abstract control flow" %6#", and" %7)

relation BlockElementStmt_ok:
  typingContext flow loopctxt |- blockElementStatement
                               : typingContext flow blockElementStatementIR
  hint(input %0 %1 %2 %3)
  hint(prose_in
        "typing" %3#", under context"
        %0#", abstract control flow" %1#", and loop context" %2)
  hint(prose_out
        "context" %4#", abstract control flow" %5#
        ", and" %6)

relation BlockElementStmtList_ok:
  typingContext flow loopctxt |- blockElementStatementList
                               : typingContext flow blockElementStatementIR*
  hint(input %0 %1 %2 %3)
  hint(prose_in
        "typing" %3#", under context"
        %0#", abstract control flow" %1#", and loop context" %2)
  hint(prose_out
        "context" %4#", abstract control flow" %5#", and" %6)

relation Block_ok:
  typingContext flow loopctxt |- blockStatement
                               : typingContext flow blockStatementIR
  hint(input %0 %1 %2 %3)
  hint(prose_in
        "typing" %3#", under context"
        %0#", abstract control flow" %1#", and loop context" %2)
  hint(prose_out
        "context" %4#", abstract control flow"
        %5#", and" %6)

;;
;;;; Parameter typing
;;;; inserts fresh type variables for parameters with don't care types
;;

relation Parameter_ok:
  cursor typingContext |- parameter
                        : typingContext parameterIR `# typeId*
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %1 "at" %0)
  hint(prose_out "context" %3#"," %4#", and fresh type variables" %5)

relation ParameterList_ok:
  cursor typingContext |- parameterList
                        : typingContext parameterListIR `# typeId*
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %1 "at" %0)
  hint(prose_out "context" %3#"," %4#", and fresh type variables" %5)

relation ConstructorParameterListOpt_ok:
  typingContext |- constructorParameterListOpt
                 : typingContext constructorParameterListIR `# typeId*
  hint(input %0 %1)
  hint(prose_in "typing" %1 "under context" %0)
  hint(prose_out "context" %2#"," %3#", and fresh type variables" %4)

;;
;;;; Extern method/constructor typing
;;

dec $callableId_of_externMethodPrototype(
    externMethodPrototype)
  : callableId
  hint(prose_in "callable id of " %0)

def $callableId_of_externMethodPrototype(
    _ (_ name _ `( parameterList )) `;)
  = $callableId(name, parameterList)
def $callableId_of_externMethodPrototype(
    _ ABSTRACT (_ name _ `( parameterList )) `;)
  = $callableId(name, parameterList)

dec $type_of_externMethodPrototypeIR(externMethodPrototypeIR)
  : externMethodTypeDefIR
  hint(prose_in "callable type definition of " %0)

def $type_of_externMethodPrototypeIR(
    _ (typeIR_ret nameIR
      `< typeParameterListIR_expl `, typeParameterListIR_impl >
      `( parameterIR* )) `;)
  = externMethodTypeDefIR
  -- if externMethodTypeDefIR
      = EXTERN_METHOD nameIR
          `< typeParameterListIR_expl `, typeParameterListIR_impl >
          `( parameterIR* ) `: typeIR_ret
def $type_of_externMethodPrototypeIR(
    _ ABSTRACT (typeIR_ret nameIR
      `< typeParameterListIR_expl `, typeParameterListIR_impl >
      `( parameterIR* )) `;)
  = externMethodTypeDefIR
  -- if externMethodTypeDefIR
      = EXTERN_METHOD ABSTRACT nameIR
          `< typeParameterListIR_expl `, typeParameterListIR_impl >
          `( parameterIR* ) `: typeIR_ret

dec $constructorId_of_externConstructorPrototype(
    externConstructorPrototype)
  : constructorId
  hint(prose_in "constructor id of " %0)

def $constructorId_of_externConstructorPrototype(
    _ typeIdentifier `( parameterList ) `;)
  = $callableId(typeIdentifier, parameterList)

relation ExternMethod_ok:
  typingContext typeId |- externMethodPrototype
                        : externMethodPrototypeIR
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %0 "for an extern object" %1)
  hint(prose_out %3)

relation ExternConstructor_ok:
  typingContext typeId |- externConstructorPrototype
                        : externConstructorPrototypeIR
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %0 "for an extern object" %1)
  hint(prose_out %3)

