  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %0 "and table context" %1)
  hint(prose_out "table context" %3 "and" %4)

relation Call_action_default_ok:
  typingContext |- parameterIR* `@ argumentListIR
                 : parameterIR* `, parameterIR* `@ argumentListIR
  hint(input %0 %1 %2)
  hint(prose_in "typing action call on" %1 "with" %2#", under context" %0)
  hint(prose_out "parameters" %3 "for data-plane," %4 "for control-plane,"#
                 "and casted" %5)

relation TableDefaultAction_ok:
  typingContext tableContext |- initializer : tableActionReferenceIR
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %0 "and table context" %1)
