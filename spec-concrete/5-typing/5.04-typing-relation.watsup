relation ParserSelect_ok:
  typingContext nameIR* |- selectExpression : selectExpressionIR
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %0 "and parser state names" %1)
  hint(prose_out "typed transition statement" %3)

relation ParserTransition_ok:
  typingContext nameIR* |- transitionStatement : transitionStatementIR
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %0 "and parser state names" %1)
  hint(prose_out "typed transition statement" %3)

relation ParserStmt_ok:
  typingContext |- parserStatement : typingContext parserStatementIR
  hint(input %0 %1)
  hint(prose_in "typing" %1#", under context" %0)
  hint(prose_out "context" %2 "and typed parser statement" %3)

relation ParserStmtList_ok:
  typingContext |- parserStatementList : typingContext parserStatementIR*
  hint(input %0 %1)
  hint(prose_in "typing" %1#", under context" %0)
  hint(prose_out "context" %2 "and typed parser statements" %3)

relation ParserState_ok:
  typingContext nameIR* |- parserState : parserStateIR
  hint(input %0 %1 %2)
  hint(prose_in "typing" %2#", under context" %0 "and parser state names" %1)
  hint(prose_out %3)

relation ParserStateList_ok:
  typingContext |- parserStateList : parserStateIR*
  hint(input %0 %1)
  hint(prose_in "typing" %1#", under context" %0)
  hint(prose_out %2)

relation ParserLocalDecl_ok:
  typingContext |- parserLocalDeclaration
                 : typingContext parserLocalDeclarationIR
  hint(input %0 %1)
  hint(prose_in "typing" %1#", under context" %0)
  hint(prose_out "context" %2 "and" %3)

relation ParserLocalDeclList_ok:
  typingContext |- parserLocalDeclarationList
                 : typingContext parserLocalDeclarationIR*
  hint(input %0 %1)
  hint(prose_in "typing" %1#", under context" %0)
  hint(prose_out "context" %2 "and" %3)

