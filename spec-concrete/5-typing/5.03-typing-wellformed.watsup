;;
;; Relations for well-formedness
;;

relation Type_wf:
  bound |- typeIR
  hint(input %0 %1)
  hint(prose_true %1 "is a well-formed type, with bound type variables" %0)
  hint(prose_false %1 "is not a well-formed type, with bound type variables" %0)

relation TypeDef_wf:
  bound |- typeDefIR
  hint(input %0 %1)
  hint(prose_true %1 "is a well-formed type definition, with bound type variables" %0)
  hint(prose_false %1 "is not a well-formed type definition, with bound type variables" %0)

relation ParameterType_wf:
  bound |- parameterIR
  hint(input %0 %1)
  hint(prose_true %1 "is a well-formed parameter, with bound type variables" %0)
  hint(prose_false %1 "is not a well-formed parameter, with bound type variables" %0)

relation ReturnType_wf:
  bound |- typeIR
  hint(input %0 %1)
  hint(prose_true %1 "is a well-formed return type, with bound type variables" %0)
  hint(prose_false %1 "is not a well-formed return type, with bound type variables" %0)

relation CallableType_wf:
  bound |- callableTypeIR
  hint(input %0 %1)
  hint(prose_true %1 "is a well-formed callable type, with bound type variables" %0)
  hint(prose_false %1 "is not a well-formed callable type, with bound type variables" %0)

relation CallableTypeDef_wf:
  bound |- callableTypeDefIR
  hint(input %0 %1)
  hint(prose_true %1 "is a well-formed callable type definition, with bound type variables" %0)
  hint(prose_false %1 "is not a well-formed callable type definition, with bound type variables" %0)

relation ConstructorParameterType_wf:
  bound |- parameterIR
  hint(input %0 %1)
  hint(prose_true %1 "is a well-formed constructor parameter, with bound type variables" %0)
  hint(prose_false %1 "is not a well-formed constructor parameter, with bound type variables" %0)

relation ConstructorType_wf:
  bound |- constructorTypeIR
  hint(input %0 %1)
  hint(prose_true %1 "is a well-formed constructor type, with bound type variables" %0)
  hint(prose_false %1 "is not a well-formed constructor type, with bound type variables" %0)

relation ConstructorTypeDef_wf:
  bound |- constructorTypeDefIR
  hint(input %0 %1)
  hint(prose_true %1 "is a well-formed constructor type definition, with bound type variables" %0)
  hint(prose_false %1 "is not a well-formed constructor type definition, with bound type variables" %0)

;;
;;;; Well-formedness of types
;;

;;; Base types

rule Type_wf/baseTypeIR:
  B |- baseTypeIR

;;; Name types

rule Type_wf/nameTypeIR:
  B |- `` typeId
  -- if $in_set<typeId>(typeId, B)

;;; Alias types

tbl dec $nestable_typedef(typeIR) : bool
  hint(prose_true %0 "can be used in a typedef")
  hint(prose_false %0 "cannot be used in a typedef")

tbl def $nestable_typedef =
  | BOOL => true
  | ERROR => true
  | STRING => true
  | integerTypeIR => true
  | nameTypeIR => true
  | TYPEDEF _ typeIR => $nestable_typedef(typeIR)
  | newTypeIR => true
  | dataTypeIR => true
  | externObjectTypeIR => true
  | parserObjectTypeIR => true
  | controlObjectTypeIR => true
  | packageObjectTypeIR => true
  | _ => false

rule Type_wf/typedefTypeIR:
  B |- TYPEDEF _ typeIR
  -- if $nestable_typedef(typeIR)
  -- Type_wf: B |- typeIR

tbl dec $nestable_new(typeIR) : bool
  hint(prose_true %0 "can be used in a new type")
  hint(prose_false %0 "cannot be used in a new type")

tbl def $nestable_new =
  | BOOL => true
  | BIT `< _ > => true
  | INT `< _ > => true
  | nameTypeIR => true
  | TYPEDEF _ typeIR => $nestable_new(typeIR)
  | newTypeIR => true
  | _ => false

rule Type_wf/newTypeIR:
  B |- TYPE _ typeIR
  -- if $nestable_new(typeIR)
  -- Type_wf: B |- typeIR 

;;; Data types

tbl dec $nestable_list(typeIR) : bool
  hint(prose_true %0 "can be nested in a list type")
  hint(prose_false %0 "cannot be nested in a list type")

tbl def $nestable_list =
  | BOOL => true
  | ERROR => true
  | MATCH_KIND => true
  | STRING => true
  | integerTypeIR => true
  | nameTypeIR => true
  | TYPEDEF _ typeIR => $nestable_list(typeIR)
  | newTypeIR => true
  | dataTypeIR => true
  | _ => false

rule Type_wf/listTypeIR:
  B |- LIST `< typeIR >
  -- if $nestable_list(typeIR)
  -- Type_wf: B |- typeIR

tbl dec $nestable_tuple(typeIR) : bool
  hint(prose_true %0 "can be nested in a tuple type")
  hint(prose_false %0 "cannot be nested in a tuple type")

tbl def $nestable_tuple =
  | BOOL => true
  | ERROR => true
  | BIT `< _ > => true
  | INT `< _ > => true
  | VARBIT `< _ > => true
  | nameTypeIR => true
  | TYPEDEF _ typeIR => $nestable_tuple(typeIR)
  | newTypeIR => true
  | tupleTypeIR => true
  | headerStackTypeIR => true
  | structTypeIR => true
  | headerTypeIR => true
  | headerUnionTypeIR => true
  | enumTypeIR => true
  | _ => false

rule Type_wf/tupleTypeIR:
  B |- TUPLE `< typeIR* >
  -- if $nestable_tuple(typeIR)*
  -- (Type_wf: B |- typeIR)*

tbl dec $nestable_headerStack(typeIR) : bool
  hint(prose_true %0 "can be nested in a header stack type")
  hint(prose_false %0 "cannot be nested in a header stack type")

tbl def $nestable_headerStack =
  | nameTypeIR => true
  | TYPEDEF _ typeIR => $nestable_headerStack(typeIR)
  | headerTypeIR => true
  | headerUnionTypeIR => true
  | _ => false

rule Type_wf/headerStackTypeIR:
  B |- typeIR `[ _ ]
  -- if $nestable_headerStack(typeIR)
  -- Type_wf: B |- typeIR

dec $nestable_struct(typeIR) : bool
  hint(prose_true %0 "can be nested in a struct type")
  hint(prose_false %0 "cannot be nested in a struct type")

def $nestable_struct(typeIR) = $nestable_tuple(typeIR)

rule Type_wf/structTypeIR:
  B |- STRUCT _ `< _ > `{ (_ typeIR_field nameIR_field `;)* }
  -- if $distinct_<nameIR>(nameIR_field*)
  -- if $nestable_struct(typeIR_field)*
  -- (Type_wf: B |- typeIR_field)*

tbl dec $nestable_header(typeIR) : bool
  hint(prose_true %0 "can be used in a header type")
  hint(prose_false %0 "cannot be used in a header type")
tbl dec $nestable_struct_in_header(typeIR) : bool
  hint(prose_true %0 "can be used in a struct nested in a header type")
  hint(prose_false %0 "cannot be used in a struct nested in a header type")

tbl def $nestable_header =
  | BOOL => true
  | INT `< _ > => true
  | BIT `< _ > => true
  | VARBIT `< _ > => true
  | nameTypeIR => true
  | TYPEDEF _ typeIR => $nestable_header(typeIR)
  | newTypeIR => true
  | ENUM _ `< _ > `{ _ } => true
  | STRUCT _ `< _ > `{ (_ typeIR_field _ `;)* } =>
      $forall_($nestable_struct_in_header(typeIR_field)*)
  | _ => false

tbl def $nestable_struct_in_header =
  | BOOL => true
  | INT `< _ > => true
  | BIT `< _ > => true
  | nameTypeIR => true
  | TYPEDEF _ typeIR => $nestable_struct_in_header(typeIR)
  | newTypeIR => true
  | ENUM _ `< _ > `{ _ } => true
  | STRUCT _ `< _ > `{ (_ typeIR_field _ `;)* } =>
      $forall_($nestable_struct_in_header(typeIR_field)*)
  | _ => false

rule Type_wf/headerTypeIR:
  B |- HEADER _ `< _ > `{ (_ typeIR_field nameIR_field `;)* }
  -- if $distinct_<nameIR>(nameIR_field*)
  -- if $nestable_header(typeIR_field)*
  -- (Type_wf: B |- typeIR_field)*

tbl dec $nestable_headerUnion(typeIR) : bool
  hint(prose_true %0 "can be used in a header union type")
  hint(prose_false %0 "cannot be used in a header union type")

tbl def $nestable_headerUnion =
  | nameTypeIR => true
  | TYPEDEF _ typeIR => $nestable_headerUnion(typeIR)
  | newTypeIR => true
  | headerTypeIR => true
  | _ => false

rule Type_wf/headerUnionTypeIR:
  B |- HEADER_UNION _ `< _ > `{ (_ typeIR_field nameIR_field `;)* }
  -- if $distinct_<nameIR>(nameIR_field*)
  -- if $nestable_headerUnion(typeIR_field)*
  -- (Type_wf: B |- typeIR_field)*

tbl dec $nestable_enum_serializable(typeIR) : bool
  hint(prose_true %0 "can be used in a serializable enum type")
  hint(prose_false %0 "cannot be used in a serializable enum type")
tbl dec $nestable_new_in_enum_serializable(typeIR) : bool
  hint(prose_true %0 "can be used in a new type nested in a serializable enum type")
  hint(prose_false %0 "cannot be used in a new type nested in a serializable enum type")

tbl def $nestable_enum_serializable =
  | INT `< _ > => true
  | BIT `< _ > => true
  | nameTypeIR => true
  | TYPEDEF _ typeIR => $nestable_enum_serializable(typeIR)
  | TYPE _ typeIR => $nestable_new_in_enum_serializable(typeIR)
  | _ => false

tbl def $nestable_new_in_enum_serializable =
  | INT `< _ > => true
  | BIT `< _ > => true
  | nameTypeIR => true
  | TYPEDEF _ typeIR => $nestable_new_in_enum_serializable(typeIR)
  | newTypeIR => true
  | _ => false

rulegroup Type_wf/enumTypeIR {

  rule Type_wf/non-serializable:
    B |- ENUM _ `{ nameIR_field* }
    -- if $distinct_<nameIR>(nameIR_field*)

  rule Type_wf/serializable:
    B |- ENUM _ `< typeIR > `{ (nameIR_field `= _ `;)* }
    -- if $distinct_<nameIR>(nameIR_field*)
    -- if $nestable_enum_serializable(typeIR)
    -- Type_wf: B |- typeIR

}

;;; Object types

rule Type_wf/externObjectTypeIR:
  B |- EXTERN _ `< _ > (`{ (_ `: externMethodTypeDefIR)* })
  -- (CallableTypeDef_wf: B |- externMethodTypeDefIR)*

rule Type_wf/parserObjectTypeIR:
  B |- PARSER _ `< _ > `( parameterIR* )
  -- (ParameterType_wf: B |- parameterIR)*

rule Type_wf/controlObjectTypeIR:
  B |- CONTROL _ `< _ > `( parameterIR* )
  -- (ParameterType_wf: B |- parameterIR)*

rule Type_wf/packageObjectTypeIR:
  B |- PACKAGE _ `< _ > `{ typeIR* }
  -- (Type_wf: B |- typeIR)*

rule Type_wf/tableObjectTypeIR:
  B |- TABLE _ `{ tableMetadataStructTypeIR }
  -- Type_wf: B |- tableMetadataStructTypeIR

;;; Synthesized types

rule Type_wf/defaultTypeIR:
  B |- DEFAULT

rule Type_wf/invalidHeaderTypeIR:
  B |- HEADER_INVALID

rulegroup Type_wf/sequenceTypeIR {

  rule Type_wf/non-default:
    B |- SEQ `< typeIR* >
    -- (Type_wf: B |- typeIR)*

  rule Type_wf/default:
    B |- SEQ `< typeIR* `, `... >
    -- (Type_wf: B |- typeIR)*

}

rulegroup Type_wf/recordTypeIR {

  rule Type_wf/non-default:
    B |- RECORD `{ (_ typeIR_field nameIR_field `;)* }
    -- if $distinct_<nameIR>(nameIR_field*)
    -- (Type_wf: B |- typeIR_field)*

  rule Type_wf/default:
    B |- RECORD `{ (_ typeIR_field nameIR_field `;)* `, `... }
    -- if $distinct_<nameIR>(nameIR_field*)
    -- (Type_wf: B |- typeIR_field)*

}

tbl dec $nestable_set(typeIR) : bool
  hint(prose_true %0 "can be used in a set type")
  hint(prose_false %0 "cannot be used in a set type")
tbl dec $nestable_tuple_in_set(typeIR) : bool
  hint(prose_true %0 "can be used in a tuple nested in a set type")
  hint(prose_false %0 "cannot be used in a tuple nested in a set type")
tbl dec $nestable_sequence_in_set(typeIR) : bool
  hint(prose_true %0 "can be used in a sequence nested in a set type")
  hint(prose_false %0 "cannot be used in a sequence nested in a set type")

tbl def $nestable_set =
  | BOOL => true
  | ERROR => true
  | INT `< _ > => true
  | BIT `< _ > => true
  | nameTypeIR => true
  | TYPEDEF _ typeIR => $nestable_set(typeIR)
  | newTypeIR => true
  | TUPLE `< typeIR* > => $forall_($nestable_tuple_in_set(typeIR)*)
  | enumTypeIR => true
  | SEQ `< typeIR* > => $forall_($nestable_sequence_in_set(typeIR)*)
  | _ => false

tbl def $nestable_tuple_in_set =
  | BOOL => true
  | INT `< _ > => true
  | BIT `< _ > => true
  | nameTypeIR => true
  | TYPEDEF _ typeIR => $nestable_tuple_in_set(typeIR)
  | newTypeIR => true
  | TUPLE `< typeIR* > => $forall_($nestable_tuple_in_set(typeIR)*)
  | enumTypeIR => true
  | _ => false

tbl def $nestable_sequence_in_set =
  | BOOL => true
  | INT `< _ > => true
  | BIT `< _ > => true
  | nameTypeIR => true
  | TYPEDEF _ typeIR => $nestable_sequence_in_set(typeIR)
  | newTypeIR => true
  | TUPLE `< typeIR* > => $forall_($nestable_sequence_in_set(typeIR)*)
  | enumTypeIR => true
  | SEQ `< typeIR* > => $forall_($nestable_sequence_in_set(typeIR)*)
  | _ => false

rule Type_wf/setTypeIR:
  B |- SET `< typeIR >
  -- if $nestable_set(typeIR)
  -- Type_wf: B |- typeIR

rulegroup Type_wf/tableMetadataTypeIR {

  rule Type_wf/enum:
    B |- TABLE_ENUM _ `{ nameIR* }
    -- if $distinct_<nameIR>(nameIR*)

  rule Type_wf/struct:
    B |- TABLE_STRUCT _ `{ HIT _ `;
                               MISS _ `;
                               ACTION_RUN tableMetadataEnumTypeIR `; }
    -- Type_wf: B |- tableMetadataEnumTypeIR
  
}

;;
;;;; Well-formedness of type definitions
;;

rule TypeDef_wf:
  B |- typeDefIR
  -- if (typeParameterIR_expl*, typeParameterIR_impl*)
      = $typeParameterListIR_of_typeDefIR(typeDefIR)
  -- if typeParameterIR*
      = typeParameterIR_expl* ++ typeParameterIR_impl*
  -- if $distinct_<typeId>(typeParameterIR*)
  -- if typeIR_base = $typeIR_of_typeDefIR(typeDefIR)
  -- if B_inner
      = $union_set<typeId>(B, `{ typeParameterIR* })
  -- Type_wf: B_inner |- typeIR_base

;;
;;;; Well-formedness of parameter types
;;

rulegroup ParameterType_wf {

  rule ParameterType_wf/non-default:
    B |- _ direction typeIR _ eps
    -- Type_wf: B |- typeIR
    -- if typeIR_unroll = $unroll_typeIR(typeIR)
    -- if ~(typeIR_unroll <: synthesizedTypeIR)
    -- if ((typeIR_unroll = INT)
          \/ (typeIR_unroll <: stringTypeIR)
          \/ (typeIR_unroll <: objectTypeIR))
          => direction = `EMPTY

  rule ParameterType_wf/default:
    B |- annotationList direction typeIR _ parameterInitializerIR
    -- Type_wf: B |- typeIR
    -- if typeIR_unroll = $unroll_typeIR(typeIR)
    -- if ~(typeIR_unroll <: synthesizedTypeIR)
    -- if ((typeIR_unroll = INT)
          \/ (typeIR_unroll <: stringTypeIR)
          \/ (typeIR_unroll <: objectTypeIR))
          => direction = `EMPTY
    -- if direction = IN \/ direction = `EMPTY
    -- if ~$optional_annotation_of_parameterIR'(annotationList)

}

;;
;;;; Well-formedness of return types
;;

rule ReturnType_wf:
  B |- typeIR_ret
  -- Type_wf: B |- typeIR_ret
  -- if typeIR_unroll = $unroll_typeIR(typeIR_ret)
  -- if ~(typeIR_unroll = INT)
        /\ ~(typeIR_unroll <: synthesizedTypeIR)
        /\ ~(typeIR_unroll <: objectTypeIR)

;;
;;;; Well-formedness of callable types
;;

;;; Action types

dec $directionless_trailing(direction*) : bool
  hint(prose_true "directionless parameters in" %0 "only appear at the end")
  hint(prose_false "directionless parameters in" %0 "do not only appear at the end")
dec $directionless_trailing'(bool, direction*) : bool

def $directionless_trailing(direction*)
  = $directionless_trailing'(true, $rev_<direction>(direction*))

def $directionless_trailing'(_, eps) = true
def $directionless_trailing'(true, `EMPTY :: direction_t*)
  = $directionless_trailing'(true, direction_t*)
def $directionless_trailing'(false, `EMPTY :: direction_t*) = false
def $directionless_trailing'(_, direction_h :: direction_t*)
  = $directionless_trailing'(false, direction_t*)
  -- if direction_h =/= `EMPTY

tbl dec $nestable_action(typeIR) : bool
  hint(prose_true %0 "can be used in an action type")
  hint(prose_false %0 "cannot be used in an action type")

tbl def $nestable_action =
  | INT => false
  | TYPEDEF _ typeIR => $nestable_action(typeIR)
  | objectTypeIR => false
  | synthesizedTypeIR => false
  | _ => true

rule CallableType_wf/actionTypeIR:
  B |- _ ACTION _ `( parameterIR* )
  -- (ParameterType_wf: B |- parameterIR)*
  -- if (~$is_optional_parameterIR(parameterIR))*
  -- if (_ direction typeIR _ _ = parameterIR)*
  -- if $directionless_trailing(direction*)
  -- if $nestable_action(typeIR)*

;;; Function types

tbl dec $nestable_definedFunction(typeIR) : bool
  hint(prose_true %0 "can be used in a defined function type")
  hint(prose_false %0 "cannot be used in a defined function type")

tbl def $nestable_definedFunction =
  | TYPEDEF _ typeIR => $nestable_definedFunction(typeIR)
  | objectTypeIR => false
  | synthesizedTypeIR => false
  | _ => true

rule CallableType_wf/definedFunctionTypeIR:
  B |- FUNCTION _ `( parameterIR* ) `: typeIR_ret
  -- (ParameterType_wf: B |- parameterIR)*
  -- if (~$is_optional_parameterIR(parameterIR))*
  -- if (_ _ typeIR _ _ = parameterIR)* 
  -- if $nestable_definedFunction(typeIR)*
  -- ReturnType_wf: B |- typeIR_ret

tbl dec $nestable_externFunction(typeIR) : bool
  hint(prose_true %0 "can be used in an extern function type")
  hint(prose_false %0 "cannot be used in an extern function type")

tbl def $nestable_externFunction =
  | TYPEDEF _ typeIR => $nestable_externFunction(typeIR)
  | parserObjectTypeIR => false
  | controlObjectTypeIR => false
  | packageObjectTypeIR => false
  | tableObjectTypeIR => false
  | _ => true

rule CallableType_wf/externFunctionTypeIR:
  B |- EXTERN_FUNCTION _ `( parameterIR* ) `: typeIR_ret
  -- (ParameterType_wf: B |- parameterIR)*
  -- if (_ _ typeIR _ _ = parameterIR)* 
  -- if $nestable_externFunction(typeIR)*
  -- ReturnType_wf: B |- typeIR_ret

;;; Method types

rule CallableType_wf/builtinMethodTypeIR:
  B |- BUILTIN_METHOD _ `( parameterIR* ) `: typeIR_ret
  -- (ParameterType_wf: B |- parameterIR)*
  -- if (~$is_optional_parameterIR(parameterIR))*
  -- ReturnType_wf: B |- typeIR_ret

tbl dec $nestable_externMethod(typeIR) : bool
  hint(prose_true %0 "can be used in an extern method type")
  hint(prose_false %0 "cannot be used in an extern method type")

tbl def $nestable_externMethod =
  | TYPEDEF _ typeIR => $nestable_externMethod(typeIR)
  | parserObjectTypeIR => false
  | controlObjectTypeIR => false
  | packageObjectTypeIR => false
  | tableObjectTypeIR => false
  | _ => true

rulegroup CallableType_wf/externMethodTypeIR {

  rule CallableType_wf/non-abstract:
    B |- EXTERN_METHOD _ `( parameterIR* ) `: typeIR_ret
    -- (ParameterType_wf: B |- parameterIR)*
    -- if (_ _ typeIR _ _ = parameterIR)* 
    -- if $nestable_externMethod(typeIR)*
    -- ReturnType_wf: B |- typeIR_ret

  rule CallableType_wf/abstract:
    B |- EXTERN_METHOD ABSTRACT _ `( parameterIR* ) `: typeIR_ret
    -- (ParameterType_wf: B |- parameterIR)*
    -- if (~$is_optional_parameterIR(parameterIR))*
    -- if (_ _ typeIR _ _ = parameterIR)* 
    -- if $nestable_externMethod(typeIR)*
    -- ReturnType_wf: B |- typeIR_ret

}

tbl dec $nestable_parserApplyMethod(typeIR) : bool
  hint(prose_true %0 "can be used in a parser apply method type")
  hint(prose_false %0 "cannot be used in a parser apply method type")

tbl def $nestable_parserApplyMethod =
  | TYPEDEF _ typeIR => $nestable_parserApplyMethod(typeIR)
  | parserObjectTypeIR => false
  | controlObjectTypeIR => false
  | packageObjectTypeIR => false
  | tableObjectTypeIR => false
  | _ => true

rule CallableType_wf/parserApplyMethodTypeIR:
  B |- PARSER_APPLY `( parameterIR* )
  -- (ParameterType_wf: B |- parameterIR)*
  -- if (~$is_optional_parameterIR(parameterIR))*
  -- if (_ _ typeIR _ _ = parameterIR)* 
  -- if $nestable_parserApplyMethod(typeIR)*

tbl dec $nestable_controlApplyMethod(typeIR) : bool
  hint(prose_true %0 "can be used in a control apply method type")
  hint(prose_false %0 "cannot be used in a control apply method type")

tbl def $nestable_controlApplyMethod =
  | TYPEDEF _ typeIR => $nestable_controlApplyMethod(typeIR)
  | parserObjectTypeIR => false
  | packageObjectTypeIR => false
  | tableObjectTypeIR => false
  | _ => true

rule CallableType_wf/controlApplyMethodTypeIR:
  B |- CONTROL_APPLY `( parameterIR* )
  -- (ParameterType_wf: B |- parameterIR)*
  -- if (~$is_optional_parameterIR(parameterIR))*
  -- if (_ _ typeIR _ _ = parameterIR)* 
  -- if $nestable_controlApplyMethod(typeIR)*

rule CallableType_wf/tableApplyMethodTypeIR:
  B |- TABLE_APPLY `: tableMetadataStructTypeIR

;;
;;;; Well-formedness of callable type definitions
;;

rule CallableTypeDef_wf:
  B |- callableTypeDefIR
  -- if (typeParameterIR_expl*, typeParameterIR_impl*)
      = $typeParameterListIR_of_callableTypeDefIR(callableTypeDefIR)
  -- if typeParameterIR*
      = typeParameterIR_expl* ++ typeParameterIR_impl*
  -- if $distinct_<typeId>(typeParameterIR*)
  -- if callableTypeIR_base
      = $callableTypeIR_of_callableTypeDefIR(callableTypeDefIR)
  -- if B_inner
      = $union_set<typeId>(B, `{ typeParameterIR* })
  -- CallableType_wf: B_inner |- callableTypeIR_base

;;
;;;; Well-formedness of constructor paramter types
;;

rule ConstructorParameterType_wf:
  B |- constructorParameterIR
  -- if _ `EMPTY _ _ _ = constructorParameterIR
  -- ParameterType_wf: B |- constructorParameterIR

;;
;;;; Well-formedness of constructor types
;;

tbl dec $nestable_constructor_extern(typeIR) : bool
  hint(prose_true %0 "can be used in an extern constructor type")
  hint(prose_false %0 "cannot be used in an extern constructor type")

tbl def $nestable_constructor_extern =
  | TYPEDEF _ typeIR => $nestable_constructor_extern(typeIR)
  | parserObjectTypeIR => false
  | controlObjectTypeIR => false
  | packageObjectTypeIR => false
  | tableObjectTypeIR => false
  | _ => true

rule ConstructorType_wf/externObjectTypeIR:
  B |- CONSTRUCTOR `( parameterIR* ) `: typeIR_object
  -- (ConstructorParameterType_wf: B |- parameterIR)*
  -- Type_wf: B |- typeIR_object
  -- if externObjectTypeIR = $unroll_typeIR(typeIR_object)
  -- if (_ _ typeIR _ _ = parameterIR)*
  -- if $nestable_constructor_extern(typeIR)*

tbl dec $nestable_constructor_parser(typeIR) : bool
  hint(prose_true %0 "can be used in a parser constructor type")
  hint(prose_false %0 "cannot be used in a parser constructor type")

tbl def $nestable_constructor_parser =
  | TYPEDEF _ typeIR => $nestable_constructor_parser(typeIR)
  | controlObjectTypeIR => false
  | packageObjectTypeIR => false
  | tableObjectTypeIR => false
  | _ => true

rule ConstructorType_wf/parserObjectTypeIR:
  B |- CONSTRUCTOR `( parameterIR* ) `: typeIR_object
  -- (ConstructorParameterType_wf: B |- parameterIR)*
  -- if (~$is_optional_parameterIR(parameterIR))*
  -- Type_wf: B |- typeIR_object
  -- if parserObjectTypeIR = $unroll_typeIR(typeIR_object)
  -- if (_ _ typeIR _ _ = parameterIR)*
  -- if $nestable_constructor_parser(typeIR)*

tbl dec $nestable_constructor_control(typeIR) : bool
  hint(prose_true %0 "can be used in a control constructor type")
  hint(prose_false %0 "cannot be used in a control constructor type")
tbl def $nestable_constructor_control =
  | TYPEDEF _ typeIR => $nestable_constructor_control(typeIR)
  | parserObjectTypeIR => false
  | packageObjectTypeIR => false
  | tableObjectTypeIR => false
  | _ => true

rule ConstructorType_wf/controlObjectTypeIR:
  B |- CONSTRUCTOR `( parameterIR* ) `: typeIR_object
  -- (ConstructorParameterType_wf: B |- parameterIR)*
  -- if (~$is_optional_parameterIR(parameterIR))*
  -- Type_wf: B |- typeIR_object
  -- if controlObjectTypeIR = $unroll_typeIR(typeIR_object)
  -- if (_ _ typeIR _ _ = parameterIR)*
  -- if $nestable_constructor_control(typeIR)*

rule ConstructorType_wf/tableObjectTypeIR:
  B |- CONSTRUCTOR `( eps ) `: typeIR_object
  -- Type_wf: B |- typeIR_object
  -- if tableObjectTypeIR = $unroll_typeIR(typeIR_object)

tbl dec $nestable_constructor_package(typeIR) : bool
  hint(prose_true %0 "can be used in a package constructor type")
  hint(prose_false %0 "cannot be used in a package constructor type")
tbl def $nestable_constructor_package =
  | TYPEDEF _ typeIR => $nestable_constructor_package(typeIR)
  | tableObjectTypeIR => false
  | _ => true

rule ConstructorType_wf/packageObjectTypeIR:
  B |- CONSTRUCTOR `( parameterIR* ) `: typeIR_object
  -- (ConstructorParameterType_wf: B |- parameterIR)*
  -- Type_wf: B |- typeIR_object
  -- if packageObjectTypeIR = $unroll_typeIR(typeIR_object)
  -- if (_ _ typeIR _ _ = parameterIR)*
  -- if $nestable_constructor_package(typeIR)*

;;
;;;; Well-formedness of constructor definitions
;;

tbl dec $definable_constructor(typeIR) : bool
  hint(prose_true %0 "can be constructed")
  hint(prose_false %0 "cannot be constructed")

tbl def $definable_constructor =
  | TYPEDEF _ typeIR => $definable_constructor(typeIR)
  | externObjectTypeIR => true
  | parserObjectTypeIR => true
  | controlObjectTypeIR => true
  | packageObjectTypeIR => true
  |  _ => false

rule ConstructorTypeDef_wf:
  B |- constructorTypeDefIR
  -- if CONSTRUCTOR `< typeParameterIR_expl* `, typeParameterIR_impl* >
          `( parameterIR* ) `: typeIR_object 
      = constructorTypeDefIR
  -- if $definable_constructor(typeIR_object)
  -- if typeParameterIR*
      = typeParameterIR_expl* ++ typeParameterIR_impl*
  -- if $distinct_<typeId>(typeParameterIR*)
  -- if B_inner
      = $union_set<typeId>(B, `{ typeParameterIR* })
  -- ConstructorType_wf:
      B_inner |- CONSTRUCTOR `( parameterIR* ) `: typeIR_object
