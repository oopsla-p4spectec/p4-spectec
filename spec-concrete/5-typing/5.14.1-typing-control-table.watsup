;;
;; Table key property typing
;;
;; syntax tableKey = expression `: name annotationList `;
;;

tbl dec $compat_table_exact_optional_key(typeIR) : bool
tbl def $compat_table_exact_optional_key =
  | BOOL => true
  | ERROR => true
  | integerTypeIR => true
  | TYPEDEF _ typeIR => $compat_table_exact_optional_key(typeIR)
  | TYPE _ typeIR => $compat_table_exact_optional_key(typeIR)
  | ENUM _ `{ _ } => true
  | ENUM _ `< typeIR > `{ _ } => $compat_table_exact_optional_key(typeIR)
  | _ => false

tbl dec $compat_table_lpm_ternary_range_key(typeIR) : bool
tbl def $compat_table_lpm_ternary_range_key =
  | INT => true
  | INT `< _ > => true
  | BIT `< _ > => true
  | TYPEDEF _ typeIR => $compat_table_lpm_ternary_range_key(typeIR)
  | TYPE _ typeIR => $compat_table_lpm_ternary_range_key(typeIR)
  | ENUM _ `< typeIR > `{ _ } => $compat_table_lpm_ternary_range_key(typeIR)
  | _ => false

dec $compat_table_key(nameIR, typeIR) : bool
  hint(prose_true %1 "can be used with match kind" %0)
  hint(prose_false %1 "cannot be used with match kind" %0)

def $compat_table_key(nameIR, typeIR) = true
  -- if nameIR = "exact" \/ nameIR = "optional" \/ nameIR = "selector"
  -- if $compat_table_exact_optional_key(typeIR)
def $compat_table_key(nameIR, typeIR) = true
  -- if nameIR = "lpm" \/ nameIR = "ternary" \/ nameIR = "range"
  -- if $compat_table_lpm_ternary_range_key(typeIR)
def $compat_table_key(nameIR, typeIR) = false
  -- otherwise

rule TableKey_ok:
  TC TBLC_0 |- expression `: name_matchkind annotationList `;
             : TBLC_2 tableKeyIR
  ---- ;; check expression
  -- Expr_ok: LOCAL TC |- expression : typedExpressionIR
  -- if typeIR = $type_of_typedExpressionIR(typedExpressionIR)
  ---- ;; check that the expression can be embedded in a set
  -- Type_wf: $bound(LOCAL, TC) |- SET `< typeIR >
  ---- ;; create key name
  -- if nameIR_default = $strip_all_whitespace($print_<expression>(expression))
  -- if nameIR_key = $name_annotation_default(annotationList, nameIR_default)
  ---- ;; check match kind
  -- if nameIR_matchkind = $name(name_matchkind)
  -- if MATCH_KIND `. nameIR_matchkind
      = $find_var_value_t(`` nameIR_matchkind, LOCAL, TC)
  ---- ;; check compatibility with the match kind
  -- if $compat_table_key(nameIR_matchkind, typeIR)
  ---- ;; update table context
  -- if TBLC_1
      = $update_mode_tbl(TBLC_0, nameIR_matchkind, typeIR)
  -- if TBLC_2
      = $add_key_tbl(TBLC_1, nameIR_matchkind, typeIR)
  ---- ;; create IR
  -- if tableKeyIR
      = typedExpressionIR `# nameIR_key `: nameIR_matchkind annotationList `;

;;
;; Table key property list typing
;;
;; syntax tableKeyList
;;

rulegroup TableKeys_ok {

  rule TableKeys_ok/nil:
    TC TBLC |- eps : TBLC eps

  rule TableKeys_ok/cons:
    TC TBLC_0 |- (tableKey_h :: tableKey_t*)
               : TBLC_2 (tableKeyIR_h :: tableKeyIR_t*)
    -- TableKey_ok: TC TBLC_0 |- tableKey_h : TBLC_1 tableKeyIR_h
    -- TableKeys_ok: TC TBLC_1 |- tableKey_t* : TBLC_2 tableKeyIR_t*

}

;;
;; Table action property typing
;;
;; syntax tableAction
;;

;;; Splitting data-plane and control-plane parameters

dec $split_dataplane_parameters(parameterIR*)
  : (parameterIR*, parameterIR*)
  hint(prose_in %0 "split into data-plane and control-plane parameters")

def $split_dataplane_parameters(eps) = (eps, eps)
def $split_dataplane_parameters(parameterIR_h :: parameterIR_t*)
  = (parameterIR_data*, parameterIR_h :: parameterIR_control*)
  -- if _ `EMPTY _ _ _ = parameterIR_h
  -- if (parameterIR_data*, parameterIR_control*)
      = $split_dataplane_parameters(parameterIR_t*)
def $split_dataplane_parameters(parameterIR_h :: parameterIR_t*)
  = (parameterIR_h :: parameterIR_data*, parameterIR_control*)
  -- if _ direction _ _ _ = parameterIR_h
  -- if direction =/= `EMPTY
  -- if (parameterIR_data*, parameterIR_control*)
      = $split_dataplane_parameters(parameterIR_t*)

;;; Detecting table apply expressions

dec $is_table_application(typedExpressionIR) : bool
  hint(prose_true %0 "is a table application expression")
  hint(prose_false %0 "is not a table application expression")
def $is_table_application(typedExpressionIR)
  = (typeIR_unroll <: tableMetadataStructTypeIR)
  -- if typeIR = $type_of_typedExpressionIR(typedExpressionIR)
  -- if typeIR_unroll = $unroll_typeIR(typeIR)

rule Call_action_partial_ok:
  TC |- parameterIR* `@ argumentIR*
      : parameterIR_data* `, parameterIR_control*
        `@ argumentIR_cast*
  ---- ;; split parameters into data- and control-planes
  -- if (parameterIR_data*, parameterIR_control*)
      = $split_dataplane_parameters(parameterIR*)
  ---- ;; check arity 
  -- if $(|parameterIR_data*| = |argumentIR*|)
  ---- ;; table apply expressions are not allowed as action arguments
  -- if typedExpressionIR_sub*
      = $subexpressions_of_argumentListIR(argumentIR*)
  -- if $forall_((~$is_table_application(typedExpressionIR_sub))*)
  ---- ;; check calling convention on dataplane parameters
  -- Call_convention_ok:
      LOCAL TC ACTION |- parameterIR_data* `@ argumentIR*
                       : argumentIR_cast*

;;; syntax tableAction = annotationList tableActionReference `;
;;;; syntax tableActionReference

;;;; prefixedNonTypeName
;;;; prefixedNonTypeName `( argumentList )

rulegroup TableAction_ok {

  rule TableAction_ok/prefixedNonTypeName:
    TC TBLC_0 |- annotationList prefixedNonTypeName `;
               : TBLC_1 tableActionIR
    ---- ;; check that the action exists
    -- if prefixedNameIR = $prefixedNonTypeName(prefixedNonTypeName)
    -- if (_, annotationList_action ACTION _ `( parameterIR* ))
        = $find_callableDef_non_overloaded_t(LOCAL, TC, prefixedNameIR)
    -- if annotation_name? = $find_name_annotation_opt(annotationList_action)
    -- if annotationList_update = $add_annotationList(annotationList, annotation_name?)
    ---- ;; check that the action reference is a valid data-plane call
    -- Call_action_partial_ok:
          TC |- parameterIR* `@ eps
              : parameterIR_data* `, parameterIR_control* `@ eps
    ---- ;; update the table context with the action
    -- if TBLC_1
        = $add_action_tbl(TBLC_0, prefixedNameIR, parameterIR*, eps)
    ---- ;; create IR
    -- if tableActionIR
        = annotationList_update (prefixedNameIR eps `( eps ))
            `# `( parameterIR_data* `, parameterIR_control* ) `;

  ;;;; prefixedNonTypeName `( argumentList )

  rule TableAction_ok/prefixedNonTypeName-argumentList:
    TC TBLC_0 |- annotationList (prefixedNonTypeName `( argumentList )) `;
               : TBLC_1 tableActionIR
    ---- ;; check that the action exists
    -- if prefixedNameIR = $prefixedNonTypeName(prefixedNonTypeName)
    -- if (_, annotationList_action ACTION _ `( parameterIR* ))
        = $find_callableDef_non_overloaded_t(LOCAL, TC, prefixedNameIR)
    -- if annotation_name? = $find_name_annotation_opt(annotationList_action)
    -- if annotationList_update = $add_annotationList(annotationList, annotation_name?)
    ---- ;; check arguments
    -- ArgumentList_ok:
        LOCAL TC |- argumentList : argumentIR*
    ---- ;; check that the action reference is a valid data-plane call
    -- Call_action_partial_ok:
        TC |- parameterIR* `@ argumentIR*
            : parameterIR_data* `, parameterIR_control* `@ argumentIR_cast*
    ---- ;; update the table context with the action
    -- if TBLC_1
        = $add_action_tbl(TBLC_0, prefixedNameIR, parameterIR*, argumentIR_cast*)
    ---- ;; create IR
    -- if tableActionIR
        = annotationList_update (prefixedNameIR eps `( argumentIR_cast* ))
            `# `( parameterIR_data* `, parameterIR_control* ) `;

}

;;
;; Table action property list typing
;;
;; syntax tableActionList
;;

rulegroup TableActions_ok {

  rule TableActions_ok/nil:
    TC TBLC |- eps : TBLC eps

  rule TableActions_ok/cons:
    TC TBLC_0 |- (tableAction_h :: tableAction_t*)
               : TBLC_2 (tableActionIR_h :: tableActionIR_t*)
    -- TableAction_ok: TC TBLC_0 |- tableAction_h : TBLC_1 tableActionIR_h
    -- TableActions_ok: TC TBLC_1 |- tableAction_t* : TBLC_2 tableActionIR_t*

}

;;
;; Table default action property typing
;;
;; syntax tableDefaultAction (doesn't exist in the grammar)
;;

rule Call_action_default_ok:
  TC |- parameterIR* `@ argumentIR*
      : parameterIR_data* `, parameterIR_control*
        `@ argumentIR_cast*
  ---- ;; split parameters into data- and control-planes
  -- if (parameterIR_data*, parameterIR_control*)
      = $split_dataplane_parameters(parameterIR*)
  ---- ;; table apply expressions are not allowed as action arguments
  -- if typedExpressionIR_sub*
      = $subexpressions_of_argumentListIR(argumentIR*)
  -- if $forall_((~$is_table_application(typedExpressionIR_sub))*)
  ---- ;; check calling convention
  -- Call_convention_ok:
      LOCAL TC ACTION |- parameterIR* `@ argumentIR*
                       : argumentIR_cast*

;;; prefixedNonTypeName
;;; prefixedNonTypeName `( argumentList )

rulegroup TableDefaultAction_ok {

  rule TableDefaultAction_ok/prefixedNonTypeName:
    TC TBLC |- `= prefixedNonTypeName
             : prefixedNameIR eps `( eps )
    ---- ;; find matching action
    -- if prefixedNameIR = $prefixedNonTypeName(prefixedNonTypeName)
    -- if (eps, eps) = $find_action(TBLC, prefixedNameIR) 

  rule TableDefaultAction_ok/prefixedNonTypeName-argumentList:
    TC TBLC |- `= (prefixedNonTypeName `( argumentList ))
             : prefixedNameIR eps `( argumentIR_cast* )
    ---- ;; find matching action
    -- if prefixedNameIR = $prefixedNonTypeName(prefixedNonTypeName)
    -- if (parameterIR_action*, argumentIR_action*)
        = $find_action(TBLC, prefixedNameIR)
    ---- ;; check arguments
    -- ArgumentList_ok:
        LOCAL TC |- argumentList : argumentIR*
    ---- ;; check calling convention
    -- Call_action_default_ok:
        TC |- parameterIR_action* `@ argumentIR*
            : parameterIR_action_data* `, parameterIR_action_control*
              `@ argumentIR_cast*
    ---- ;; arguments must be syntatcially equivalent to
    ---- ;; dataplane arguments specified in the actions list property
    -- if argumentIR_action_data*
        = argumentIR_action*[0 : |parameterIR_action_data*|] 
    -- if argumentIR_cast_data*
        = argumentIR_cast*[0 : |parameterIR_action_data*|]
    -- if (argumentIR_action_data = argumentIR_cast_data)*

}

;;
;; Table entry property typing
;;
;; syntax tableEntry
;;

;;
;;;; Table entry simple keyset typing
;;;;
;;;; syntax simpleKeysetExpression
;;

relation TableEntry_keyset_simple_ok:
  typingContext tableContext |- matchKey `@ simpleKeysetExpression
                              : tableEntryState simpleKeysetExpressionIR
  hint(input %0 %1 %2 %3)

;;;;;; expression

;; To account for the patterns used in:
;;  * action-two-params.p4
;;  * op_bin.p4
;;  * table-entries-no-arg-actions.p4

dec $is_singleton_list_expression(expression) : bool
  hint(prose_true %0 "is a singleton list expression")
  hint(prose_false %0 "is not a singleton list expression")

def $is_singleton_list_expression(expression) = true
  -- if expression = `{ expression_elem `EMPTY }
def $is_singleton_list_expression(expression) = false
  -- otherwise

rulegroup TableEntry_keyset_simple_ok/expression {

  rule TableEntry_keyset_simple_ok/lpm:
    TC TBLC |- (typeIR_key `: "lpm") `@ expression
             : (LPM n) typedExpressionIR_set
    ---- ;; check match mode
    -- if TBLC.MODE = NOPRILPM n
    ---- ;; check expression
    -- Expr_ok: LOCAL TC |- expression : typedExpressionIR
    -- if typeIR = $type_of_typedExpressionIR(typedExpressionIR)
    -- if ctk = $ctk_of_typedExpressionIR(typedExpressionIR)
    ---- ;; check compatibility with the key type
    -- Cast_impl: typeIR -> typeIR_key
    ---- ;; lift the expression to set type
    -- if typeIR_set = SET `< typeIR_key >
    -- if typedExpressionIR_set
        = (`( typeIR_set ) typedExpressionIR) `# `( typeIR_set ctk )

  rule TableEntry_keyset_simple_ok/non-lpm-singleton-seq:
    TC TBLC |- (typeIR_key `: nameIR_matchkind) `@ expression
             : NON_LPM typedExpressionIR_set
    ---- ;; check match mode
    -- if nameIR_matchkind =/= "lpm"
    ---- ;; if a singleton sequence
    -- if $is_singleton_list_expression(expression)
    -- if `{ expression_elem `EMPTY } = expression
    ---- ;; check expression
    -- Expr_ok: LOCAL TC |- expression_elem : typedExpressionIR
    -- if typeIR = $type_of_typedExpressionIR(typedExpressionIR)
    -- if ctk = $ctk_of_typedExpressionIR(typedExpressionIR)
    ---- ;; check compatibility with the key type
    -- Cast_impl: typeIR -> typeIR_key
    ---- ;; lift the expression to set type
    -- if typeIR_set = SET `< typeIR_key >
    -- if typedExpressionIR_set
        = (`( typeIR_set ) typedExpressionIR) `# `( typeIR_set ctk )

  rule TableEntry_keyset_simple_ok/non-lpm-non-singleton-seq:
    TC TBLC |- (typeIR_key `: nameIR_matchkind) `@ expression
             : NON_LPM typedExpressionIR_set
    ---- ;; check match mode
    -- if nameIR_matchkind =/= "lpm"
    ---- ;; if not a singleton sequence
    -- if ~$is_singleton_list_expression(expression)
    ---- ;; check expression
    -- Expr_ok: LOCAL TC |- expression : typedExpressionIR
    -- if typeIR = $type_of_typedExpressionIR(typedExpressionIR)
    -- if ctk = $ctk_of_typedExpressionIR(typedExpressionIR)
    ---- ;; check compatibility with the key type
    -- Cast_impl: typeIR -> typeIR_key
    ---- ;; lift the expression to set type
    -- if typeIR_set = SET `< typeIR_key >
    -- if typedExpressionIR_set
        = (`( typeIR_set ) typedExpressionIR) `# `( typeIR_set ctk )

}

;;;;;; expression `&&& expression

rulegroup TableEntry_keyset_simple_ok/mask {

  rule TableEntry_keyset_simple_ok/lpm:
    TC TBLC |- (typeIR_key `: "lpm") `@ (expression_l `&&& expression_r)
             : (LPM n_prefix) (typedExpressionIR_l_reduced `&&& typedExpressionIR_r_reduced)
    ---- ;; check match mode
    -- if TBLC.MODE = NOPRILPM n
    ---- ;; check both sides
    -- Expr_ok: LOCAL TC |- expression_l : typedExpressionIR_l
    -- Expr_ok: LOCAL TC |- expression_r : typedExpressionIR_r
    ---- ;; check that the types are compatible
    ---- ;; while inserting implicit casts if necessary
    -- if typedExpressionIR_l_cast
        = $cast_unary(typedExpressionIR_l, typeIR_key)
    -- if typedExpressionIR_r_cast
        = $cast_unary(typedExpressionIR_r, typeIR_key)
    -- if (typedExpressionIR_l_reduced, typedExpressionIR_r_reduced)
          = $reduce_serenum_binary(
              typedExpressionIR_l_cast,
              typedExpressionIR_r_cast,
              def $compat_mask
            )
    ---- ;; fetch the type
    -- if ctk_r_reduced
        = $ctk_of_typedExpressionIR(typedExpressionIR_r_reduced)
    ---- ;; statically evaluate the right hand side to get its width
    -- if ctk_r_reduced = LCTK
    -- Expr_eval_lctk: LOCAL TC |- typedExpressionIR_r_reduced ~> integerValue_r
    -- if n_r = $nat_of_integerValue(integerValue_r)
    ---- ;; compute the table entry state
    -- if n_prefix = $tableEntry_lpm_prefix(n W $int_to_bitstr(n, n_r))

  rule TableEntry_keyset_simple_ok/ternary:
    TC TBLC |- (typeIR_key `: "ternary") `@ (expression_l `&&& expression_r)
             : NON_LPM (typedExpressionIR_l_reduced `&&& typedExpressionIR_r_reduced)
    ---- ;; check both sides
    -- Expr_ok: LOCAL TC |- expression_l : typedExpressionIR_l
    -- Expr_ok: LOCAL TC |- expression_r : typedExpressionIR_r
    ---- ;; check that the types are compatible
    ---- ;; while inserting implicit casts if necessary
    -- if typedExpressionIR_l_cast
        = $cast_unary(typedExpressionIR_l, typeIR_key)
    -- if typedExpressionIR_r_cast
        = $cast_unary(typedExpressionIR_r, typeIR_key)
    -- if (typedExpressionIR_l_reduced, typedExpressionIR_r_reduced)
          = $reduce_serenum_binary(
              typedExpressionIR_l_cast,
              typedExpressionIR_r_cast,
              def $compat_mask)

}

;;;;;; expression `.. expression

rule TableEntry_keyset_simple_ok/range:
  TC TBLC |- (typeIR_key `: "range") `@ (expression_l `.. expression_r)
           : NON_LPM (typedExpressionIR_l_reduced `.. typedExpressionIR_r_reduced)
  ---- ;; check both sides
  -- Expr_ok: LOCAL TC |- expression_l : typedExpressionIR_l
  -- Expr_ok: LOCAL TC |- expression_r : typedExpressionIR_r
  ---- ;; check that the types are compatible
  ---- ;; while inserting implicit casts if necessary
  -- if typedExpressionIR_l_cast
      = $cast_unary(typedExpressionIR_l, typeIR_key)
  -- if typedExpressionIR_r_cast
      = $cast_unary(typedExpressionIR_r, typeIR_key)
  -- if (typedExpressionIR_l_reduced, typedExpressionIR_r_reduced)
        = $reduce_serenum_binary(
            typedExpressionIR_l_cast,
            typedExpressionIR_r_cast,
            def $compat_range)

;;;;;; DEFAULT

rulegroup TableEntry_keyset_simple_ok/default {

  rule TableEntry_keyset_simple_ok/lpm:
    TC TBLC |- (typeIR_key `: "lpm") `@ DEFAULT
             : (LPM n) DEFAULT
    ---- ;; check match mode
    -- if TBLC.MODE = NOPRILPM n

  rule TableEntry_keyset_simple_ok/non-lpm:
    TC TBLC |- (typeIR_key `: nameIR_matchkind) `@ DEFAULT
             : NON_LPM DEFAULT
    -- if nameIR_matchkind =/= "lpm"
    ---- ;; cannot use default for exact match
    -- if nameIR_matchkind =/= "exact"

}

;;;;;; `_

rulegroup TableEntry_keyset_simple_ok/dontcare { 

  rule TableEntry_keyset_simple_ok/lpm:
    TC TBLC |- (typeIR_key `: "lpm") `@ `_
             : (LPM 0) `_
    ---- ;; check match mode
    -- if TBLC.MODE = NOPRILPM _

  rule TableEntry_keyset_simple_ok/non-lpm:
    TC TBLC |- (typeIR_key `: nameIR_matchkind) `@ `_
             : NON_LPM `_
    -- if nameIR_matchkind =/= "lpm"
    ---- ;; cannot use don't care for exact match
    -- if nameIR_matchkind =/= "exact"

}

;;
