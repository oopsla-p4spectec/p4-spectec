;;;;; DEFAULT
;;;;; `( DEFAULT )

rulegroup TableEntry_keyset_ok/default {

  rule TableEntry_keyset_ok/simple-noprilpm:
    TC TBLC |- DEFAULT : TBLS DEFAULT
    -- if TBLC.MODE = NOPRILPM n
    -- if TBLS = LPM n

  rule TableEntry_keyset_ok/simple-non-noprilpm:
    TC TBLC |- DEFAULT : TBLS DEFAULT
    -- if TBLC.MODE = NOPRI \/ TBLC.MODE = PRI \/ TBLC.MODE = PRILPM
    -- if TBLS = NON_LPM

  rule TableEntry_keyset_ok/tuple-noprilpm:
    TC TBLC |- `( DEFAULT ) : TBLS (`( DEFAULT ))
    -- if TBLC.MODE = NOPRILPM n
    -- if TBLS = LPM n

  rule TableEntry_keyset_ok/tuple-non-noprilpm:
    TC TBLC |- `( DEFAULT ) : TBLS (`( DEFAULT ))
    -- if TBLC.MODE = NOPRI \/ TBLC.MODE = PRI \/ TBLC.MODE = PRILPM
    -- if TBLS = NON_LPM

