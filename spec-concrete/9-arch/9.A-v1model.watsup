;;
;; V1Model architecture initialization
;;

relation V1Model_init:
  |- p4program : evalContext arch
  hint(input %0)
  hint(prose_in "initializing the evaluation context and state for"
                %0 "in the V1Model architecture")
  hint(prose_out "the resulting evaluation context" %1#" and state" %2)

rule V1Model_init:
  |- p4program : EC ARCH
  ---- ;; instantiate the program
  -- Program_init:
      |- p4program : EC STO
  -- if ARCH = { STATE $init_archState, STORE STO }

;;
;; V1Model packet setup
;;

relation V1Model_init_packet_in:
  evalContext arch |- objectState : evalContext arch
  hint(input %0 %1 %2)

rule V1Model_init_packet_in:
  EC_0 ARCH_0 |- objectState_packet_in : EC_1 ARCH_2
  ---- ;; initialize packet_in extern
  -- Extern_init: EC_0 ARCH_0 |- "packet_in" "packet_in" : ARCH_1
  ---- ;; add packet_in to context
  -- if EC_1 = $add_var_e(GLOBAL, EC_0, `` "packet_in", REF "packet_in")
  ---- ;; initialize packet_in state and update arch
  -- if externObject_packet_in = $find_object_e(ARCH_1, [ "packet_in" ])
  -- if EXTERN typeId `< theta > `{ _ frame externMethodDefEnv }
      = externObject_packet_in
  -- if externObject_packet_in_init
      = EXTERN typeId `< theta > `{ objectState_packet_in frame externMethodDefEnv }
  -- if ARCH_2
      = $add_object_e(ARCH_1, [ "packet_in" ], externObject_packet_in_init)

relation V1Model_init_packet_out:
  evalContext arch |- objectState : evalContext arch
  hint(input %0 %1 %2)

rule V1Model_init_packet_out:
  EC_0 ARCH_0 |- objectState_packet_out : EC_1 ARCH_2
  ---- ;; initialize packet_out extern
  -- Extern_init: EC_0 ARCH_0 |- "packet_out" "packet_out" : ARCH_1
  ---- ;; add packet_out to context
  -- if EC_1 = $add_var_e(GLOBAL, EC_0, `` "packet_out", REF "packet_out")
  ---- ;; initialize packet_out state and update arch
  -- if externObject_packet_out = $find_object_e(ARCH_1, [ "packet_out" ])
  -- if EXTERN typeId `< theta > `{ _ frame externMethodDefEnv }
      = externObject_packet_out
  -- if externObject_packet_out_init
      = EXTERN typeId `< theta > `{ objectState_packet_out frame externMethodDefEnv }
  -- if ARCH_2
      = $add_object_e(ARCH_1, [ "packet_out" ], externObject_packet_out_init)

relation V1Model_init_globals:
  evalContext arch |- int : evalContext
  hint(input %0 %1 %2)

rule V1Model_init_globals:
  EC_0 ARCH |- i_port : EC_4
  ---- ;; hdr and meta
  -- if PACKAGE `< theta > `{ _ }
      = $find_object_e(ARCH, [ "main" ])
  -- if typeIR_hdr = $find_map<typeId, typeIR>(theta, "H")
  -- if typeIR_meta = $find_map<typeId, typeIR>(theta, "M")
  -- Var_init: EC_0 |- typeIR_hdr "hdr" : EC_1
  -- Var_init: EC_1 |- typeIR_meta "meta" : EC_2
  ---- ;; standard_metadata
  -- if typeDefIR_standard_metadata
      = $find_typeDef_e(GLOBAL, EC_2, `` "standard_metadata_t")
  -- if typeIR_std_meta
      = $specialize_typeDefIR(typeDefIR_standard_metadata, eps)
  -- Var_init: EC_2 |- typeIR_std_meta "standard_metadata" : EC_3
  ---- ;; setup port
  -- if storageReference_port = (`` "standard_metadata") `. "ingress_port"
  -- if value_port = 9 W i_port
  -- Lvalue_write:
      GLOBAL EC_3 ARCH |- storageReference_port -> value_port : EC_4

;;
;; Setup helpers
;;

dec $V1Model_setup_packet_in_argument(evalContext) : argumentIR
def $V1Model_setup_packet_in_argument(EC) = argumentIR_packet_in
  -- if typeDefIR_packet_in
      = $find_typeDef_e(GLOBAL, EC, `` "packet_in")
  -- if typeIR_packet_in
      = $specialize_typeDefIR(typeDefIR_packet_in, eps)
  -- if argumentIR_packet_in
      = (`. "packet_in") `# `( typeIR_packet_in CTK )

dec $V1Model_setup_packet_out_argument(evalContext) : argumentIR
def $V1Model_setup_packet_out_argument(EC) = argumentIR_packet_out
  -- if typeDefIR_packet_out
      = $find_typeDef_e(GLOBAL, EC, `` "packet_out")
  -- if typeIR_packet_out
      = $specialize_typeDefIR(typeDefIR_packet_out, eps)
  -- if argumentIR_packet_out
      = (`. "packet_out") `# `( typeIR_packet_out CTK )

dec $V1Model_setup_hdr_argument(arch) : argumentIR
def $V1Model_setup_hdr_argument(ARCH) = argumentIR_hdr
  -- if PACKAGE `< theta > `{ _ }
      = $find_object_e(ARCH, [ "main" ])
  -- if typeIR_hdr = $find_map<typeId, typeIR>(theta, "H") 
  -- if argumentIR_hdr
      = (`. "hdr") `# `( typeIR_hdr DYN )

dec $V1Model_setup_meta_argument(arch) : argumentIR
def $V1Model_setup_meta_argument(ARCH) = argumentIR_meta
  -- if PACKAGE `< theta > `{ _ }
      = $find_object_e(ARCH, [ "main" ])
  -- if typeIR_meta = $find_map<typeId, typeIR>(theta, "M") 
  -- if argumentIR_meta
      = (`. "meta") `# `( typeIR_meta DYN )

dec $V1Model_setup_standard_metadata_argument(evalContext) : argumentIR
def $V1Model_setup_standard_metadata_argument(EC) = argumentIR_standard_metadata
  -- if typeDefIR_standard_metadata
      = $find_typeDef_e(GLOBAL, EC, `` "standard_metadata_t")
  -- if typeIR_std_meta
      = $specialize_typeDefIR(typeDefIR_standard_metadata, eps)
  -- if argumentIR_standard_metadata
      = (`. "standard_metadata") `# `( typeIR_std_meta DYN )

dec $V1Model_setup_main_callee(evalContext, arch) : typedExpressionIR
def $V1Model_setup_main_callee(EC, ARCH) = typedExpressionIR_main
  ---- ;; get package type definition
  -- if typeDefIR_package
      = $find_typeDef_e(GLOBAL, EC, `` "V1Switch")
  ---- ;; get package type arguments
  -- if PACKAGE `< theta > `{ _ }
      = $find_object_e(ARCH, [ "main" ])
  -- if typeIR_hdr = $find_map<typeId, typeIR>(theta, "H")
  -- if typeIR_meta = $find_map<typeId, typeIR>(theta, "M")
  ---- ;; create callee
  -- if typeIR_package
      = $specialize_typeDefIR(typeDefIR_package, [ typeIR_hdr, typeIR_meta ])
  -- if typedExpressionIR_main
      = (`` "main") `# `( typeIR_package CTK )

dec $V1Model_setup_parser_callee(
    evalContext, arch, typedExpressionIR)
  : typedExpressionIR
def $V1Model_setup_parser_callee(
    EC, ARCH, typedExpressionIR_main)
  = typedExpressionIR_parser
  ---- ;; get parser type definition
  -- if typeDefIR_parser = $find_typeDef_e(GLOBAL, EC, `` "Parser")
  ---- ;; get package type arguments
  -- if PACKAGE `< theta > `{ _ }
      = $find_object_e(ARCH, [ "main" ])
  -- if typeIR_hdr = $find_map<typeId, typeIR>(theta, "H")
  -- if typeIR_meta = $find_map<typeId, typeIR>(theta, "M")
  ---- ;; create callee
  -- if typeIR_parser
      = $specialize_typeDefIR(typeDefIR_parser, [ typeIR_hdr, typeIR_meta ])
  -- if typedExpressionIR_parser
      = (typedExpressionIR_main `. "p") `# `( typeIR_parser CTK )

dec $V1Model_setup_verify_callee(
    evalContext, arch, typedExpressionIR)
  : typedExpressionIR
def $V1Model_setup_verify_callee(
    EC, ARCH, typedExpressionIR_main)
  = typedExpressionIR_verify
  ---- ;; get parser type definition
  -- if typeDefIR_verify
      = $find_typeDef_e(GLOBAL, EC, `` "VerifyChecksum")
  ---- ;; get package type arguments
  -- if PACKAGE `< theta > `{ _ }
      = $find_object_e(ARCH, [ "main" ])
  -- if typeIR_hdr = $find_map<typeId, typeIR>(theta, "H")
  -- if typeIR_meta = $find_map<typeId, typeIR>(theta, "M")
  ---- ;; create callee
  -- if typeIR_verify
      = $specialize_typeDefIR(typeDefIR_verify, [ typeIR_hdr, typeIR_meta ])
  -- if typedExpressionIR_verify
      = (typedExpressionIR_main `. "vr") `# `( typeIR_verify CTK )

