;;
;; V1Model specific annotations
;;

dec $field_list_annotation_index(annotationList) : integerLiteral?
dec $field_list_annotation_index'(annotation) : integerLiteral?

def $field_list_annotation_index(annotationList) = integerLiteral_fixbit
  -- if annotation* = $flatten_annotationList(annotationList)
  -- if (integerLiteral? = $field_list_annotation_index'(annotation))*
  -- if integerLiteral_found = integerLiteral?*
  ---- ;; field list index is bit<8>
  -- if integerLiteral_fixbit = $cast_op(BIT `< 8 >, integerLiteral_found)
def $field_list_annotation_index(annotationList) = eps
  -- otherwise

def $field_list_annotation_index'(`@ name `( annotationBody )) = integerLiteral
  -- if "field_list" = $name(name)
  -- if `EMPTY integerLiteral = annotationBody
def $field_list_annotation_index'(annotation) = eps
  -- otherwise

dec $fields_with_field_list_index(fieldTypeIR*, integerLiteral) : fieldTypeIR*
dec $field_has_field_list_index(fieldTypeIR, integerLiteral) : bool

def $fields_with_field_list_index(fieldTypeIR_h :: fieldTypeIR_t*, integerLiteral) = fieldTypeIR*
  -- if $field_has_field_list_index(fieldTypeIR_h, integerLiteral)
  -- if fieldTypeIR* = fieldTypeIR_h :: $fields_with_field_list_index(fieldTypeIR_t*, integerLiteral)
def $fields_with_field_list_index(fieldTypeIR_h :: fieldTypeIR_t*, integerLiteral) = fieldTypeIR*
  -- if ~$field_has_field_list_index(fieldTypeIR_h, integerLiteral)
  -- if fieldTypeIR* = $fields_with_field_list_index(fieldTypeIR_t*, integerLiteral)
def $fields_with_field_list_index(eps, integerLiteral) = eps

def $field_has_field_list_index(annotationList typeIR nameIR `;, integerLiteral)
  = $bin_eq(integerLiteral, integerLiteral_found)
  -- if integerLiteral_found = $field_list_annotation_index(annotationList)
def $field_has_field_list_index(_, _) = false
  -- otherwise

;;
;; Metadata setup after field-preserving extern calls
;;

dec $V1Model_meta_fields_of_index(arch, integerLiteral) : nameIR*
def $V1Model_meta_fields_of_index(ARCH, integerLiteral_index) = nameIR_field*
  -- if PACKAGE `< theta > `{ _ } = $find_object_e(ARCH, [ "main" ])
  -- if typeIR_meta = $find_map<typeId, typeIR>(theta, "M")
  -- if STRUCT _ `< _ > `{ fieldTypeIR* } = typeIR_meta
  -- if (_ _ nameIR `;)* = fieldTypeIR*
  -- if (_ _ nameIR_field `;)* = $fields_with_field_list_index(fieldTypeIR*, integerLiteral_index)

relation V1Model_copy_meta_fields:
  evalContext evalContext arch |- nameIR* : evalContext
  hint(input %0 %1 %2 %3)

rulegroup V1Model_copy_meta_fields {

  rule V1Model_copy_meta_fields/nil:
    EC_capture EC_0 ARCH |- eps : EC_0

  rule V1Model_copy_meta_fields/cons:
    EC_capture EC_0 ARCH |- (nameIR_h :: nameIR_t*) : EC_2
    -- if storageReference_h = (`` "meta") `. nameIR_h
    -- Lvalue_read: 
        GLOBAL EC_capture ARCH |- storageReference_h : value_h
    -- Lvalue_write:
        GLOBAL EC_0 ARCH |- storageReference_h -> value_h : EC_1
    -- V1Model_copy_meta_fields:
        EC_capture EC_1 ARCH |- nameIR_t* : EC_2

}

relation V1Model_setup_preserved_meta_fields:
  evalContext arch |- integerLiteral : evalContext
  hint(input %0 %1 %2)

rule V1Model_setup_preserved_meta_fields:
  EC_0 ARCH |- integerLiteral_index : EC_2
  -- if PACKAGE `< theta > `{ _ } = $find_object_e(ARCH, [ "main" ])
  -- if typeIR_meta = $find_map<typeId, typeIR>(theta, "M")
  -- Var_init: EC_0 |- typeIR_meta "meta" : EC_1
  -- if nameIR_field*
      = $V1Model_meta_fields_of_index(ARCH, integerLiteral_index)
  -- V1Model_copy_meta_fields:
      EC_0 EC_1 ARCH |- nameIR_field* : EC_2
