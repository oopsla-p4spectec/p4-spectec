;;
;; V1Model parser invocation
;;

relation V1Model_parser:
  evalContext arch |- evalContext arch transitionResult
  hint(input %0 %1)

rulegroup V1Model_parser {

  rule V1Model_parser/cont:
    EC_0 ARCH_0 |- EC_1 ARCH_1 ACCEPT
    ---- ;; prepare the arguments
    -- if argumentIR_packet_in
        = $V1Model_setup_packet_in_argument(EC_0)
    -- if argumentIR_hdr
        = $V1Model_setup_hdr_argument(ARCH_0)
    -- if argumentIR_meta
        = $V1Model_setup_meta_argument(ARCH_0)
    -- if argumentIR_standard_metadata
        = $V1Model_setup_standard_metadata_argument(EC_0)
    -- if argumentIR*
        = [ argumentIR_packet_in, argumentIR_hdr,
            argumentIR_meta, argumentIR_standard_metadata ]
    ---- ;; invoke the parser object (main.p)
    -- if typedExpressionIR_main
        = $V1Model_setup_main_callee(EC_0, ARCH_0)
    -- if typedExpressionIR_p
        = $V1Model_setup_parser_callee(EC_0, ARCH_0, typedExpressionIR_main)
    -- if callableTargetIR = typedExpressionIR_p `. "apply"
    -- Stmt_eval:
        GLOBAL EC_0 ARCH_0 |- callableTargetIR `< eps > `( argumentIR* ) `;
                            : EC_1 ARCH_1 `EMPTY

  rule V1Model_parser/reject:
    EC_0 ARCH_0 |- EC_1 ARCH_1 rejectTransitionResult
    ---- ;; prepare the arguments
    -- if argumentIR_packet_in
        = $V1Model_setup_packet_in_argument(EC_0)
    -- if argumentIR_hdr
        = $V1Model_setup_hdr_argument(ARCH_0)
    -- if argumentIR_meta
        = $V1Model_setup_meta_argument(ARCH_0)
    -- if argumentIR_standard_metadata
        = $V1Model_setup_standard_metadata_argument(EC_0)
    -- if argumentIR*
        = [ argumentIR_packet_in, argumentIR_hdr,
            argumentIR_meta, argumentIR_standard_metadata ]
    ---- ;; invoke the parser object (main.p)
    -- if typedExpressionIR_main
        = $V1Model_setup_main_callee(EC_0, ARCH_0)
    -- if typedExpressionIR_p
        = $V1Model_setup_parser_callee(EC_0, ARCH_0, typedExpressionIR_main)
    -- if callableTargetIR = typedExpressionIR_p `. "apply"
    -- Stmt_eval:
        GLOBAL EC_0 ARCH_0 |- callableTargetIR `< eps > `( argumentIR* ) `;
                            : EC_1 ARCH_1 rejectTransitionResult

}

;;
;; V1Model verify invocation
;;

relation V1Model_verify:
  evalContext arch |- evalContext arch callResult
  hint(input %0 %1)

rulegroup V1Model_verify {

  rule V1Model_verify/continueEmptyResult:
    EC_0 ARCH_0 |- EC_1 ARCH_1 (RETURN eps)
    ---- ;; prepare the arguments
    -- if argumentIR_hdr
        = $V1Model_setup_hdr_argument(ARCH_0)
    -- if argumentIR_meta
        = $V1Model_setup_meta_argument(ARCH_0)
    -- if argumentIR* = [ argumentIR_hdr, argumentIR_meta ]
    ---- ;; invoke the verify object (main.vr)
    -- if typedExpressionIR_main
        = $V1Model_setup_main_callee(EC_0, ARCH_0)
    -- if typedExpressionIR_vr
        = $V1Model_setup_verify_callee(EC_0, ARCH_0, typedExpressionIR_main)
    -- if callableTargetIR = typedExpressionIR_vr `. "apply"
    -- Stmt_eval:
        GLOBAL EC_0 ARCH_0 |- callableTargetIR `< eps > `( argumentIR* ) `;
                            : EC_1 ARCH_1 `EMPTY

  rule V1Model_verify/exit:
    EC_0 ARCH_0 |- EC_1 ARCH_1 EXIT
    ---- ;; prepare the arguments
    -- if argumentIR_hdr
        = $V1Model_setup_hdr_argument(ARCH_0)
    -- if argumentIR_meta
        = $V1Model_setup_meta_argument(ARCH_0)
    -- if argumentIR* = [ argumentIR_hdr, argumentIR_meta ]
    ---- ;; invoke the verify object (main.vr)
    -- if typedExpressionIR_main
        = $V1Model_setup_main_callee(EC_0, ARCH_0)
    -- if typedExpressionIR_vr
        = $V1Model_setup_verify_callee(EC_0, ARCH_0, typedExpressionIR_main)
    -- if callableTargetIR = typedExpressionIR_vr `. "apply"
    -- Stmt_eval:
        GLOBAL EC_0 ARCH_0 |- callableTargetIR `< eps > `( argumentIR* ) `;
                            : EC_1 ARCH_1 EXIT

}

