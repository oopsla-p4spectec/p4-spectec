  -- if typeIR_meta = $find_map<typeId, typeIR>(theta, "M")
  ---- ;; create callee
  -- if typeIR_ingress
      = $specialize_typeDefIR(typeDefIR_ingress, [ typeIR_hdr, typeIR_meta ])
  -- if typedExpressionIR_ingress
      = (typedExpressionIR_main `. "ig") `# `( typeIR_ingress CTK )

